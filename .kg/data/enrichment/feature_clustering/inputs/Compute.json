      "id": "script:Compute:LotkaVolterra",
      "name": "LotkaVolterra",
      "language": "javascript",
      "description": "Model describes the dynamics of biological systems in which two species interact, one as a predator and the other as prey."
    },
    {
      "id": "script:Compute:Vmax",
      "name": "Vmax",
      "language": "r",
      "description": "Predict the minimum filter size required for the separation of effluent from bioreactors, given the constraints of batch size and total batch time based on a training dataset of time vs filtrate…"
    },
    {
      "id": "script:Compute:Object cooling",
      "name": "Object cooling",
      "language": "javascript",
      "description": "Uses Newton's law of cooling to simulate object cooling process. Default values are for cube of boiling water in air."
