      "evidence_summary": "ivpFileHandler (role: fileHandler, ext: ipv) and previewIvp (role: fileViewer, fileViewer: ivp) share the ivp file-format name root and complementary file-handling roles."
    },
    {
      "id": "feature:DiffStudio:ode-serialization-api",
      "name": "ODE Serialization API",
      "description": "Developer-facing API for converting textual ODE definitions into structured objects or executable JavaScript code, enabling programmatic embedding of ODE models.",
