{
  "name": "datagrok-tools",
  "version": "6.4.1",
  "description": "Utility to upload and publish packages to Datagrok",
  "homepage": "https://github.com/datagrok-ai/public/tree/master/tools#readme",
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@typescript-eslint/typescript-estree": "^8.61.1",
    "@typescript-eslint/visitor-keys": "^8.61.1",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "datagrok-api": "^1.27.6",
    "estraverse": "^5.3.0",
    "glob": "^13.0.6",
    "ignore-walk": "^6.0.5",
    "inquirer": "^8.2.7",
    "js-yaml": "^4.2.0",
    "minimist": "^1.2.8",
    "node-fetch": "^2.7.0",
    "papaparse": "^5.5.3",
    "puppeteer": "^24.15.0",
    "ts-morph": "^28.0.0"
  },
  "scripts": {
    "link": "npm link",
    "prepublishOnly": "node build.js",
    "babel": "node build.js",
    "build": "node build.js",
    "update:ivp-parser": "esbuild plugins/ivp-parser.entry.mjs --bundle --format=cjs --platform=node --alias:diff-grok=../libraries/compute-utils/node_modules/diff-grok --outfile=plugins/ivp-parser.bundle.cjs",
    "debug-source-map": "node build.js --source-maps",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run"
  },
  "bin": {
    "datagrok-upload": "./bin/_deprecated/upload.js",
    "grok": "./bin/grok.js",
    "datagrok-tools": "./bin/grok.js"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "chrome": "100"
          },
          "exclude": [
            "@babel/plugin-transform-async-to-generator"
          ]
        }
      ],
      "@babel/preset-typescript"
    ],
    "plugins": [
      "@babel/plugin-transform-runtime"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.0",
    "@eslint/js": "^9.39.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^6.0.3",
    "@types/ignore-walk": "^4.0.3",
    "@types/inquirer": "^8.2.10",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.3.15",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.0",
    "globals": "^17.6.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3.2.6",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "archiver-utils": {
      "glob": "$glob"
    }
  }
}
