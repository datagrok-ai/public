{
  "name": "@datagrok/inventory",
  "friendlyName": "Inventory",
  "version": "0.0.1",
  "author": {
    "name": "Andrew Skalkin",
    "email": "askalkin@datagrok.ai"
  },
  "description": "Inventory — reference app for hybrid domain schemas: relational items + per-department jsonb columns, batch upsert by SKU, optimistic stock adjustments, aggregation",
  "dependencies": {
    "@datagrok-libraries/test": "^1.1.0",
    "datagrok-api": "../../js-api"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "datagrok-tools": "^5.1.5",
    "ts-loader": "latest",
    "typescript": "latest",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  },
  "scripts": {
    "debug-inventory": "webpack && grok publish",
    "release-inventory": "webpack && grok publish --release",
    "build-inventory": "webpack",
    "build": "grok api && grok check --soft && webpack",
    "test": "grok test",
    "debug-inventory-dev": "webpack && grok publish dev",
    "release-inventory-dev": "webpack && grok publish dev --release",
    "debug-inventory-public": "webpack && grok publish public",
    "release-inventory-public": "webpack && grok publish public --release",
    "debug-inventory-localhost": "webpack && grok publish localhost",
    "release-inventory-localhost": "webpack && grok publish localhost --release"
  },
  "canEdit": [
    "Developers"
  ],
  "canView": [
    "All users"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/datagrok-ai/public.git",
    "directory": "packages/Inventory"
  },
  "overrides": {
    "datagrok-api": "$datagrok-api"
  }
}
