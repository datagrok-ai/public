{
  "swagger": "2.0",
  "info": {
    "title": "PubChem API",
    "description": ""
  },
  "host": "pubchem.ncbi.nlm.nih.gov/rest/pug",
  "basePath": "",
  "schemes": [
    "https"
  ],
  "paths": {
    "/compound/fastsubstructure/{format}/{mol}/cids/XML": {
      "get": {
        "summary": "PubChem Substructure Search",
        "description": "Returns PubChem compound IDs (CIDs) that contain the query structure as a substructure.",
        "parameters": [
          {
            "name": "mol",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Query structure, encoded in the notation given by 'format'."
          },
          {
            "name": "format",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Input structure notation (e.g. smiles, inchi, sdf)."
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "schema": {
              "$schema": "http://json-schema.org/draft-04/schema#",
              "type": "object",
              "properties": {
                "Waiting": {
                  "type": "object",
                  "properties": {
                    "ListKey": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "ListKey",
                    "Message"
                  ]
                }
              },
              "required": [
                "Waiting"
              ]
            }
          }
        },
        "description": ""
      }
    },
    "/compound/fastsuperstructure/{format}/{mol}/cids/XML": {
      "get": {
        "summary": "PubChem Superstructure Search",
        "description": "Returns PubChem compound IDs (CIDs) that contain the query structure as a superstructure.",
        "parameters": [
          {
            "name": "mol",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Query structure, encoded in the notation given by 'format'."
          },
          {
            "name": "format",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Input structure notation (e.g. smiles, inchi, sdf)."
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "description": ""
      }
    },
    "/compound/fastsimilarity_2d/smiles/{smiles}/cids/XML": {
      "get": {
        "summary": "PubChem Similarity Search",
        "description": "Returns PubChem compound IDs (CIDs) whose 2D similarity to the query SMILES meets the threshold.",
        "parameters": [
          {
            "name": "smiles",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Query structure as a SMILES string."
          },
          {
            "name": "Threshold",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 90,
            "minimum": 0,
            "maximum": 100,
            "description": "Minimum 2D Tanimoto similarity, 0-100 (default 90)."
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "schema": {
              "description": "",
              "type": "object",
              "properties": {
                "molecules": {
                  "type": "array",
                  "uniqueItems": true,
                  "minItems": 1,
                  "items": {
                    "required": [
                      "molecule_structures",
                      "molecule_chembl_id",
                      "molecule_properties"
                    ],
                    "properties": {
                      "atc_classifications": {
                        "type": "string"
                      },
                      "availability_type": {
                        "type": "number"
                      },
                      "biotherapeutic": {
                        "type": "string"
                      },
                      "black_box_warning": {
                        "type": "string"
                      },
                      "chebi_par_id": {
                        "type": "string"
                      },
                      "chirality": {
                        "type": "number"
                      },
                      "cross_references": {
                        "type": "string"
                      },
                      "dosed_ingredient": {
                        "type": "string"
                      },
                      "first_approval": {
                        "type": "string"
                      },
                      "first_in_class": {
                        "type": "number"
                      },
                      "helm_notation": {
                        "type": "string"
                      },
                      "indication_class": {
                        "type": "string"
                      },
                      "inorganic_flag": {
                        "type": "number"
                      },
                      "max_phase": {
                        "type": "number"
                      },
                      "molecule_chembl_id": {
                        "name": "chembl_id",
                        "type": "string"
                      },
                      "molecule_hierarchy": {
                        "type": "object",
                        "properties": {
                          "molecule_chembl_id": {
                            "type": "string"
                          },
                          "parent_chembl_id": {
                            "type": "string"
                          }
                        }
                      },
                      "molecule_properties": {
                        "name": "properties",
                        "type": "object",
                        "properties": {
                          "alogp": {
                            "type": "string"
                          },
                          "aromatic_rings": {
                            "type": "string"
                          },
                          "cx_logd": {
                            "type": "string"
                          },
                          "cx_logp": {
                            "type": "string"
                          },
                          "cx_most_apka": {
                            "type": "string"
                          },
                          "cx_most_bpka": {
                            "type": "string"
                          },
                          "full_molformula": {
                            "type": "string"
                          },
                          "hba": {
                            "type": "string"
                          },
                          "hba_lipinski": {
                            "type": "string"
                          },
                          "hbd": {
                            "type": "string"
                          },
                          "heavy_atoms": {
                            "type": "string"
                          },
                          "molecular_species": {
                            "type": "string"
                          },
                          "mw_freebase": {
                            "type": "string"
                          },
                          "mw_monoisotopic": {
                            "type": "string"
                          },
                          "full_mwt": {
                            "type": "string"
                          },
                          "num_lipinski_ro5_violations": {
                            "type": "string"
                          },
                          "num_ro5_violations": {
                            "type": "string"
                          },
                          "psa": {
                            "type": "string"
                          },
                          "qed_weighted": {
                            "type": "string"
                          },
                          "ro3_pass": {
                            "type": "string"
                          },
                          "rtb": {
                            "type": "string"
                          }
                        }
                      },
                      "molecule_structures": {
                        "name": "structures",
                        "type": "object",
                        "properties": {
                          "name": "smiles_molecule",
                          "canonical_smiles": {
                            "type": "string"
                          },
                          "molfile": {
                            "name": "molfile_molecule",
                            "type": "string"
                          }
                        },
                        "required": [
                          "canonical_smiles",
                          "molfile"
                        ]
                      },
                      "molecule_synonyms": {
                        "type": "string"
                      },
                      "molecule_type": {
                        "type": "string"
                      },
                      "natural_product": {
                        "type": "string"
                      },
                      "oral": {
                        "type": "string"
                      },
                      "parenteral": {
                        "type": "string"
                      },
                      "polymer_flag": {
                        "type": "string"
                      },
                      "pref_name": {
                        "type": "string"
                      },
                      "prodrug": {
                        "type": "string"
                      },
                      "structure_type": {
                        "type": "string"
                      },
                      "therapeutic_flag": {
                        "type": "string"
                      },
                      "topical": {
                        "type": "string"
                      },
                      "usan_stem": {
                        "type": "string"
                      },
                      "usan_stem_definition": {
                        "type": "string"
                      },
                      "usan_substem": {
                        "type": "string"
                      },
                      "usan_year": {
                        "type": "string"
                      },
                      "withdrawn_class": {
                        "type": "string"
                      },
                      "withdrawn_country": {
                        "type": "string"
                      },
                      "withdrawn_flag": {
                        "type": "string"
                      },
                      "withdrawn_reason": {
                        "type": "string"
                      },
                      "withdrawn_year": {
                        "type": "string"
                      }
                    }
                  }
                },
                "page_meta": {
                  "type": "object",
                  "properties": {
                    "limit": {
                      "type": "number"
                    },
                    "previous": {
                      "type": "string"
                    },
                    "next": {
                      "type": "string"
                    },
                    "offset": {
                      "type": "number"
                    },
                    "total_count": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "next"
                  ]
                }
              },
              "required": [
                "molecules",
                "page_meta"
              ]
            }
          }
        },
        "description": ""
      }
    }
  }
}
