      parameters:
      - name: resourceType
        in: path
        description: The type of the resource for which the policies should be updated.
        required: true
        schema:
          type: string
          example: execution_context
      - name: resourceId
        in: path
        description: The resource ID of the resource for which the policies should
          be updated.
        required: true
        schema:
          type: string
          example: 09ea2e9d-befd-4bc1-b061-b09a55d5a09b
      requestBody:
        description: A list of policies to be either kept or added. Policies that
