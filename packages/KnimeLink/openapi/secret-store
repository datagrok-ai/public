    secretId:
      name: secretId
      in: path
      description: "The globally unique ID of the secret, always prefixed with \"\
        secret:\"."
      required: true
      schema:
        format: string
        type: string
        example: secret:580ec296-ec3a-4b87-ad46-8dce1f27b31d
    accountId:
      name: accountId
      in: path
      description: "A globally unique account ID, always prefixed with \"account:\"\
        ."
      required: true
      schema:
        pattern: "(?:account(?::|%3A))?(?:team|user)(?::|%3A)[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}"
        type: string
      example: account:team:a885bb42-d808-4557-9a7f-9f10c5777739
