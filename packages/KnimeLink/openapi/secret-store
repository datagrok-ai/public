---
openapi: 3.0.3
info:
  title: KNIME Hub Permissions Library REST API
  description: RESTful services provided by the KNIME Hub Permissions Library.
  termsOfService: https://www.knime.com/terms-forum-hub
  contact:
    name: KNIME Support
    url: http://www.knime.com
    email: support@knime.com
  version: v1
servers:
- url: /secret-store
  description: KNIME Hub
- url: /
  description: KNIME Hub
tags:
- name: Secret Configuration
  description: Manage secrets.
- name: Secret Consumption
  description: Consume secrets.
- name: OAuth2
  description: Interactive OAuth2 authentication (authorization code grant).
- name: Permissions
  description: Requests related to permissions.
paths:
  /secrets:
    get:
      tags:
      - Secret Configuration
      summary: Lists all secrets (only metadata) that the current user can consume.
      description: |
        Provides an aggregate list of all secrets (only metadata) that the current user can consume. This may include secrets from several owning scopes, depending on (for example) the team memberships of the current user.
      responses:
        "200":
          description: A list of secret infos (metadata about secrets).
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/SecretInfo"
              examples:
                SecretInfoList:
                  $ref: "#/components/examples/SecretInfoList"
  /secrets/{secretId}:
    get:
      tags:
      - Secret Configuration
      summary: Retrieves the metadata and configuration of a secret.
      description: |
        Retrieves the metadata and configuration of the secret with the given id. Note that confidential fields of the configuration are masked by default, for example passwords. Please see the response schema to see which fields are considered confidential.
      parameters:
      - $ref: "#/components/parameters/secretId"
      - name: maskConfidential
        in: query
        description: |
          If parameter value is "blank", confidential fields of the secret config will be masked using an empty string, otherwise they will be replaced with asterisks.
        required: false
        schema:
          default: default
          enum:
          - default
          - blank
          type: string
      - name: Prefer
        in: header
        description: Set to "representation=minimal" to hide Mason controls.
        required: false
        schema:
          type: string
          example: representation=minimal
      responses:
        "200":
          description: Secret retrieved successfully.
          content:
            application/json:
              schema:
                oneOf:
                - $ref: "#/components/schemas/Secret"
              examples:
                AzureOAuth2AuthCodeSecret:
                  $ref: "#/components/examples/AzureOAuth2AuthCodeSecret"
                AzureOAuth2ClientCredsSecret:
                  $ref: "#/components/examples/AzureOAuth2ClientCredsSecret"
                AzureOAuth2PasswordSecret:
                  $ref: "#/components/examples/AzureOAuth2PasswordSecret"
                AzureStorageSASSecret:
                  $ref: "#/components/examples/AzureStorageSASSecret"
                AzureStorageSharedKeySecret:
                  $ref: "#/components/examples/AzureStorageSharedKeySecret"
                BoxOAuth2AuthCodeSecret:
                  $ref: "#/components/examples/BoxOAuth2AuthCodeSecret"
                BoxOAuth2ClientCredsSecret:
                  $ref: "#/components/examples/BoxOAuth2ClientCredsSecret"
                CredentialsSecret:
                  $ref: "#/components/examples/CredentialsSecret"
                CredentialsSecretWithMason:
                  $ref: "#/components/examples/CredentialsSecretWithMason"
                DatabricksOAuth2AuthCodeSecret:
                  $ref: "#/components/examples/DatabricksOAuth2AuthCodeSecret"
                DatabricksOAuth2ClientCredsSecret:
                  $ref: "#/components/examples/DatabricksOAuth2ClientCredsSecret"
                DatabricksPersonalAccessTokenSecret:
                  $ref: "#/components/examples/DatabricksPersonalAccessTokenSecret"
                FileSecret:
                  $ref: "#/components/examples/FileSecret"
                GoogleOAuth2AuthCodeSecret:
                  $ref: "#/components/examples/GoogleOAuth2AuthCodeSecret"
                GoogleOAuth2JwtBearerSecretJsonKeyFile:
                  $ref: "#/components/examples/GoogleOAuth2JwtBearerSecretJsonKeyFile"
                GoogleOAuth2JwtBearerSecretP12KeyFile:
                  $ref: "#/components/examples/GoogleOAuth2JwtBearerSecretP12KeyFile"
                OAuth2AuthCodeSecret:
                  $ref: "#/components/examples/OAuth2AuthCodeSecret"
                OAuth2AuthCodeSecretWithMason:
                  $ref: "#/components/examples/OAuth2AuthCodeSecretWithMason"
                OAuth2ClientCredsSecret:
                  $ref: "#/components/examples/OAuth2ClientCredsSecret"
                OAuth2PasswordSecret:
                  $ref: "#/components/examples/OAuth2PasswordSecret"
                SalesforceOAuth2PasswordSecret:
                  $ref: "#/components/examples/SalesforceOAuth2PasswordSecret"
                SalesforceOAuth2AuthCodeSecret:
                  $ref: "#/components/examples/SalesforceOAuth2AuthCodeSecret"
                CredentialsTokenSecret:
                  $ref: "#/components/examples/CredentialsTokenSecret"
        "403":
          description: "The requested secret exists, but the current user is not allowed\
            \ to access it, e.g. because it is owned by someone else."
        "404":
          description: The specified secret could not be found.
    put:
      tags:
      - Secret Configuration
      summary: Updates the mutable metadata and configuration fields of a secret.
      description: |
        Updates the mutable metadata and configuration fields of the secret identified by the given ID.

        Note that it is possible to omit the config field to only update metadata like name or description. However if the config
        is specified, then it must be complete.
      parameters:
      - $ref: "#/components/parameters/secretId"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateSecret"
            examples:
              UpdateAzureOAuth2AuthCodeSecret:
                $ref: "#/components/examples/CreateAzureOAuth2AuthCodeSecret"
              UpdateAzureOAuth2ClientCredsSecret:
                $ref: "#/components/examples/CreateAzureOAuth2ClientCredsSecret"
              UpdateAzureOAuth2PasswordSecret:
                $ref: "#/components/examples/CreateAzureOAuth2PasswordSecret"
              UpdateAzureStorageSASSecret:
                $ref: "#/components/examples/CreateAzureStorageSASSecret"
              UpdateAzureStorageSharedKeySecret:
                $ref: "#/components/examples/CreateAzureStorageSharedKeySecret"
              UpdateBoxOAuth2AuthCodeSecret:
                $ref: "#/components/examples/CreateBoxOAuth2AuthCodeSecret"
              UpdateBoxOAuth2ClientCredsSecret:
                $ref: "#/components/examples/CreateBoxOAuth2ClientCredsSecret"
              UpdateCredentialsSecret:
                $ref: "#/components/examples/CreateCredentialsSecret"
              UpdateDatabricksOAuth2AuthCodeSecret:
                $ref: "#/components/examples/CreateDatabricksOAuth2AuthCodeSecret"
              UpdateDatabricksOAuth2ClientCredsSecret:
                $ref: "#/components/examples/CreateDatabricksOAuth2ClientCredsSecret"
              UpdateDatabricksPersonalAccessTokenSecret:
                $ref: "#/components/examples/CreateDatabricksPersonalAccessTokenSecret"
              UpdateFileSecret:
                $ref: "#/components/examples/CreateFileSecret"
              UpdateGoogleOAuth2AuthCodeSecret:
                $ref: "#/components/examples/CreateGoogleOAuth2AuthCodeSecret"
              UpdateGoogleOAuth2AuthCodeSecretWithScopeGroups:
                $ref: "#/components/examples/CreateGoogleOAuth2AuthCodeSecretWithScopeGroups"
              UpdateGoogleOAuth2JwtBearerSecretJsonKeyFile:
                $ref: "#/components/examples/CreateGoogleOAuth2JwtBearerSecretJsonKeyFile"
              UpdateGoogleOAuth2JwtBearerSecretP12KeyFile:
                $ref: "#/components/examples/CreateGoogleOAuth2JwtBearerSecretP12KeyFile"
              UpdateGoogleOAuth2JwtBearerSecretWithScopeGroups:
                $ref: "#/components/examples/CreateGoogleOAuth2JwtBearerSecretWithScopeGroups"
              UpdateOAuth2AuthCodeSecret:
                $ref: "#/components/examples/CreateOAuth2AuthCodeSecret"
              UpdateOAuth2ClientCredsSecret:
                $ref: "#/components/examples/CreateOAuth2ClientCredsSecret"
              UpdateOAuth2PasswordSecret:
                $ref: "#/components/examples/CreateOAuth2PasswordSecret"
              UpdateSalesforceOAuth2PasswordSecret:
                $ref: "#/components/examples/CreateSalesforceOAuth2PasswordSecret"
              UpdateSalesforceOAuth2AuthCodeSecret:
                $ref: "#/components/examples/CreateSalesforceOAuth2AuthCodeSecret"
              UpdateCredentialsTokenSecret:
                $ref: "#/components/examples/CreateCredentialsTokenSecret"
      responses:
        "200":
          description: Secret updated successfully.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/SecretInfo"
              examples:
                AzureOAuth2AuthCodeInfo:
                  $ref: "#/components/examples/AzureOAuth2AuthCodeInfo"
                AzureOAuth2ClientCredsInfo:
                  $ref: "#/components/examples/AzureOAuth2ClientCredsInfo"
                AzureOAuth2PasswordInfo:
                  $ref: "#/components/examples/AzureOAuth2PasswordInfo"
                AzureStorageSASInfo:
                  $ref: "#/components/examples/AzureStorageSASInfo"
                AzureStorageSharedKeyInfo:
                  $ref: "#/components/examples/AzureStorageSharedKeyInfo"
                BoxOAuth2AuthCodeSecretInfo:
                  $ref: "#/components/examples/BoxOAuth2AuthCodeSecretInfo"
                BoxOAuth2ClientCredsSecretInfo:
                  $ref: "#/components/examples/BoxOAuth2ClientCredsSecretInfo"
                CredentialsSecretInfo:
                  $ref: "#/components/examples/CredentialsSecretInfo"
                CredentialsTokenSecretInfo:
                  $ref: "#/components/examples/CredentialsTokenSecretInfo"
                DatabricksOAuth2AuthCodeSecretInfo:
                  $ref: "#/components/examples/DatabricksOAuth2AuthCodeSecretInfo"
                DatabricksOAuth2ClientCredsSecretInfo:
                  $ref: "#/components/examples/DatabricksOAuth2ClientCredsSecretInfo"
                DatabricksPersonalAccessTokenSecretInfo:
                  $ref: "#/components/examples/DatabricksPersonalAccessTokenSecretInfo"
                FileSecretInfo:
                  $ref: "#/components/examples/FileSecretInfo"
                GoogleOAuth2AuthCodeSecretInfo:
                  $ref: "#/components/examples/GoogleOAuth2AuthCodeSecretInfo"
                GoogleOAuth2JwtBearerSecretInfo:
                  $ref: "#/components/examples/GoogleOAuth2JwtBearerSecretInfo"
                OAuth2AuthCodeSecretInfo:
                  $ref: "#/components/examples/OAuth2AuthCodeSecretInfo"
                OAuth2ClientCredsSecretInfo:
                  $ref: "#/components/examples/OAuth2ClientCredsSecretInfo"
                OAuth2PasswordSecretInfo:
                  $ref: "#/components/examples/OAuth2PasswordSecretInfo"
                SalesforceOAuth2PasswordInfo:
                  $ref: "#/components/examples/SalesforceOAuth2PasswordInfo"
                SalesforceOAuth2AuthCodeInfo:
                  $ref: "#/components/examples/SalesforceOAuth2AuthCodeInfo"
        "403":
          description: "The secret exists, but the current user is not allowed to\
            \ update it."
        "404":
          description: The specified secret could not be found.
        "422":
          description: "There is already a secret with the same name, owned by the\
            \ current user, or the provided secret lacks a required field, or the\
            \ value of a provided field is invalid."
    patch:
      tags:
      - Secret Configuration
      summary: Partially updates the mutable metadata and configuration fields of
        a secret.
      description: |
        This endpoint allows to partially update the mutable metadata and configuration fields of a secret. The request
        body is treated as a [JSON Merge Patch](https://datatracker.ietf.org/doc/html/rfc7386). Please note the following:

        * JSON Merge Patch is designed to update JSON objects. In order to update a JSON array, the array needs to be supplied in full.
        * Only the following fields can be changed: *name*, *description* and *config*
      parameters:
      - $ref: "#/components/parameters/secretId"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateSecret"
            examples:
              UpdateName:
                summary: Update the name
                value:
                  name: The new name
              UpdatePassword:
                summary: Update the password
                value:
                  config:
                    password: vasd673j3r3jh677
              UpdateClientIdAndRemoveClientSecret:
                summary: Update the OAuth2 client_id and remove the client_secret
                value:
                  config:
                    clientId: some_new_id
                    clientSecret: null
              AddSomeScope:
                summary: Add an OAuth2 scope
                value:
                  config:
                    scopes:
                    - existingScope
                    - scopeToAdd
      responses:
        "200":
          description: Secret updated successfully.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/SecretInfo"
              examples:
                AzureOAuth2AuthCodeInfo:
                  $ref: "#/components/examples/AzureOAuth2AuthCodeInfo"
                AzureOAuth2ClientCredsInfo:
                  $ref: "#/components/examples/AzureOAuth2ClientCredsInfo"
                AzureOAuth2PasswordInfo:
                  $ref: "#/components/examples/AzureOAuth2PasswordInfo"
                AzureStorageSASInfo:
                  $ref: "#/components/examples/AzureStorageSASInfo"
                AzureStorageSharedKeyInfo:
                  $ref: "#/components/examples/AzureStorageSharedKeyInfo"
                BoxOAuth2AuthCodeSecretInfo:
                  $ref: "#/components/examples/BoxOAuth2AuthCodeSecretInfo"
                BoxOAuth2ClientCredsSecretInfo:
                  $ref: "#/components/examples/BoxOAuth2ClientCredsSecretInfo"
                CredentialsSecretInfo:
                  $ref: "#/components/examples/CredentialsSecretInfo"
                CredentialsTokenSecretInfo:
                  $ref: "#/components/examples/CredentialsTokenSecretInfo"
                DatabricksOAuth2AuthCodeSecretInfo:
                  $ref: "#/components/examples/DatabricksOAuth2AuthCodeSecretInfo"
                DatabricksOAuth2ClientCredsSecretInfo:
                  $ref: "#/components/examples/DatabricksOAuth2ClientCredsSecretInfo"
                DatabricksPersonalAccessTokenSecretInfo:
                  $ref: "#/components/examples/DatabricksPersonalAccessTokenSecretInfo"
                FileSecretInfo:
                  $ref: "#/components/examples/FileSecretInfo"
                GoogleOAuth2AuthCodeSecretInfo:
                  $ref: "#/components/examples/GoogleOAuth2AuthCodeSecretInfo"
                GoogleOAuth2JwtBearerSecretInfo:
                  $ref: "#/components/examples/GoogleOAuth2JwtBearerSecretInfo"
                OAuth2AuthCodeSecretInfo:
                  $ref: "#/components/examples/OAuth2AuthCodeSecretInfo"
                OAuth2ClientCredsSecretInfo:
                  $ref: "#/components/examples/OAuth2ClientCredsSecretInfo"
                OAuth2PasswordSecretInfo:
                  $ref: "#/components/examples/OAuth2PasswordSecretInfo"
                SalesforceOAuth2PasswordInfo:
                  $ref: "#/components/examples/SalesforceOAuth2PasswordInfo"
                SalesforceOAuth2AuthCodeInfo:
                  $ref: "#/components/examples/SalesforceOAuth2AuthCodeInfo"
        "403":
          description: "The secret exists, but the current user is not allowed to\
            \ update it."
        "404":
          description: The specified secret could not be found.
        "422":
          description: "There is already a secret with the same name, owned by the\
            \ current user, or the provided secret lacks a required field, or the\
            \ value of a provided field is invalid."
    delete:
      tags:
      - Secret Configuration
      summary: Deletes a secret identified by the given ID.
      parameters:
      - $ref: "#/components/parameters/secretId"
      responses:
        "204":
          description: Secret deleted successfully.
        "403":
          description: The current user is not allowed to delete the secret.
        "404":
          description: The specified secret could not be found.
  /secrets/{secretId}/consume:
    get:
      tags:
      - Secret Consumption
      summary: Consume a secret by its id.
      description: |
        Creates a "consumable" for the secret with the given id. A consumable is a representation of the secret
        which only contains fields that are strictly necessary to actually use the secret, e.g. call an API.

        The fields of a consumable only depend on the type of the secret. For example the consumable of a
        credentials-typed secret is a username/password pair, whereas the consumable of an oauth2-typed secret
        is an OAuth2 access token.

        Before a secret can be consumed, certain secrets require a user to go through an interactive login procedure first
        (see login endpoint). Such secrets can be identified based on the "supportsLogin" metadata field.
        Examples are oauth2-typed secrets that use the OAuth2 authorization code grant.
      parameters:
      - $ref: "#/components/parameters/secretId"
      - name: oauth2AccessTokenMargin
        in: query
        description: |
          In case the consumable contains a refreshable token, this value specifies the minimum number of seconds required from now until its expiry. The minimum value of this margin is 15. A value of -1 enforces an immediate refresh of the token.
        required: false
        schema:
          default: 15
          type: number
      responses:
        "200":
          description: Secret consumable was retrieved successfully.
          content:
            application/json:
              schema:
                oneOf:
                - $ref: "#/components/schemas/SecretConsumableSuccess"
              examples:
                AzureStorageSASConsumable:
                  $ref: "#/components/examples/AzureStorageSASConsumable"
                AzureStorageSharedKeyConsumable:
                  $ref: "#/components/examples/AzureStorageSharedKeyConsumable"
                CredentialsSecretConsumable:
                  $ref: "#/components/examples/CredentialsSecretConsumable"
                CredentialsTokenSecretConsumable:
                  $ref: "#/components/examples/CredentialsTokenSecretConsumable"
                DatabricksOAuth2Consumable:
                  $ref: "#/components/examples/DatabricksOAuth2Consumable"
                DatabricksPersonalAccessTokenConsumable:
                  $ref: "#/components/examples/DatabricksPersonalAccessTokenConsumable"
                SalesforceOAuth2Consumable:
                  $ref: "#/components/examples/SalesforceOAuth2Consumable"
                FileConsumable:
                  $ref: "#/components/examples/FileConsumable"
                OAuth2SecretConsumable:
                  $ref: "#/components/examples/OAuth2SecretConsumable"
        "404":
          description: "The specified secret could not be found, or the current user\
            \ is not allowed to consume it."
        "422":
          description: There was an error consuming the secret.
          content:
            application/json:
              schema:
                oneOf:
                - $ref: "#/components/schemas/SecretConsumableFailed"
              examples:
                OAuth2SecretConsumableError:
                  $ref: "#/components/examples/OAuth2SecretConsumableError"
                SecretConsumableError:
                  $ref: "#/components/examples/SecretConsumableError"
  /secrets/{secretId}/login-start:
    get:
      tags:
      - OAuth2
      summary: Creates a new interactive login flow for an oauth2-typed secret.
      description: "Starts an interactive login flow for the given secret. The login\
        \ flow is a multi-step process, at the end of which secret store has\nan OAuth2\
        \ access/refresh token for the secret and it becomes consumable. The secret\
        \ must have `type: oauth2` and must support\nlogins (see `supportsLogin` field\
        \ in secret). Currently this is only the case when `configSchema: *_oauth2_auth_code`.\n\
        \nThe response of this endpoint is a HTTP redirect to the authorization URL\
        \ of the OAuth2 IDP, where the user must authenticate\ninteractively. After\
        \ that, the IDP will redirect the user to the callback endpoint of the \n\
        OAuth2 flow service, which in turn invokes the login-finish endpoint (see\
        \ below).\n"
      parameters:
      - $ref: "#/components/parameters/secretId"
      responses:
        "303":
          description: Redirect to an IDP authorization URL.
        "403":
          description: "The requested secret exists, but the current user is not allowed\
            \ to update it, e.g. because it is owned by someone else."
        "404":
          description: The specified secret could not be found.
        "500":
          description: "An internal error occurred, for example the OAuth2 flow service\
            \ could not be reached."
  /secrets/{secretId}/login-finish:
    post:
      tags:
      - OAuth2
      summary: Finish an interactive login flow for an oauth2-typed secret.
      description: "Finishes an interactive login flow for the given secret. The login\
        \ flow is a multi-step process, at the end of which secret store has\nan OAuth2\
        \ access/refresh token for the secret and it becomes consumable. The request\
        \ body must contain the `flowId` of the flow to finish,\nand the query parameters\
        \ that the IDP provided when redirecting the user browser. This endpoint will\
        \ analyze the query parameters\nand either exchange the contained auth code\
        \ for an access token (success), or parse the contained error.\n\nThis endpoint\
        \ is intended to be called by the OAuth2 flow service to pass on the authorization\
        \ code or an error from the OAuth2 IDP. \n"
      parameters:
      - $ref: "#/components/parameters/secretId"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              required:
              - flowId
              - queryParams
              type: object
              properties:
                flowId:
                  $ref: "#/components/parameters/flowId"
                queryParams:
                  format: uri
                  description: |
                    The query parameters (application/x-www-form-urlencoded) that the IDP has provided
                    as part of its redirect
                    (see [RFC 6749](https://datatracker.ietf.org/doc/html/rfc6749#section-4.1.2)).
                  type: string
                  example: code=dd872b936ffe427d8a158948bc01da87&state=c9c9c2926332433cb5d214ceacff78ca
            examples:
              FlowFinished:
                value:
                  flowId: oauth2-flow:037ceda9-ad07-42dc-9876-215442063fa7
                  queryParams: code=dd872b936ffe427d8a158948bc01da87&state=c9c9c2926332433cb5d214ceacff78ca
      responses:
        "200":
          description: The result of the login flow.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/OAuth2Flow"
              examples:
                FlowSuccess:
                  summary: A sucessfully completed OAuth2 login flow
                  value:
                    flowId: oauth2-flow:037ceda9-ad07-42dc-9876-215442063fa7
                    status: success
                FlowFailed:
                  summary: A failed OAuth2 login flow
                  value:
                    flowId: oauth2-flow:037ceda9-ad07-42dc-9876-215442063fa7
                    status: failed
                    error:
                      message: The client is not authorized to request an authorization
                        code using this method. (unauthorized_client)
                      idpCorrelationId: 8dfbca65-bd84-43f6-9a83-0171da49fdce
                      idpResponse:
                        code: unauthorized_client
                        description: The client is not authorized to request an authorization
                          code using this method.
                        uri: https://docs.idp.com/login-errors
        "403":
          description: "The requested secret exists, but the current user is not allowed\
            \ to update it, e.g. because it is owned by someone else."
        "404":
          description: The specified secret could not be found.
        "500":
          description: An internal error occurred.
  /secrets/{accountId}:
    get:
      tags:
      - Secret Configuration
      summary: "Lists all secrets (only metadata) within the given owning scope or\
        \ shared with the scope, that the current user can read."
      description: |
        Lists all secrets (only metadata) within the given scope, that the current user can read. This includes secrets owned by the scope, and secrets shared with this scope, or groups of this scope the use is a member of.
      parameters:
      - $ref: "#/components/parameters/accountId"
      - name: Prefer
        in: header
        description: Set to "representation=minimal" to hide Mason controls.
        required: false
        schema:
          type: string
          example: representation=minimal
      responses:
        "200":
          description: A list of secret infos (metadata about secrets) within the
            given scope or shared with the scope.
          content:
            application/json:
              schema:
                type: object
                properties:
                  secrets:
                    type: array
                    items:
                      $ref: "#/components/schemas/SecretInfo"
                  '@controls':
                    $ref: "#/components/schemas/ScopeMasonControls"
              examples:
                SecretInfoListScoped:
                  $ref: "#/components/examples/SecretInfoListScoped"
                SecretInfoListScopedWithoutMason:
                  $ref: "#/components/examples/SecretInfoListScopedWithoutMason"
    post:
      tags:
      - Secret Configuration
      summary: Creates a new secret within the specified scope.
      description: |
        Creates a new secret in the given owning scope (account). The name must be unique within the given scope.

        The type determines how the secret can be consumed, for example the type "oauth2" implies
        that the consume endpoint will return an OAuth2 access token.

        The configSchema determines the expected JSON structure for the config field. Please see the request body examples
        for the various supported configuration schemas.
      parameters:
      - $ref: "#/components/parameters/accountId"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateSecret"
            examples:
              SecretAzureOAuth2AuthCodeSecret:
                $ref: "#/components/examples/CreateAzureOAuth2AuthCodeSecret"
              SecretAzureOAuth2ClientCredsSecret:
                $ref: "#/components/examples/CreateAzureOAuth2ClientCredsSecret"
              SecretAzureOAuth2PasswordSecret:
                $ref: "#/components/examples/CreateAzureOAuth2PasswordSecret"
              SecretAzureStorageSASSecret:
                $ref: "#/components/examples/CreateAzureStorageSASSecret"
              SecretAzureStorageSharedKeySecret:
                $ref: "#/components/examples/CreateAzureStorageSharedKeySecret"
              SecretBoxOAuth2AuthCodeSecret:
                $ref: "#/components/examples/CreateBoxOAuth2AuthCodeSecret"
              SecretBoxOAuth2ClientCredsSecret:
                $ref: "#/components/examples/CreateBoxOAuth2ClientCredsSecret"
              SecretCredentialsSecret:
                $ref: "#/components/examples/CreateCredentialsSecret"
              SecretDatabricksOAuth2AuthCodeSecret:
                $ref: "#/components/examples/CreateDatabricksOAuth2AuthCodeSecret"
              SecretDatabricksOAuth2ClientCredsSecret:
                $ref: "#/components/examples/CreateDatabricksOAuth2ClientCredsSecret"
              SecretDatabricksPersonalAccessTokenSecret:
                $ref: "#/components/examples/CreateDatabricksPersonalAccessTokenSecret"
              SecretFileSecret:
                $ref: "#/components/examples/CreateFileSecret"
              SecretGoogleOAuth2AuthCodeSecret:
                $ref: "#/components/examples/CreateGoogleOAuth2AuthCodeSecret"
              SecretGoogleOAuth2AuthCodeSecretWithScopeGroups:
                $ref: "#/components/examples/CreateGoogleOAuth2AuthCodeSecretWithScopeGroups"
              SecretGoogleOAuth2JwtBearerSecretJsonKeyFile:
                $ref: "#/components/examples/CreateGoogleOAuth2JwtBearerSecretJsonKeyFile"
              SecretGoogleOAuth2JwtBearerSecretP12KeyFile:
                $ref: "#/components/examples/CreateGoogleOAuth2JwtBearerSecretP12KeyFile"
              SecretGoogleOAuth2JwtBearerSecretWithScopeGroups:
                $ref: "#/components/examples/CreateGoogleOAuth2JwtBearerSecretWithScopeGroups"
              SecretOAuth2AuthCode:
                $ref: "#/components/examples/CreateOAuth2AuthCodeSecret"
              SecretOAuth2ClientCredentials:
                $ref: "#/components/examples/CreateOAuth2ClientCredsSecret"
              SecretOAuth2Password:
                $ref: "#/components/examples/CreateOAuth2PasswordSecret"
              SecretSalesforceOAuth2PasswordSecret:
                $ref: "#/components/examples/CreateSalesforceOAuth2PasswordSecret"
              SecretSalesforceOAuth2AuthCodeSecret:
