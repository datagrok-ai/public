            type: string
            example: my-service-account@my-company-402213.iam.gserviceaccount.com
          scopes:
            description: |
              The scopes to request for the OAuth2 access token. Scopes define what you can use the access token for. Can be used as an alternative to the scope groups field.
            type: array
            items:
              type: string
            example:
            - https://www.googleapis.com/auth/bigquery
          scopeGroups:
            description: |
              The scope group ids to request for the OAuth2 access token. Can be used as an alternative to the scopes field. See /secret-store/oauth2/scope-groups to list available groups.
            type: array
            items:
              type: string
            example:
            - google.analytics
            - google.bigquery
