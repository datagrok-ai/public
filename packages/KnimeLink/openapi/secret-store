          description: The specified config schema does not exist.
  /permissions/policies/{resourceType}/{resourceId}:
    get:
      tags:
      - Permissions
      summary: Returns list of policies for the resource.
      description: Returns a list of all policies for the provided resource.
      parameters:
      - name: resourceType
        in: path
        description: The type of the resource for which the policies should be returned.
        required: true
        schema:
          type: string
          example: execution_context
      - name: resourceId
        in: path
        description: The resource ID of the resource for which the policies should
          be returned.
        required: true
        schema:
          type: string
          example: 09ea2e9d-befd-4bc1-b061-b09a55d5a09b
      responses:
        "200":
          description: The updated list of policies for the given resource.
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/PolicyWithId"
        "403":
          description: The user does not have permissions to manage permissions for
