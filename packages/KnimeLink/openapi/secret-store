components:
  schemas:
    SecretType:
      description: The type of the secret. The type implies the structure of the JSON
        response on the /consume endpoint.
      enum:
      - azure_storage_sas
      - azure_storage_shared_key
      - credentials
      - databricks_oauth2
      - databricks_personal_access_token
      - file
      - oauth2
      - salesforce_oauth2
      type: string
      example: credentials
    ConfigSchema:
      description: The configuration schema of a secret. The schema implies the JSON
        structure of the config field.
      enum:
      - azure_oauth2_auth_code
      - azure_oauth2_client_credentials
      - azure_oauth2_password
      - azure_storage_sas
      - azure_storage_shared_key
      - box_oauth2_auth_code
      - box_oauth2_client_credentials
      - credentials
      - credentials_token
      - databricks_oauth2_auth_code
      - databricks_oauth2_client_credentials
      - databricks_personal_access_token
      - file
      - google_oauth2_auth_code
      - google_oauth2_jwt_bearer
      - oauth2_auth_code
      - oauth2_client_credentials
      - oauth2_password
      - salesforce_oauth2_auth_code
      - salesforce_oauth2_password
      type: string
      example: credentials
    ConsumableStatus:
      description: The consumable status of a secret. The status indicates if a secret
        can be consumed or not.
      enum:
      - consumable
      - not_consumable
      type: string
      readOnly: true
      example: consumable
    SecretInfoBase:
      description: Information about a secret (metadata only).
      type: object
      properties:
        name:
          description: "The name of the secret, which is unique within the scope."
          type: string
        description:
          description: The optional description of the secret.
          type: string
        type:
          $ref: "#/components/schemas/SecretType"
        configSchema:
          $ref: "#/components/schemas/ConfigSchema"
    SecretInfo:
      description: "Metadata information about a secret, as returned when listing\
        \ secrets."
      required:
      - id
      - scope
      - scopeName
      - creator
      - creatorName
      - createdAt
      - updatedAt
      - consumableStatus
      - name
      - description
      - type
      - configSchema
      type: object
      allOf:
      - properties:
          id:
            format: uuid
            description: The id of the secret.
            type: string
            readOnly: true
            example: 580ec296-ec3a-4b87-ad46-8dce1f27b31d
          scope:
            description: An account ID that defines the owning scope of the secret.
            type: string
            readOnly: true
            example: account:team:f0dfe3a7-bc7c-4463-8511-5e62eab52357
          scopeName:
            description: The account name of the owning scope of the secret of the
              secret.
            type: string
            readOnly: true
            example: Some Team
          creator:
            description: The id of the account that created the secret.
            type: string
            readOnly: true
            example: account:user:6db70a29-f565-4e5c-8cf1-2bf0f2ccdcf6
          creatorName:
            description: The account name that created the secret.
            type: string
            readOnly: true
            example: Some User
          createdAt:
            format: date-time
            description: The date and time the secret was created.
            type: string
            readOnly: true
            example: 2022-02-22T22:10:00+01:00
          updatedAt:
            format: date-time
            description: The date and time the secret was updated.
            type: string
            readOnly: true
            example: 2022-02-22T22:10:00+01:00
          consumableStatus:
            $ref: "#/components/schemas/ConsumableStatus"
          consumableMessage:
            description: A complementary explanation of the status of the consumable.
            type: string
            readOnly: true
            example: Login required before secret can be consumed.
          consumableUntil:
            format: date-time
            description: The date and time the secret will expire.
            type: string
            readOnly: true
            example: 2022-02-22T22:22:22+01:00
          '@controls':
            description: The secret mason controls for a given scope.
            allOf:
            - $ref: "#/components/schemas/SecretMasonControls"
      - $ref: "#/components/schemas/SecretInfoBase"
    CredentialsConfig:
      description: |
        The configuration of a credentials-typed secret, which consists of a username/password pair.
      required:
      - username
      - password
      type: object
      properties:
        username:
          description: The username of the credentials.
          type: string
          example: john.smith
        password:
          description: |
            The password of the credentials. This field is confidential and, by default, will be masked when retrieving the secret configuration.
          type: string
          example: vasd673j3r3jh677
    CredentialsTokenConfig:
      description: |
        The configuration of a Credentials Token secret, which consists of a token value.
      required:
      - token
      type: object
      properties:
        token:
          description: |
            The credential token. This field is confidential and, by default, will be masked when retrieving the secret configuration.
          type: string
          example: TGV0IG1lIGluISBQbGVhc2UuLi4gVGhyb3dpbmcgZGljdGlvbmFyaWVzIGF0IHlvdSBpcyBubyBmdW4hCg
    OAuth2ConfigBase:
      type: object
      properties:
        tokenUrl:
          format: uri
          description: "The URL of the OAuth2 token endpoint, which is used to acquire\
            \ an OAuth2 access token."
          type: string
          example: https://auth.website.com/oauth2/token
        clientId:
          description: |
            The client/app ID to use. The client/app needs to be registered with the OAuh2 service that issues the access token.
          type: string
          example: 3194d643-3c58-4cd3-aa5a-7ac77a538195
        clientSecret:
          description: |
            The client/app secret to use. The client/app needs to be registered with the OAuth2 service that issues the
            access token.

            This field is confidential and, by default, will be masked when retrieving the secret configuration.
          type: string
          example: bj0ERn1RrKi2dIonYsios3znQ4pAblo5OCYhdu6sAscHa7EoVAS8T0bIAs9
        scopes:
          description: |
            The scopes to request for the OAuth2 access token. Scopes define what you can use the access token for. The choice of scopes is specific to each service/API, so please consult the documentation of the respective service/API.
          type: array
          items:
            type: string
          example:
          - openid
        tokenRequestMethod:
          description: |
            The HTTP request method (POST or GET) to use when calling the token endpoint. When omitted this defaults to POST, since most OAuth2 services use the POST method.
          default: POST
          enum:
          - POST
          - GET
          type: string
          example: POST
        clientAuthType:
          description: "How to transfer the client secret to the token endpoint. When\
            \ omitted this defaults to REQUEST_BODY, since most OAuth2 services accept\
            \ the client secret as a field in the application/x-www-form-url encoded\
            \ request body.\n            \nSome services require HTTP_BASIC_AUTH,\
            \ which transfers the client secret via the Authorization header using\
            \ Basic authentication.\n"
          default: REQUEST_BODY
          enum:
          - REQUEST_BODY
          - HTTP_BASIC_AUTH
          type: string
          example: REQUEST_BODY
    OAuth2AuthCodeConfig:
      description: |
        The configuration of an oauth2-typed secret, where the access token is acquired using the (interactive) OAuth2 authorization code flow. Note that a secret of this type can only be created in a user scope, but not in a team or global scope.
      required:
      - authorizationUrl
      - tokenUrl
      - clientId
      - scopes
      allOf:
      - properties:
          authorizationUrl:
            format: uri
            description: "The URL of the OAuth2 authorization endpoint, where the\
              \ user needs to interactively log in and grant access."
            type: string
            example: https://auth.website.com/oauth2/authorize
          usePkce:
            description: Enable Proof Key for Code Exchange (PKCE) using S256 as challenge
              method.
            default: false
            type: boolean
      - $ref: "#/components/schemas/OAuth2ConfigBase"
    OAuth2ClientCredsConfig:
      description: |
        The configuration of an oauth2-typed secret, where the access token is acquired using the OAuth2 client credentials flow.
      required:
      - tokenUrl
      - clientId
      - clientSecret
      - scopes
      allOf:
      - properties:
          additionalBodyRequestFields:
            description: |
              Optional custom key/value pairs (string) to put into the request body sent to the token endpoint. Some OAuth2 services require custom fields in order to issue an access token.
            type: object
            additionalProperties:
              type: string
            example:
              enterpriseAccountId: "75059134502393"
      - $ref: "#/components/schemas/OAuth2ConfigBase"
    OAuth2PasswordConfig:
      description: |
        The configuration of an oauth2-typed secret, where the access token is acquired using the OAuth2 password flow (aka ROPC).
      required:
      - tokenUrl
      - clientId
      - scopes
      - username
      - password
      allOf:
      - properties:
          username:
            description: The username to use.
            type: string
            example: john.smith
          password:
            description: |
              The password to use. This field is confidential and, by default, will be masked when retrieving the secret configuration.
            type: string
            example: vasd673j3r3jh677
      - $ref: "#/components/schemas/OAuth2ConfigBase"
    SalesforceOAuth2PasswordConfig:
      description: |
        The configuration of a Salesforce oauth2-typed secret, where the access token is acquired using the OAuth2 password flow. See service account in the [Salesforce documentation](https://help.salesforce.com/s/articleView?id=sf.remoteaccess_oauth_username_password_flow.htm&type=5)
      required:
      - clientId
      - clientSecret
      - username
      - password
      properties:
        clientId:
          description: |
            The client/consumer ID to use. The consumer key of the connected app.  To access consumer key from App manager, find the connected app and select View in Manage Consumer Details.
          type: string
          example: 3MVG9lKcPoNINVBIPJjdw1J9LLM82HnFVVX19KY1uA5mu0
        clientSecret:
          description: |
            The client/consumer secret to use. The consumer secret of the connected app.
          type: string
          example: naigojaeR0sah1thojah5voobeeZiphe
        username:
          description: |
            The username of the connected app.
          type: string
          example: john.smith
        password:
          description: |
            The password to use. This field is confidential and, by default, will be masked when retrieving the secret configuration.
          type: string
          example: vasd673j3r3jh677
        securityToken:
          description: |
            The security token to use.
          type: string
          example: etasd673j3r3jh7867
        instanceType:
          description: |
            The instance type to established the connection with either Salesforce Sandbox Instance or Salesforce Production Instance.
          enum:
          - production
          - sandbox
          type: string
          example: production
    SalesforceOAuth2AuthCodeConfig:
      description: |
        The configuration of a Salesforce oauth2-typed secret, where the access token is acquired using the OAuth2 auth code flow. See service account in the [Salesforce documentation](https://help.salesforce.com/s/articleView?id=sf.remoteaccess_authcodecreds_singlepageapp.htm&type=5)
      required:
      - clientId
      - clientSecret
      properties:
        clientId:
          description: |
            The client/consumer ID to use. The consumer key of the connected app.  To access consumer key from App manager, find the connected app and select View in Manage Consumer Details.
          type: string
          example: 3MVG9lKcPoNINVBIPJjdw1J9LLM82HnFVVX19KY1uA5mu0
        clientSecret:
          description: |
            The client/consumer secret to use. The consumer secret of the connected app.
          type: string
          example: naigojaeR0sah1thojah5voobeeZiphe
        instanceType:
          description: |
            The instance type to established the connection with either Salesforce Sandbox Instance or Salesforce Production Instance.
          enum:
          - production
          - sandbox
          type: string
          example: production
    AzureOAuth2AuthCodeConfig:
      description: |
        The configuration of an Azure oauth2-typed secret, where the access token is acquired using the OAuth2 authorization code flow. Note that a secret of this type can only be created in a user scope, but not in a team or global scope.
      required:
      - clientId
      allOf:
      - properties:
          authorizationUrl:
            description: |
              Optional URL of the authorization endpoint. This can be used to specify an endpoint that is specific to an Azure
              AD tenant for example.
            default: https://login.microsoftonline.com/common
            type: string
          clientId:
            description: |
              The client/app ID to use. The client/app needs to be registered in Azure Entra ID.
            type: string
            example: 3194d643-3c58-4cd3-aa5a-7ac77a538195
          clientSecret:
            description: |
              An optional client/app secret to use. The client/app needs to be registered in Azure Entra ID.

              This field is confidential and, by default, will be masked when retrieving the secret configuration.
            type: string
            example: bj0ERn1RrKi2dIonYsios3znQ4pAblo5OCYhdu6sAscHa7EoVAS8T0bIAs9
