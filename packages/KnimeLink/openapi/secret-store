  /stats:
    get:
      tags:
      - Secret Statistics
      summary: Get statistics about the secrets in this secret store.
      description: |
        Provides an aggregated statistic about the number of secrets by scope, and by config schema. This endpoint requires expensive calculations, and is only available to hub admin users.
      responses:
        "200":
          description: "Secret counts by scope, and config schema."
          content:
            application/json:
              schema:
                type: object
                properties:
                  secretsCountByBackend:
                    type: array
                    items:
                      type: object
                      properties:
                        backend:
                          description: The type of the backend.
                          type: string
                          example: built-in-s3
                        count:
                          description: The total number of secrets.
                          type: number
                  secretsCountByConfigSchema:
                    type: array
                    items:
                      type: object
                      properties:
                        configSchema:
                          $ref: "#/components/schemas/ConfigSchema"
                        count:
                          description: The total number of secrets.
                          type: number
                  secretsCountByScope:
                    type: array
                    items:
                      type: object
                      properties:
                        scope:
                          description: The type of the scope.
                          enum:
                          - user
                          - team
                          - global
                          type: string
                        count:
                          description: The total number of secrets.
                          type: number
                        quantiles:
                          description: "Array with min, p25, p50/median, p75, and\
                            \ max secret counts."
                          type: array
                          items:
                            format: double
                            type: number
              examples:
                SecretStats:
                  value:
                    secretsCountByBackend:
                    - backend: built-in-s3
                      count: 4
                    - backend: built-in-vault
                      count: 3
                    secretsCountByConfigSchema:
                    - configSchema: credentials
                      count: 5
                    - configSchema: oauth2_client_credentials
                      count: 2
                    secretsCountByScope:
                    - scope: user
                      count: 5
                      quantiles:
                      - 1
                      - 2.25
                      - 2.5
                      - 3
                      - 3
                    - scope: team
                      count: 8
                      quantiles:
                      - 1
                      - 4
                      - 4.5
                      - 4.75
                      - 5
                    - scope: global
                      count: 10
                      quantiles:
                      - 1
                      - 2
                      - 3
                      - 4
                      - 5
  /oauth2/scope-groups:
    get:
      tags:
      - OAuth2
      summary: Lists all supported scope groups of a given config schema.
      description: |
        Provides a list of scope groups that a given config schema supports. This includes a scope group id, name, scopes and an optional group description. The group id might be used in the scopeGroups fields in the secret config.
      parameters:
      - name: configSchema
        in: query
