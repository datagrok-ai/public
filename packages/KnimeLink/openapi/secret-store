      requestBody:
        description: A list of policies to be added.
        content:
          application/json:
            schema:
              type: array
              items:
                $ref: "#/components/schemas/BasePolicy"
      responses:
        "200":
          description: The updated list of policies for the given resource.
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/PolicyWithId"
        "403":
          description: The user does not have permissions to manage permissions for
            the given resource.
        "404":
          description: The provided resource does not exist.
        "400":
          description: The provided resource type is invalid.
        "422":
          description: A provided user or group identifier is invalid.
        "500":
          description: An internal error occurred.
    put:
      tags:
      - Permissions
