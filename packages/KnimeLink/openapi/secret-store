            type: array
            items:
              type: string
            example:
            - google.analytics
            - google.bigquery
    GoogleOAuth2JwtBearerConfig:
      description: |
        The configuration of a Google oauth2-typed secret, where the access token is acquired using the OAuth2 jwt-bearer flow. See service accounts in the [Google documentation](https://developers.google.com/identity/protocols/oauth2/service-account).
      required:
      - keyFileFormat
      allOf:
      - properties:
          keyFileFormat:
            description: |
