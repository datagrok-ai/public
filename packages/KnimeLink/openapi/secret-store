      required:
      - clientId
      - clientSecret
      - workspaceUrl
      properties:
        clientId:
          description: |
            The client ID of the custom application to use.
          type: string
          example: 0652bf38-7a68-4791-808d-2c3e2264156b
        clientSecret:
          description: |
            The optional client secret of the custom application.
            This field is confidential and, by default, will be masked when retrieving the secret configuration.
          type: string
          example: dose8753bf387a684791808d2c3e2264143c
        workspaceUrl:
