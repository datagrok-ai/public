---
openapi: 3.0.3
info:
  title: KNIME Hub Execution REST API
  description: RESTful services for the KNIME Hub execution service.
  contact:
    name: KNIME Support
    url: http://www.knime.com
    email: support@knime.com
  version: v1
servers:
- url: /
  description: KNIME Hub
tags:
- name: Jobs
  description: Requests relating to KNIME jobs.
- name: Execution Contexts
  description: Requests relating to KNIME execution contexts.
- name: Executors
  description: Requests relating to KNIME Executor.
- name: Deployments
  description: Requests relating to KNIME deployments.
- name: Customization Profiles
  description: Requests relating to Customization Profiles.
- name: Tags
  description: Requests relating to resource tags.
- name: Clusters
  description: Requests relating k8s clusters.
- name: Permissions
  description: Requests related to permissions.
- name: Limits
  description: Requests related to limits.
paths:
  /executors:
    get:
      tags:
      - Executors
      summary: Returns a collection of all executor's information.
      parameters:
      - name: wait
        in: query
        description: Optional waiting time in milliseconds for the executors to respond.
        schema:
          format: int64
          default: 5000
          maximum: 60000
          minimum: 0
          type: integer
          example: 10000
      - name: includeJobStates
        in: query
        description: Optional flag to request information about the number of loaded
          jobs and their respective states.
        schema:
          default: false
          type: boolean
          example: true
      - $ref: "#/components/parameters/PreferHeader"
      responses:
        "200":
          description: Information about all executors.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/ExecutorInfoList"
            application/json:
              schema:
                $ref: "#/components/schemas/ExecutorInfoList"
        "400":
          description: The set waiting time exceeds the maximum waiting time.
        "403":
          description: The calling user does not have the rights for this endpoint.
        "500":
          description: An internal error occurred.
  /executors/{uuid}:
    get:
      tags:
      - Executors
      summary: Returns the executor's information.
      description: Returns the information for the provided executor.
      parameters:
      - name: uuid
        in: path
        description: The executor's ID.
        required: true
        schema:
          type: string
          example: a68c5d2b-c498-4787-9c8b-4e43bb8da402_ed43f811-6860-489c-a3f9-e710bdc92d5b
      - name: wait
        in: query
        description: Optional waiting time in milliseconds for the executor to respond.
        schema:
          format: int64
          default: 5000
          maximum: 60000
          minimum: 0
          type: integer
          example: 2000
      - $ref: "#/components/parameters/PreferHeader"
      responses:
        "200":
          description: Information about a single executor.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/ExecutorInfo"
            application/json:
              schema:
                $ref: "#/components/schemas/ExecutorInfo"
        "403":
          description: The calling user does not have the rights for this endpoint.
        "404":
          description: The executor did not respond within time.
        "500":
          description: An internal error occurred.
    delete:
      tags:
      - Executors
      summary: Stops an executor.
      description: Stops the provided executor. All running jobs will be cancelled
        and swapped out.
      parameters:
      - name: uuid
        in: path
        description: The executor's ID.
        required: true
        schema:
          type: string
          example: a68c5d2b-c498-4787-9c8b-4e43bb8da402_ed43f811-6860-489c-a3f9-e710bdc92d5b
      - name: timeout
        in: query
        description: Optional timeout in milliseconds.
        schema:
          format: int64
          default: 30000
          maximum: 60000
          minimum: 0
          type: integer
          example: 60000
      responses:
        "204":
          description: When executor received the shutdown request.
        "403":
          description: The calling user does not have the rights for this endpoint.
        "500":
          description: An internal error occurred.
    patch:
      tags:
      - Executors
      summary: Changes the options of the executor.
      description: The sent data will be parsed and checked if the provided option
        of the executor can be changed.
      parameters:
      - name: uuid
        in: path
        description: The executor's ID.
        required: true
        schema:
          type: string
          example: a68c5d2b-c498-4787-9c8b-4e43bb8da402_ed43f811-6860-489c-a3f9-e710bdc92d5b
      - name: timeout
        in: query
        description: Optional timeout in milliseconds.
        schema:
          format: int64
          default: 30000
          maximum: 60000
          minimum: 0
          type: integer
      - $ref: "#/components/parameters/PreferHeader"
      requestBody:
        content:
          application/json:
            schema:
              default: {}
              type: object
              properties:
                isDraining:
                  default: false
                  type: boolean
                  example: true
            example:
              isDraining: true
      responses:
        "200":
          description: Information about a single executor
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/ExecutorInfo"
            application/json:
              schema:
                $ref: "#/components/schemas/ExecutorInfo"
        "403":
          description: The calling user does not have the rights for this endpoint.
        "422":
          description: The provided input is not valid.
        "500":
          description: An internal error occurred.
        "504":
          description: The executor does not respond within the provided timeout.
  /executors/images:
    get:
      tags:
      - Executors
      summary: Returns a collection of all executor image infos.
      description: "Returns all executor image infos the user can view. If called\
        \ without the `page` parameter, cursor-based pagination will be used. It is\
        \ much faster than page-based pagination and should be preferred. The Mason\
        \ controls and the `pagination` property contain the cursor information for\
        \ the next page."
      parameters:
      - name: If-None-Match
        in: header
        description: Header used to check if a change occurred since the last request.
        schema:
          type: string
      - $ref: "#/components/parameters/ExecutorImageInfoFilterQuery"
      - $ref: "#/components/parameters/ExecutorImageInfoSortQuery"
      - $ref: "#/components/parameters/PageQuery"
      - $ref: "#/components/parameters/CursorQuery"
      - $ref: "#/components/parameters/PagelenQuery"
      - $ref: "#/components/parameters/PreferHeader"
      responses:
        "200":
          description: A list with the executor image infos.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/ExecutorImageInfoList"
            application/json:
              schema:
                $ref: "#/components/schemas/ExecutorImageInfoList"
        "304":
          description: Nothing changed since the last request.
        "500":
          description: An internal error occurred.
    post:
      tags:
      - Executors
      summary: Creates a new executor image info.
      parameters:
      - $ref: "#/components/parameters/PreferHeader"
      description: Create a new executor image info.
      requestBody:
        description: The executor image info.
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/BaseExecutorImageInfo"
      responses:
        "200":
          description: The created executor image info.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/ExecutorImageInfo"
            application/json:
              schema:
                $ref: "#/components/schemas/ExecutorImageInfo"
        "403":
          description: The calling user does not have the rights to create an executor
            image info.
        "413":
          description: The provided input is too large.
        "422":
          description: The provided input is not valid.
        "500":
          description: An internal error occurred.
  /executors/images/{id}:
    get:
      tags:
      - Executors
      summary: Returns the executor image info with the given ID.
      parameters:
      - name: id
        in: path
        description: The ID of the executor image info.
        required: true
        schema:
          format: uuid
          type: string
          example: c151cdc8-b864-441f-9fce-a6e4a30afc0d
      - $ref: "#/components/parameters/PreferHeader"
      responses:
        "200":
          description: Returns the executor image info with the given ID.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/ExecutorImageInfo"
            application/json:
              schema:
                $ref: "#/components/schemas/ExecutorImageInfo"
        "403":
          description: The calling user does not have the rights to view the executor
            image info.
        "404":
          description: The requested executor image info does not exist.
        "500":
          description: An internal error occurred.
    put:
      tags:
      - Executors
      summary: Updates the executor image info with the given ID.
      parameters:
      - name: id
        in: path
        description: The ID of the executor image info.
        required: true
        schema:
          format: uuid
          type: string
          example: c151cdc8-b864-441f-9fce-a6e4a30afc0d
      - $ref: "#/components/parameters/PreferHeader"
      requestBody:
        description: The updated executor image info.
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/BaseExecutorImageInfo"
      responses:
        "200":
          description: Returns the updated executor image info.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/ExecutorImageInfo"
            application/json:
              schema:
                $ref: "#/components/schemas/ExecutorImageInfo"
        "403":
          description: The calling user does not have the rights to update the executor
            image info.
        "404":
          description: The requested executor image info does not exist.
        "413":
          description: The provided input is too large.
        "500":
          description: An internal error occurred.
    delete:
      tags:
      - Executors
      summary: Deletes the executor image info with the given ID.
      parameters:
      - name: id
        in: path
        description: The ID of the executor image info.
        required: true
        schema:
          format: uuid
          type: string
          example: c151cdc8-b864-441f-9fce-a6e4a30afc0d
      responses:
        "204":
          description: The executor image info has been deleted successfully.
        "403":
          description: The calling user does not have the rights to delete the executor
            image info.
        "404":
          description: The requested executor image info does not exist.
        "500":
          description: An internal error occurred.
  /executors/images/{scope}:
    get:
      tags:
      - Executors
      summary: Returns a collection of all executor image infos the user can view
        under a specific scope.
      parameters:
      - name: scope
        in: path
        description: The scope.
        required: true
        schema:
          type: string
          example: account:team:c151cdc8-b864-441f-9fce-a6e4a30afc0d
      - name: If-None-Match
        in: header
        description: Header used to check if a change occurred since the last request.
        schema:
          type: string
      - $ref: "#/components/parameters/PreferHeader"
      responses:
        "200":
          description: A list with the executor image infos.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/ExecutorImageInfoList"
            application/json:
              schema:
                $ref: "#/components/schemas/ExecutorImageInfoList"
        "304":
          description: Nothing changed since the last request.
        "500":
          description: An internal error occurred.
  /executors/{uuid}/diagnostics-bundle:
    post:
      tags:
      - Executors
      summary: Requests the executor to create a diagnostics bundle.
      description: "Sending this request will make the executor create a diagnostics\
        \ bundle. The diagnostics information will be printed as part of the executor\
        \ log and returned as response. If a heap dump shall be created a well, it\
        \ will be stored in a temporary directory in the executor pod."
      parameters:
      - name: uuid
        in: path
        description: The executor's ID.
        required: true
        schema:
          type: string
          example: a68c5d2b-c498-4787-9c8b-4e43bb8da402_ed43f811-6860-489c-a3f9-e710bdc92d5b
      - name: includeHeapDump
        in: query
        description: Flag to determine whether to create a heap dump of the executor
          process as well.
        schema:
          default: false
          type: boolean
          example: true
      - name: timeout
        in: query
        description: Optional timeout in milliseconds.
        schema:
          format: int64
          default: 30000
          type: integer
          example: 120000
      responses:
        "200":
          description: Information about a single executor including the diagnostics.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ExecutorInfo"
        "403":
          description: The calling user does not have the rights for this endpoint.
        "500":
          description: An internal error occurred.
  /jobs:
    get:
      tags:
      - Jobs
      summary: Returns all jobs that are managed by this service.
      description: "The returned list will only contain jobs that the current user\
        \ can read. Only the administrator can see all jobs. If called without the\
        \ `page` parameter, cursor-based pagination will be used. It is much faster\
        \ than page-based pagination and should be preferred. The Mason controls and\
        \ the `pagination` property contain the cursor information for the next page."
      parameters:
      - name: user
        in: query
        deprecated: true
        description: "Deprecated, use a `q` filter expression instead! An optional\
          \ filter to only show the jobs of the specified user. If not provided all\
          \ jobs the current user is allowed to see are returned."
        schema:
          type: string
          example: account:user:9a2c1ce1-cdc4-46f0-93dc-4bfa0aad2ae0
      - name: workflowUri
        in: query
        deprecated: true
        description: "Deprecated, use a `q` filter expression instead! An optional\
          \ filter to only show the jobs of the specified workflow. If not provided\
          \ all jobs the current user is allowed to see are returned. The provided\
          \ parameter can either denote a path to the workflow or its ID."
        schema:
          type: string
        examples:
          id:
            value: '*workflow-id'
            summary: The ID of an workflow.
          path:
            value: /Users/userX/Public+Space/my_workflow
            summary: The path of the workflow.
      - name: scopes
        in: query
        description: "An optional filter to jobs under the provided scopes. If provided,\
          \  all jobs that the user is allowed to view under the provided scopes \
          \ are returned."
        schema:
          default: []
          type: array
          items:
            type: string
        examples:
          oneScope:
            summary: A single provided scope
            value:
            - account:team:c161cdc8-b864-441f-9fce-a123a30afc0d
          multipleScopes:
            summary: Multiple provided scopes
            value:
            - account:team:c161cdc8-b864-441f-9fce-a123a30afc0d
            - account:team:c874cdc8-b864-441f-9fce-a123a30af12c
      - name: forCurrentUser
        in: query
        description: "An optional filter to list jobs for the current user. If this\
          \ parameter is provided with the scopes parameter, all jobs for the current\
          \ user under the provided scopes are returned."
        schema:
          default: false
          type: boolean
          example: true
      - name: If-None-Match
        in: header
        description: Header used to check if a change occurred since the last request.
        schema:
          type: string
      - $ref: "#/components/parameters/FilterQuery"
      - $ref: "#/components/parameters/SortQuery"
      - $ref: "#/components/parameters/PageQuery"
      - $ref: "#/components/parameters/CursorQuery"
      - $ref: "#/components/parameters/PagelenQuery"
      - $ref: "#/components/parameters/PreferHeader"
      responses:
        "200":
          description: A list with jobs
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/JobList"
            application/json:
              schema:
                $ref: "#/components/schemas/JobList"
        "304":
          description: Nothing changed since the last request.
        "422":
          description: The provided filter or sorting is invalid.
        "500":
          description: An internal error occurred.
    post:
      tags:
      - Jobs
      summary: Creates a new job for the provided workflow for ad-hoc execution.
      description: "Creates a new job for the provided workflow using the provided\
        \ execution context, configuration and actions. If no execution context is\
        \ provided the default context of the workflow's space will be used. If no\
        \ configuration is provided the default configuration of the workflow will\
        \ be used."
      parameters:
      - name: workflowUri
        in: query
        description: The path or the ID of the workflow for which a job should be
          created.
        required: true
        schema:
          type: string
        examples:
          id:
            value: '*workflow-id'
            summary: The ID of an workflow.
          path:
            value: /Users/userX/Public+Space/my_workflow
            summary: The path of the workflow.
      - name: itemVersion
        in: query
        description: An optional item version of the workflow. If no version is provided
          the current state will be used. If 'most-recent' is provided the latest
          version will be used.
        schema:
          type: string
      - name: timeout
        in: query
        description: An optional load timeout in milliseconds. In case the job is
          not loaded within the provided timeout a respective response is returned.
          In case no timeout is provided the default timeout of the execution context
          is used.
        schema:
          format: int64
          default: -1
          type: integer
          example: 60000
      - name: asyncLoading
        in: query
        description: "An optional flag to load the job asynchronously, i.e. the service\
          \ returns directly after sending a load message to the message broker. The\
          \ state of a job that has not been loaded yet is LOADING. This flag can\
          \ not be set to true if resetBeforeExecution is also set to true."
        schema:
          default: false
          type: boolean
          example: true
      - name: resetBeforeExecution
        in: query
        description: An optional flag to reset the job after it has been loaded.  If
          this flag is set the job will be loaded as usual and then immediatly reset.
          This flag can not be set to true if asyncLoading is also set to true.
        schema:
          default: false
          type: boolean
          example: true
      - name: wizardExecution
        in: query
        description: An optional flag to run this job like a Data App. This flag should
          be only used by the KNIME Web App.
        schema:
          default: false
          type: boolean
          example: true
      - $ref: "#/components/parameters/JobCreatedByHeader"
      - $ref: "#/components/parameters/PreferHeader"
      requestBody:
        content:
          application/json:
            schema:
              default: {}
              type: object
              properties:
                executionContext:
                  format: uuid
                  description: An optional execution context that is used for the
                    job. If no execution context is provided the default context of
                    the space of the workflow will be used.
                  type: string
                  example: 27d64eb1-a426-4f3b-b973-98c81d7350f3
                configuration:
                  $ref: "#/components/schemas/WorkflowConfiguration"
                actions:
                  description: Actions that are triggered after the execution of the
                    job has been finished. These actions can be also when updating
                    the job via PUT.
                  default: []
                  type: array
                  items:
                    anyOf:
                    - $ref: "#/components/schemas/SendMailAction"
                    - $ref: "#/components/schemas/SaveReportAction"
                    - $ref: "#/components/schemas/CallWorkflowAction"
                requiredExecutionContextFeatures:
                  description: The execution context features required by this job.
                  default:
                  - EXECUTION
                  type: array
                  items:
                    enum:
                    - EXECUTION
                    - EDITING
                    type: string
                  example:
                  - EDITING
            example:
              configuration:
                integer-configuration: 33
                string-configuration: my config
              actions:
              - type: SendMail
                customName: Report Mail
                onSuccess: true
                onFailure: false
                onInactivityDiscard: false
                reportFormats:
                - PDF
                - HTML
                appendNodeMessages: false
                recipients:
                - mail1@<emailhost1>.<org>
                - mail2@<emailhost2>.<com>
              - type: CallWorkflow
                customName: Cleanup
                onSuccess: true
                onFailure: true
                jobName: cleanup-job
                discardAfterSuccessfulExec: true
                discardAfterFailedExec: false
                reset: true
                actions:
                - type: SendMail
                  customName: Cleanup Fail Mail
                  onSuccess: false
                  onFailure: true
                  onInactivityDiscard: false
                  appendNodeMessages: true
                  recipients:
                  - workflowMaintainer@<emailhost>.<org>
                workflowUri: '*cleanupWorkflow'
                workflowConfiguration:
                  clean-filesystem-config: true
      responses:
        "201":
          description: The created job
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/WorkflowJob"
            application/json:
              schema:
                $ref: "#/components/schemas/WorkflowJob"
        "403":
          description: The calling user does not have the rights to execute the workflow.
        "422":
          description: The provided configuration is invalid.
        "500":
          description: An internal error occurred.
        "504":
          description: The job was not loaded within time.
    delete:
      tags:
      - Jobs
      summary: Deletes a set of jobs.
      description: "If the current user has permissions to delete all supplied jobs\
        \ they will all be deleted. In case permissions are missing for at least one\
        \ job or at least one job doesn't exist, the request will fail."
      requestBody:
        content:
          application/json:
            schema:
              description: An array of job IDs (UUIDs).
              type: array
              items:
                format: uuid
                type: string
                example: 27d64eb1-a426-4f3b-b973-98c81d7350f3
      responses:
        "204":
          description: All jobs have been deleted successfully.
        "403":
          description: The calling user does not have the rights to delete at least
            one job.
        "404":
          description: At least one provided job does not exist.
        "422":
          description: The provided job list is invalid.
        "500":
          description: An internal error occurred.
  /jobs/{uuid}:
    get:
      tags:
      - Jobs
      summary: Returns all information for the given job ID.
      parameters:
      - name: uuid
        in: path
        description: The job's ID
        required: true
        schema:
          format: uuid
          type: string
          example: c151cdc8-b864-441f-9fce-a6e4a30afc0d
      - name: If-None-Match
        in: header
        description: Header used to check if a change occurred since the last request.
        schema:
          type: string
      - $ref: "#/components/parameters/PreferHeader"
      responses:
        "200":
          description: Information about the job.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/WorkflowJob"
            application/json:
              schema:
                $ref: "#/components/schemas/WorkflowJob"
        "304":
          description: Nothing changed since the last request.
        "403":
          description: The calling user does not have the rights to cancelview the
            job.
        "404":
          description: The job is unknown.
        "500":
          description: An internal error occurred.
    put:
      tags:
      - Jobs
      summary: Modifies an existing job using the values from the passed object.
      description: Note that not all properties can be updated because some properties
        are read-only. If the current and the updated values for read-only properties
        are different no update is performed and an error is raised.
      parameters:
      - name: uuid
        in: path
        description: The job's ID.
        required: true
        schema:
          format: uuid
          type: string
          example: c151cdc8-b864-441f-9fce-a6e4a30afc0d
      - name: timeout
        in: query
        description: An optional timeout in milliseconds for setting input parameters.
          In case the input parameters are not set within the provided timeout a respective
          response is returned. In case no timeout is provided the default load timeout
          of the execution context is used.
        schema:
          format: int64
          default: -1
          type: integer
          example: 60000
      - name: reset
        in: query
        description: An optional flag to reset the job. Note that a job can be also
          reset when execution is triggered.
        schema:
          format: uuid
          default: false
          type: boolean
          example: true
      - $ref: "#/components/parameters/PreferHeader"
      requestBody:
        description: "Input to update the job. In case a property is omitted the value\
          \ will not be updated. It's also possible to provide a complete instance\
          \ of WorkflowJob, however other fields are read only and have to reflect\
          \ the current state of the job as otherwise an error is raised."
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/BaseJob"
          application/vnd.mason+json:
            schema:
              $ref: "#/components/schemas/BaseJob"
      responses:
        "200":
          description: The updated job.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/WorkflowJob"
            application/json:
              schema:
                $ref: "#/components/schemas/WorkflowJob"
        "403":
          description: The calling user does not have the rights to update the job.
        "404":
          description: The job is unknown.
        "422":
          description: The provided input is not valid.
        "500":
          description: An internal error occurred.
        "504":
          description: The input parameters were not set or the job was not reset
            within time.
    post:
      tags:
      - Jobs
      summary: Executes the given job
      description: |-
        If no data is sent the job is executed with the current input parameters (if there are any), otherwise the input parameters are set according to the JSON map that is sent in the request body.
