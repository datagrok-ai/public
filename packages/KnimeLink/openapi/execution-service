  parameters:
    FilterQuery:
      name: q
      in: query
      description: |
        An optional filter to only show the jobs that match the filter. Only a single attribute can be used for
        filtering right now. Available attributes are:
          - `workflowId` : ID of the workflow
          - `workflowPath` : Path of the workflow
          - `itemVersion`: the corresponding workflow's version
          - `jobState`: the job's state, one of `UNDEFINED`, `LOAD_ERROR`, `LOAD_REQUESTED`, `LOADING`, `LOADED`, `SWAP_REQUESTED', `SWAPPING`, `SWAPPED`, `DISCARD_REQUESTED`, `VANISHED
          - `workflowState`: the state of the workflow behind this job, one of `UNDEFINED`, `CONFIGURED`, `IDLE`, `EXECUTION_FAILED`, `EXECUTION_CANCELLED`, `EXECUTION_FINISHED`, `INTERACTION_REQUIRED`, `EXECUTUON_FAILED_WITH_CONTENT`, `EXECUTING`, `NOT_EXECUTABLE`
          - `creator`: the fully-qualified ID of the job's creator
          - `deploymentId`: the fully-qualified ID of the deployment from which the job was created
          - `executor`: the ID of the executor in which the job is loaded
      schema:
        type: string
      examples:
        itemVersion:
          value: itemVersion=1
          summary: filter by version of the item.
        state:
          value: state=CONFIGURED
          summary: filter by state of the job.
    DeploymentFilterQuery:
      name: q
      in: query
      description: |
        An optional filter to only show the deployments that match the filter. Only a single attribute can be used for filtering right now. Available attributes are:
          - `workflowPath`: the workflow path
          - `workflowId`: the workflow id
          - `creator`: the fully-qualified ID of the deployment's creator
          - `executionContextId`: the fully-qualified ID of the execution context under which deployment was created
      schema:
        type: string
      examples:
        workflowPath:
          value: workflowPath=*abcdef
          summary: filter by workflow of the deployment.
    DeploymentFilterQueryExecutionContext:
      name: q
      in: query
      description: |
        An optional filter to only show the deployments that match the filter. Only a single attribute can be used for filtering right now. Available attributes are:
          - `workflowPath`: the workflow path
          - `workflowId`: the workflow path
          - `creator`: the fully-qualified ID of the deployment's creator
      schema:
        type: string
      examples:
        workflowPath:
          value: workflowPath=*abcdef
          summary: filter by workflow path of the deployment.
    SortQuery:
      name: sort
      in: query
      description: "An optional parameter for sorting. By default results are sorted\
        \ in ascending order. If you prefix the attribute with `-` the sort order\
        \ is descending. You can provide multiple attributes separated by commas.\
        \ The default sorting is `createdAt`. \nAvailable attributes for sorting are:\n\
        \  - `id`: the job ID\n  - `name`: the job name\n  - `workflowId` : ID of\
        \ the workflow\n  - `workflowPath` : Path of the workflow\n  - `itemVersion`:\
        \ the corresponding workflow's version\n  - `jobState`: the job's state\n\
        \  - `workflowState`: the state of the workflow behind the job\n  - `creator`:\
        \ the fully-qualified ID of the job's creator\n  - `deploymentId`: the fully-qualified\
        \ ID of the deployment from which the job was created\n  - `executor`: the\
        \ ID of the executor in which the job is loaded\n  - `createdAt`: the job's\
        \ creation timestamp\n  - `startedAt`: the timestamp when the job started\
        \ executing\n"
      schema:
        enum:
        - id
        - -id
        - name
        - -name
        - workflowId
        - -workflowId
        - workflowPath
        - -workflowPath
        - itemVersion
        - -itemVersion
        - jobState
        - -jobState
        - workflowState
        - -workflowState
        - creator
        - -creator
        - deploymentId
        - -deploymentId
        - executor
        - -executor
        - createdAt
        - -createdAt
        - startedAt
        - -startedAt
        type: string
      examples:
        nonDescending:
          value: state
          summary: sort by string value of state in ascending order
        nonAscending:
          value: "-state,createdAt"
          summary: sort by string value of state in descending order and then by createdAt
            in ascending order
    DeploymentSortQuery:
      name: sort
      in: query
      description: |
        An optional parameter for sorting. By default results are sorted in ascending order. If you prefix the attribute with `-` the sort order is descending. You can provide multiple attributes separated by commas. The default sorting is `createdAt`.
        Available attributes for sorting are:
          - `workflowId`: the workflow ID
          - `workflowPath`: the workflow path
          - `itemVersion`: the corresponding workflow's version
          - `creator`: the fully-qualified ID of the deployment's creator
          - `executionContextId`: the fully-qualified ID of the execution context under which deployment was created
          - `type`: type of the deployment
          - `createdAt`: the deployment's creation timestamp
      schema:
        enum:
        - workflowId
        - -workflowId
        - workflowPath
        - -workflowPath
        - itemVersion
        - -itemVersion
        - creator
        - -creator
        - executionContextId
        - -executionContextId
        - type
        - -type
        - createdAt
        - -createdAt
        type: string
      examples:
        nonDescending:
          value: workflowPath
          summary: sort by string value of workflow path in ascending order
        nonAscending:
          value: "-workflowPath,createdAt"
          summary: sort by string value of workflow path in descending order and then
            by creation date in ascending order
    DeploymentSortQueryExecutionContext:
      name: sort
      in: query
      description: |
        An optional parameter for sorting. By default results are sorted in ascending order. If you prefix the attribute with `-` the sort order is descending. The default sorting is `createdAt`.
        Available attributes for sorting are:
          - `workflowId`: the workflow ID
          - `workflowPath`: the workflow path
          - `itemVersion`: the corresponding workflow's version
          - `creator`: the fully-qualified ID of the deployment's creator
          - `type`: type of the deployment
          - `createdAt`: the deployment's creation timestamp
      schema:
        enum:
