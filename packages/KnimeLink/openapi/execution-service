components:
  schemas:
    Control:
      description: A hypermedia element associated with this resource.
      type: object
      properties:
        href:
          type: string
        method:
          type: string
        encoding:
          enum:
          - None
          - Json
          - JsonPlusFiles
          - Raw
          type: string
        isHrefTemplate:
          type: boolean
        accept:
          type: array
          items:
            type: string
        output:
          type: array
          items:
            type: string
        template:
          type: object
        title:
          type: string
        type:
          type: string
          writeOnly: true
    Error:
      description: A potential error attached to this Mason object.
      type: object
      properties:
        '@id':
          type: string
        '@message':
          type: string
        '@code':
          type: string
        '@messages':
          type: array
          items:
            type: string
    Namespace:
      description: A (possibly empty) map with the namespaces for this object.
      type: object
      properties:
        name:
          type: string
    ExecutorInfoList:
      description: A collection of executor information.
      type: object
      properties:
        '@controls':
          description: A (possibly empty) map with all controls for this object.
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Control"
        '@namespaces':
          description: A (possibly empty) map with the namespaces for this object.
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Namespace"
        executorInfos:
          type: array
          items:
            $ref: "#/components/schemas/ExecutorInfo"
    ExecutorInfo:
      type: object
      properties:
        '@controls':
          description: A (possibly empty) map with all controls for this object.
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Control"
        '@namespaces':
          description: A (possibly empty) map with the namespaces for this object.
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Namespace"
        executorId:
          description: The unique id of the executor.
          type: string
          example: a68c5d2b-c498-4787-9c8b-4e43bb8da402_ed43f811-6860-489c-a3f9-e710bdc92d5b
        executorName:
          description: The name of the executor.
          type: string
          example: executor-a68c5d2b-c498-4797-8d8b-4e43bb8da402-fe43f811-6860-489
          deprecated: true
        executionContext:
          format: uuid
          description: The execution context the executor belongs to.
          type: string
          example: bd385280-a57f-49e9-9e2d-0ddde6bea59f
        heapUsage:
          format: double
          description: The heapspace usage in percent.
          type: number
          example: 54.3
        cpuLoad:
          format: double
          description: The overall CPU load relative to the number of vCores.
          type: number
          example: 0.9
        isDraining:
          description: "If the executor is in draining state, i.e. it doesn't accept\
            \ new jobs."
          type: boolean
          example: false
        isTerminating:
          description: "If the executor is marked for termination, i.e. it will be\
            \ shut down."
          type: boolean
          example: true
        ips:
          description: The executor's IP adresses. This property will only be returned
            if the calling user has appropriate permissions.
          type: array
          items:
            type: string
          example:
          - 192.2.1.4
          - 27.0.0.1
        workflowMap:
          description: A mapping between job states and the number of jobs.
          type: object
          additionalProperties:
            format: int32
            type: integer
          example:
            EXECUTING: 3
            EXECUTION_FINISHED: 2
        executorUptime:
          format: int64
          description: The uptime of the executor in milliseconds.
          type: integer
          example: 5700000
        freeDiskSpace:
          format: int64
          description: The free disk space in bytes.
          type: integer
          example: 4518293504
        totalDiskSpace:
          format: int64
          description: The total disk space in bytes.
          type: integer
          example: 21462233088
        executorConnectorVersion:
          description: The version of the executor connector plugin.
          type: string
          example: 5.17.3
        analyticsPlatformVersion:
          description: The version of the underlying KNIME Analytics Platform.
          type: string
          example: 7.3.1
    ExecutionContextList:
      description: A collection of execution contexts.
      type: object
      properties:
        '@controls':
          description: A (possibly empty) map with all controls for this object.
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Control"
        '@namespaces':
          description: A (possibly empty) map with the namespaces for this object.
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Namespace"
        executionContexts:
          type: array
          items:
            $ref: "#/components/schemas/ExecutionContext"
        pagination:
          $ref: "#/components/schemas/PaginationInfo"
    ExecutionContext:
      description: All information of an execution context.
      allOf:
      - type: object
        properties:
          '@controls':
            description: A (possibly empty) map with all controls for this object.
            type: object
            additionalProperties:
              $ref: "#/components/schemas/Control"
          '@namespaces':
            description: A (possibly empty) map with the namespaces for this object.
            type: object
            additionalProperties:
              $ref: "#/components/schemas/Namespace"
          id:
            format: uuid
            description: The context's unique ID.
            type: string
            example: 7d444840-9dc0-11d1-b245-5ffdce74fad2
          scope:
            format: fully qualified identifier
            description: The scope under which the context exists.
            type: string
            example: account:team:7fcb5934-b65f-42bf-a7c5-f5828ba56940
          parentId:
            format: uuid
            description: The ID of the parent context.
            type: string
            example: 7d444840-9dc0-11d1-b245-5ffdce74fad2
          isDisabled:
            description: If the context is disabled. Note that disabled contexts cannot
              be used to load jobs.
            type: boolean
            example: false
          isTemplate:
            description: If the context is a template. Note that templates cannot
              be used to load jobs.
            type: boolean
            example: true
          isPool:
            description: "If the context maintains a pool of executors. Execution\
              \ contexts with a pool attach their executors on demand. Note, that\
              \ this requires a special setup."
            default: false
            type: boolean
            example: true
          readOnly:
            description: Inherited properties that cannot be overriden by the context.
            type: array
            items:
              type: string
              example: maxJobExecutionTime
          inherited:
            description: Properties that are inherited from the parent.
            type: array
            items:
              type: string
            example:
            - maxJobExecutionTime
            - defaultLoadTimeout
          inheritable:
            description: A list of all inheritable properties.
            type: array
            items:
              type: string
              example: defaultLoadTimeout
          executorApVersion:
            description: The version of KNIME Analytics Platform that is run by the
              executors of this execution context. The information is only available
              after the first executor has successfully started.
            type: string
            readOnly: true
            example: 5.1.1.v202309181230
          executorConnectorVersion:
            description: The version of the KNIME Server/Hub connector installed in
              the executors of this execution context. The information is only available
              after the first executor has successfully started.
            type: string
            readOnly: true
            example: 4.17.0.v202309181230
      - $ref: "#/components/schemas/BaseExecutionContext"
    ExecutionContextWithMetrics:
      description: All information of an execution context including live metrics
        such as jobs and deployment counts.
      allOf:
      - type: object
        properties:
          liveMetrics:
            description: Live metrics about the execution context.
            type: object
            properties:
              deployments:
                description: The number of deployments associated with this execution
                  context.
                minimum: 0
                type: integer
                example: 3
              jobs:
                description: The number of active jobs in this execution context.
                minimum: 0
                type: integer
                example: 3
              loadedJobs:
                description: The number of active jobs loaded on executors in this
                  execution context.
                minimum: 0
                type: integer
                example: 3
              lastJobStatusUpdate:
                format: date-time
                description: The last job status update received in this execution
                  context.
                type: string
                example: "2023-06-19T16:21+01:00[Europe/Zurich]"
      - $ref: "#/components/schemas/ExecutionContext"
    BaseExecutionContext:
      required:
      - name
      - scope
      - clusterId
      type: object
      properties:
        name:
          description: The name of the execution context.
          type: string
          example: Datascience Context
        description:
          description: User given description of the context.
          default: ""
          type: string
          example: Execution Context for heavy jobs.
        scope:
          format: fully qualified identifier
          description: The scope under which the execution context should be created.
          type: string
          example: account:team:7df44321-9dc0-11d1-b245-5ffdce74fad2
        clusterInfoId:
          format: uuid
          description: The cluster info id.
          type: string
          example: 7df44321-9dc0-11d1-b245-5ffdce74fad2
        tags:
          description: User given tags of the context
          default: []
          type: array
          items:
            type: string
          example:
          - PYTHON 3
          - GPU
          - Heavy jobs
        final:
          description: "Properties that are set final, i.e. cannot be overriden by\
            \ descending contexts. Note that this also includes final properties of\
            \ ancestors."
          default: []
          type: array
          items:
            type: string
          example:
          - maxJobExecutionTime
          - defaultLoadTimeout
        maxJobTimeInMemory:
          format: duration
          description: The maximum time an inactive job stays loaded in the executor.
            The value is formatted according to ISO 8601.
          default: PT1H
          type: string
          example: PT1H
        defaultDeploymentRunMode:
          description: The default run mode used for new deployments which do not
            set their own run  mode.
          default: ACCOUNT
          enum:
          - ACCOUNT
          - INITIATOR
          type: string
          example: ACCOUNT
        maxJobLifeTime:
          format: duration
          description: The maximum time of an inactive job before it gets deleted.
            The value is formatted according to ISO 8601.
          default: PT24H
          type: string
          example: PT144H
        maxJobExecutionTime:
          format: duration
          description: The maximum execution time of a job. The value is formatted
            according to ISO 8601.
          default: P24H
          type: string
          example: PT5H
        maxJobInOutSize:
          description: "The maximum size in megabytes that inline input and output\
            \ of a job can have. The limit is for input and output separately, i.e.\
            \ by default both input and output can have 10 MB. If the input or the\
            \ output is larger a client error will be returned."
          default: 10
          type: integer
          example: 5
        discardAfterMaxExecutionTime:
          description: If the job should be discarded after the maximum execution
            time has been reached.
          default: false
          type: boolean
          example: false
        updateLinkedComponents:
          description: If linked components should be updated when loading a job.
          default: false
          type: boolean
          example: true
        rejectFutureWorkflows:
          description: If jobs of workflows that were created with a newer version
            of KNIME Analytics Platform should be rejected by the executor.
          default: true
          type: boolean
          example: true
        defaultLoadTimeout:
          format: duration
          description: The default timeout when loading a job. The value is formatted
            according to ISO 8601.
          default: PT5M
          type: string
          example: PT10M
        defaultAsyncLoadTimeout:
          format: duration
          description: The default timeout when loading a job asynchronously. The
            value is formatted according to ISO 8601.
          default: PT5M
          type: string
          example: PT10M
        defaultExecutionTimeout:
          format: duration
          description: The default timeout when executing a job synchronously. The
            value is formatted according to ISO 8601.
          default: PT5M
          type: string
          example: PT10M
        defaultReportTimeout:
          format: duration
          description: The default timeout when rendering a report. The value is formatted
            according to ISO 8601.
          default: PT5M
          type: string
          example: PT10M
        defaultSwapTimeout:
          format: duration
          description: The default timeout when swapping a job. The value is formatted
            according to ISO 8601.
          default: PT1M
          type: string
          example: PT10M
        defaultSessionTimeout:
          format: duration
          description: The default timeout after which a session to a job is deleted
            if it doesn't have any open connections. The value is formatted according
            to ISO 8601.
          default: PT1M
          type: string
          example: PT10M
        defaultCpuRequirement:
          format: double
          description: The default number of vCores reserved in the executor when
            loading a job.
          default: 0
          minimum: 0
          type: number
          example: 1.5
        defaultRamRequirement:
          format: int64
          description: The default bytes of memory reserved in the executor when loading
            a job.
          default: 0
          minimum: 0
          type: integer
          example: 365000000
        defaultMaxScheduleFailures:
          format: int64
          description: The default value for the number of maximum schedule failure
            before the deployment gets disabled.
          default: 2147483647
          minimum: 0
          type: integer
          example: 5
        blacklistedNodes:
          description: Blacklisted nodes that aren't allowed to be executed. This
            is a comma separated list of factory names of the nodes and might contain
            wildcards (*).
          default: ""
          type: string
          example: "org.knime.base.node.jsnippet.JavaSnippetNodeFactory,org.knime.ext.sun.nodes.script.*Java*"
        perJobLogging:
          description: If logging per-job should be enabled. If this is true it is
            possible to retrieve individual job logs for jobs executed in this execution
            context.
          default: true
          type: boolean
          example: false
        maxSwapFailures:
          format: int32
          description: The maximum number of failed swap attempts before a job is
            considered unswappable.
          default: 2147483647
          maximum: 2147483647
          minimum: 0
          type: integer
          example: 3
        saveWorkflowSummary:
          description: If the workflow summary of the job should be saved when the
            job is swapped.
          default: false
          type: boolean
          example: true
        startExecutionTimeout:
          format: duration
          description: The timeout the service will wait until execution has been
            started by the executor. The value is formatted according to ISO 8601.
          default: PT1M
          type: string
          example: PT30S
        maxLoadedJobsPerExecutor:
          description: The maximum number of jobs that can be loaded at the same time
            into a single executor. The executor will not accept any additional jobs
            if this number has been reached until an existing job gets unloaded. The
            default is unlimited.
          default: 2147483647
          type: integer
          example: 5
        customizationProfiles:
          description: An ordered list of customization profiles that are enabled
            for this execution context.
          default: []
          type: array
          items:
            format: uuid
            type: string
          example:
          - 28b65793-3a52-43fa-b58f-fb4c6d567f69
          - 333df3e2-683f-43c3-a414-3a7714a9ac04
        operationInfo:
          description: The operational information for running executors.
          type: object
          properties:
            updateStrategy:
              description: |-
                The update strategy for executors.
                  - `RECREATE`: All existing executors are terminated before new ones are started ensuring a clean transition without requiring additional hardware resources but at the cost of downtime.
                  - `ROLLING_UPDATE`: Executors are gradually replaced with new ones starting while old ones are still running. This minimizes downtime but introduces version overlap and requires additional hardware resources during the transition.
                  - `ON_DELETE`: Executors are updated only when vCore or memory settings change, causing the executors to restart. In all other cases updates take effect only after a restart, which can be triggered manually or by the auto-stop functionality.
              enum:
              - RECREATE
              - ROLLING_UPDATE
              - ON_DELETE
              type: string
            minExecutors:
              format: int32
              description: The minimum numbers of executors that should run.
              default: 0
              minimum: 0
              type: integer
              example: 1
            maxExecutors:
              format: int32
              description: The maximum numbers of executors that should run.
              default: 1
              minimum: 0
              type: integer
              example: 3
            dockerImage:
              description: The docker image of the executor.
              type: string
            kubernetesNodeLabel:
              description: A Kubernetes node label which is used to select the node
                where to start executors of this execution context.
              type: string
              example: gpu
            containerCores:
              format: int32
              description: Number of vCores per container.
              default: 1
              minimum: 1
              type: integer
              example: 4
            containerMemoryLimit:
              format: int64
              description: Memory limit of the container in megabytes.
              default: 2048
              minimum: 2048
              type: integer
              example: 8192
            executorCPUUsagePercentLimit:
              format: int32
              description: "The CPU load threshold (in percent, normalized on CPU\
                \ count) above which the executor will not accept new jobs any more."
              default: 90
              minimum: 0
              type: integer
              example: 90
            executorHeapUsagePercentLimit:
              format: int32
              description: The memory (heap) usage limit (in percent) above which
                the executor will not accept new jobs any more.
              default: 90
              maximum: 100
              minimum: 0
              type: integer
              example: 90
            envVars:
              description: Environment variables that are passed to the executor on
                startup.
              default: {}
              type: object
              additionalProperties:
                type: string
              example:
                ENV_VAR_1: value 1
                ENV_VAR_2: value 2
            applicationArguments:
              description: An ordered list of arguments that are passed to the executor.
              default: []
              type: array
              items:
                type: string
              example:
              - -profileList
              - "executor,python"
            vmArguments:
              description: An ordered list of arguments that are passed to the Java
                runtime environment.
              default: []
              type: array
              items:
                type: string
              example:
              - -Dfoo=bar
            autoStart:
              description: Controls the execution context's executors auto start behavior.
              type: object
              properties:
                enabled:
                  description: Whether auto start is enabled for this execution context's
                    executors
                  default: true
                  type: boolean
                  example: false
            autoStop:
              description: Controls the execution context's executors auto stop behavior.
              type: object
              properties:
                enabled:
                  description: Whether auto stop is enabled for this execution context's
                    executors.
                  default: true
                  type: boolean
                  example: false
                idleTime:
                  format: duration
                  description: The idle time after which the execution context's executors
                    will be automatically stopped. The idle time is the period of
                    time during which an execution context is continuously idle. The
                    value is formatted according to ISO 8601.
                  default: PT1H
                  type: string
                  example: PT30S
        defaultForSpaces:
          description: The ID of the spaces for which this execution context is the
            default context.
          default: []
          type: array
          items:
            type: string
          example:
          - '*space1Id'
          - '*space2Id'
        executionContextFeatures:
          description: The features offered by this execution context.
          default:
          - EXECUTION
          type: array
          items:
            enum:
            - EXECUTION
            - EDITING
            type: string
          example:
          - EDITING
    JobList:
      description: A collection of jobs.
      required:
      - jobs
      type: object
      properties:
        '@controls':
          description: A (possibly empty) map with all controls for this object.
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Control"
        '@namespaces':
          description: A (possibly empty) map with the namespaces for this object.
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Namespace"
        pagination:
          $ref: "#/components/schemas/PaginationInfo"
        jobs:
          type: array
          items:
            $ref: "#/components/schemas/WorkflowJobList"
    WorkflowJob:
      allOf:
      - $ref: "#/components/schemas/WorkflowJobMason"
      - description: Represents a single job.
        type: object
        properties:
          configuration:
            $ref: "#/components/schemas/WorkflowConfiguration"
          outputResources:
            description: The output resources that can be accessed via the respective
              REST endpoint after execution finished successfully.
            type: object
            additionalProperties:
              type: string
          outputValues:
            description: The output values created by this job.
            type: object
            additionalProperties:
              enum:
              - null
              anyOf:
              - type: array
                items: {}
              - type: object
              - type: string
              - type: number
              - type: boolean
            example:
              "42": null
              string-output: My custom output
              integer-output: null
          inputResources:
            description: The input resources that were used to execute this job.
            type: object
            additionalProperties:
              type: string
      - $ref: "#/components/schemas/BaseWorkflowJob"
      - $ref: "#/components/schemas/BaseJob"
      - $ref: "#/components/schemas/WorkflowJobMason"
      - description: Represents a single job.
        type: object
        properties:
          configuration:
            $ref: "#/components/schemas/WorkflowConfiguration"
          outputResources:
            description: The output resources that can be accessed via the respective
              REST endpoint after execution finished successfully.
            type: object
            additionalProperties:
              type: string
          outputValues:
            description: The output values created by this job.
            type: object
            additionalProperties:
              enum:
              - null
              anyOf:
              - type: array
                items: {}
              - type: object
              - type: string
              - type: number
              - type: boolean
            example:
              "42": null
              string-output: My custom output
              integer-output: null
          inputResources:
            description: The input resources that were used to execute this job.
            type: object
            additionalProperties:
              type: string
      - $ref: "#/components/schemas/BaseWorkflowJob"
      - $ref: "#/components/schemas/BaseJob"
    WorkflowJobList:
      type: object
      allOf:
      - $ref: "#/components/schemas/WorkflowJobMason"
      - $ref: "#/components/schemas/BaseWorkflowJob"
      - $ref: "#/components/schemas/StrippedBaseJob"
    BaseWorkflowJob:
      description: Represents a single job.
      type: object
      properties:
        id:
          format: uuid
          description: The job's unique ID.
          type: string
          example: 7d444840-9dc0-11d1-b245-5ffdce74fad2
        scope:
          format: fully qualified identifier
          description: The scope under which the job exists.
          type: string
          example: account:team:7fcb5934-b65f-42bf-a7c5-f5828ba56940
        deploymentId:
          format: uuid
          description: The ID of the schedule deployment if triggered by one.
          type: string
          example: c151cdc8-b864-441f-9fce-a6e4a30afc0d
        parentId:
          format: uuid
          description: The parent id if this job has been triggered due to an action
            or failure of another job.
          type: string
          example: d85e287b-485e-4d6b-9b4c-5840e5248005
        executorID:
          description: The unique id of the executor the job is loaded in. Not present
            if the job is swapped.
          type: string
          example: a885bb42-d808-4557-9a7f-9f10c5777739@bd385280-a57f-49e9-9e2d-0ddde6bea59f
        executorName:
          description: The name of the executor the job is loaded in. Not present
            if the job is swapped.
          type: string
          example: Machine-01
        executorIPs:
          description: The executor's IP adresses if the job is loaded in an executor.
            Not present if the job is swapped. This property will only be returned
            if the calling user has appropriate permissions.
          uniqueItems: true
          type: array
          items:
            type: string
          example:
          - 192.2.1.4
          - 27.0.0.1
        createdVia:
          description: Returns the created by info inferred from the client type.
          enum:
          - KNIME Explorer
          - Workflow
          - Hub UI
          - Schedule Handler
          - Trigger Service
          - Post Execution Handler
          - generic client
          type: string
          example: generic client
        createdBy:
          description: Contains the created by info in case the client provided it
            when creating the job.
          type: string
          example: My external Application.
        workflow:
          description: The path of the workflow to which this jobs belongs.
          type: string
          example: /Users/userX/Public Space/workflowA
        workflowId:
          description: The id of the underlying workflow.
          type: string
          example: '*workflowId'
        itemVersion:
          description: The item version of the workflow. If empty the current state
            at creation was being used.
          type: string
          example: 1
        creator:
          description: The creator of the job. The creator is the user or the (account)
            application-password that actually executes the job. The job will run
            with the permissions of the creator.
          type: string
          example: account:user:9a2c1ce1-cdc4-46f0-93dc-4bfa0aad2ae0
        creatorName:
          description: The account name of the creator.
          type: string
          example: user321
        initiator:
          description: The initiator of the job. The initiator is the user or application
            password that triggered job creation.
          type: string
          example: account:user:c8ec21a3-e522-404d-bdee-3159e41a3055
        initiatorName:
          description: The account name of the initiator.
          type: string
          example: user123
        state:
          description: The current state of the job. This property is deprecated.
            Use `jobState` and `workflowState` instead.
          enum:
          - EXECUTING
          - CONFIGURED
          - IDLE
          - UNDEFINED
          - DISCARDED
          - LOAD_ERROR
          - EXECUTION_FAILED
          - EXECUTION_CANCELLED
          - EXECUTION_FINISHED
          - INTERACTION_REQUIRED
          - EXECUTION_FAILED_WITH_CONTENT
          - LOADING
          - NOT_EXECUTABLE
          - SWAPPING
          - VANISHED
          type: string
          deprecated: true
        jobState:
          description: The current state of the job.
          enum:
          - UNDEFINED
          - LOAD_REQUESTED
          - LOADING
          - LOADED
          - LOAD_ERROR
          - SWAP_REQUESTED
          - SWAPPING
          - SWAPPED
          - VANISHED
          - DISCARD_REQUESTED
          - DISCARDED
          type: string
          example: LOADING
        workflowState:
          description: The current state of the workflow behing this job.
          enum:
          - UNDEFINED
          - CONFIGURED
          - IDLE
          - NOT_EXECUTABLE
          - EXECUTING
          - EXECUTED
          - EXECUTION_FAILED
          - EXECUTION_CANCELLED
          - EXECUTION_FINISHED
          - INTERACTION_REQUIRED
          - EXECUTION_FAILED_WITH_CONTENT
          type: string
          example: IDLE
        nodeMessages:
          description: A collection with all node messages that occurred during execution.
          type: array
          items:
            $ref: "#/components/schemas/NodeMsg"
          example:
          - node: Kafka Connector 7:1
            messageType: ERROR
            message: "Execute failed: Cannot connect to server."
        isOutdated:
          description: "If the underlying workflow has been updated, i.e. the job\
            \ doesn't reflect the current workflow."
          type: boolean
          example: true
        createdAt:
          format: date-time
          description: The date and time this job was created.
          type: string
          example: "2022-02-22T22:10:00.000281+01:00[Europe/Berlin]"
        hasReport:
          description: Whether the job is able to create a report.
          type: boolean
          example: true
        isSwapped:
          description: Indicates if the job is persisted to the object store rather
            than loaded in an executor.
          type: boolean
          example: false
        finishedExecutionAt:
          format: date-time
          description: The date and time this job finished execution.
          type: string
          example: "2022-02-23T02:10:11.000281+01:00[Europe/Berlin]"
        startedExecutionAt:
          format: date-time
          description: The date and time this job started execution.
          type: string
          example: "2022-02-22T22:10:20.000281+01:00[Europe/Berlin]"
    BaseJob:
      allOf:
      - type: object
        properties:
          InputParameters:
            $ref: "#/components/schemas/InputParameters"
      - $ref: "#/components/schemas/StrippedBaseJob"
    WorkflowJobMason:
      type: object
      properties:
        '@controls':
          description: A (possibly empty) map with all controls for this object.
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Control"
        '@error':
          $ref: "#/components/schemas/Error"
        '@namespaces':
          description: A (possibly empty) map with the namespaces for this object.
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Namespace"
    StrippedBaseJob:
      type: object
      properties:
