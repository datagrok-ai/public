              schema:
                $ref: "#/components/schemas/ExecutionContextList"
        "403":
          description: The calling user does not have the rights for this endpoint.
        "422":
          description: The provided space ID is invalid.
        "500":
          description: An internal error occurred.
    post:
      tags:
      - Execution Contexts
      summary: Creates a new execution context.
      description: "Creates a new execution context. An execution context can be declared\
        \ as a template, s.t. it cannot be attached to spaces and hence not used to\
        \ load jobs. Furthermore, execution contexts can have parent contexts and\
        \ inherit their properties. These properties can be either overridden or set\
        \ to be read only for descendants."
      parameters:
      - $ref: "#/components/parameters/PreferHeader"
      requestBody:
        description: An ExecutionContext object. If a property is omited its default
          value will be used. An explicit ID can be provided optionally. If none is
          provided the server will generate a random ID.
        content:
          application/json:
            schema:
              allOf:
              - type: object
                properties:
                  id:
                    format: uuid
                    description: An explicit ID.
                    type: string
                    example: 7d444840-9dc0-11d1-b245-5ffdce74fad2
                  parentId:
                    format: uuid
                    description: The ID of the parent context.
                    default: ""
                    type: string
                    example: 7d444840-9dc0-11d1-b245-5ffdce74fad2
                  isTemplate:
                    description: If the context is a template. Note that templates
                      cannot be used to load jobs.
                    default: false
                    type: boolean
                    example: true
                  isPool:
                    description: "If the context maintains a pool of executors. Execution\
                      \ contexts with a pool attach their executors on demand. Note,\
                      \ that this requires a special setup."
                    default: false
                    type: boolean
                    example: true
