  /deployments/{id}/execution:
    post:
      tags:
      - Deployments
      summary: "Creates a tempory job from a deployment, executes it, and immediately\
        \ discards the job created by the execution."
      description: "Calling this endpoint will create a temporary job from the provided\
        \ deployment and execute it with the input provided in the request body. The\
        \ call will wait until execution has finished. If the workflow contains a\
        \ report and the optional format query parameter is passed then the result\
        \ if this operation will be the rendered report. Otherwise the job's status\
        \ after execution is returned, including inline ouput values. It's not possible\
        \ to access external resources created by the job because they are associated\
        \ with the job and the job is discarded immediately after execution. By adding\
        \ `edge-compatible` to the `Prefer` header of the request you can ask the\
        \ service to return only the job's output values instead of all metadata."
      parameters:
      - name: id
        in: path
        description: The ID of the deployment.
        required: true
        schema:
          type: string
          example: rest:c151cdc8-b864-441f-9fce-a6e4a30afc0d
      - name: timeout
        in: query
        description: An optional timeout in milliseconds. In case the job is not loaded
          and fully executed within the provided timeout a respective response is
          returned. In case no timeout is provided the default timeout of the deployment
          is used.
        schema:
          format: int64
          default: -1
          type: integer
          example: 60000
      - name: reset
        in: query
        description: Set to true if the job should be reset prior to execution.
        schema:
          default: false
          type: boolean
          example: true
      - name: keepJob
        in: query
        description: Set to true if the job should be kept after execution and not
          get discarded immediately.
        schema:
          default: false
          type: boolean
          example: true
      - name: format
        in: query
        description: The requested report format.
        schema:
          default: PDF
          enum:
          - PDF
          - HTML
          - DOC
          - DOCX
          - XLS
          - PPT
          - PPTX
          - PS
          - ODT
          - ODS
