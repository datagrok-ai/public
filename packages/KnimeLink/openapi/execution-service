          value: workflowPath
          summary: sort by string value of workflow path in ascending order
        nonAscending:
          value: -workflowPath
          summary: sort by string value of workflow path in descending order
    PageQuery:
      name: page
      in: query
      description: The page number to be displayed.
      schema:
        type: integer
      example: 1
    CursorQuery:
      name: cursor
      in: query
      description: "The cursor for the next page. It is provided by the previous response,\
        \ you cannot construct it yourself."
      schema:
        type: string
      example: eyJzIjpbIi1uYW1lIl0sImx2IjpbInVzZXIxIl0sInEiOiJqb2JTdGF0ZT1MT0FESU5HIn0
    PagelenQuery:
      name: pagelen
