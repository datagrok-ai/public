    TimeInterval:
      type: object
      properties:
        start:
          format: time
          description: The start time of the interval. The time is provided as HH:mm:ss
            and ranges from 00:00:00 to 23:59:59.
          type: string
          example: 12:11:00
        end:
          format: time
          description: The end time of the interval. The time is provided as HH:mm:ss
            and ranges from 00:00:00 to 23:59:59.
          type: string
          example: 16:45:00
    SendMailAction:
      title: SendMail
      description: Action for sending emails.
      required:
      - recipients
      - type
      type: object
      properties:
        type:
          description: The action's type.
          enum:
          - SendMail
          type: string
        customName:
          description: The action's custom name.
          type: string
          example: Mail on Error
        onSuccess:
          description: If the mail should be sent after a successful execution.
          type: boolean
          example: true
        onFailure:
          description: If the mail should be sent after an unsuccessful execution.
          type: boolean
          example: false
        onInactivityDiscard:
          description: If the mail should be sent after a job has been discarded due
            to inactivity.
          type: boolean
          example: true
        appendNodeMessages:
          description: If the mail should contain the node messages.
          type: boolean
          example: true
        recipients:
          description: the recipients of the mail
          type: array
          items:
            type: string
            example: mail@<emailhost>.<org>
        reportFormats:
          description: The format of the report that shall be attached to the mail
            in case the workflow has a report; if empty no report will be generated.
          type: array
          items:
            enum:
            - PDF
            - HTML
            - DOC
            - DOCX
            - XLS
            - PPT
            - PPTX
            - PS
            - ODT
            - ODS
            - CSV
            type: string
            example: PDF
    SaveReportAction:
      title: SaveReport
      description: Action for saving reports on the server.
      required:
      - type
      - location
      - reportFormats
      - reportName
      type: object
      properties:
        type:
          description: The action's type.
          enum:
          - SaveReport
          type: string
        customName:
          description: The action's custom name.
          type: string
          example: Weekly Report
        location:
          description: The location on the hub where the report shall be stored.
          type: string
          example: '*spaceId'
        reportName:
          description: The name of the report.
          type: string
          example: Weekly Numbers
        reportFormats:
          description: The format of the report.
          type: array
          items:
            enum:
            - PDF
            - HTML
            - DOC
            - DOCX
            - XLS
            - PPT
            - PPTX
            - PS
            - ODT
            - ODS
            - CSV
            type: string
            example: PDF
        appendTimeStamp:
          description: If the timestamp shall be appended to the report; if set to
            false previous reports with the given name and location are overwritten.
          type: boolean
          example: true
    CallWorkflowAction:
      title: CallWorkflow
      description: Action for calling a workflow.
      required:
      - workflowUri
      - type
      type: object
      properties:
        type:
          description: The action's type.
          enum:
          - CallWorkflow
          type: string
        customName:
          description: The action's custom name.
          type: string
          example: Cleanup Action
        workflowUri:
          description: The ID or path of the workflow for which a job should be created.
          type: string
          example: '*workflow-id'
        onSuccess:
          description: If the workflow should be called after a successful execution.
          type: boolean
          example: true
        onFailure:
          description: If the workflow should be called after an unsuccessful execution.
          type: boolean
          example: true
        reset:
          description: If the workflow should be reset before execution.
          type: boolean
          example: false
        jobName:
          description: The custom job name.
          type: string
          example: Cleanup Job
        actions:
          description: The actions passed to the created job.
          type: array
          items:
            anyOf:
            - $ref: "#/components/schemas/SendMailAction"
            - $ref: "#/components/schemas/SaveReportAction"
            - $ref: "#/components/schemas/CallWorkflowAction"
        discardAfterSuccessfulExec:
          description: If the resulting job should be discarded after a successful
            execution.
          default: true
          type: boolean
          example: false
        discardAfterFailedExec:
          description: If the resulting job should be discarded after a failed execution.
          default: true
          type: boolean
          example: false
        workflowConfiguration:
          $ref: "#/components/schemas/WorkflowConfiguration"
    DiscardAfterExecutionAction:
      title: DiscardAfterExecution
      description: Action for discarding a job immediately after execution has finished.
      type: object
      properties:
        type:
          description: The action's type.
          enum:
          - DiscardAfterExecution
          type: string
        customName:
          description: The action's custom name.
          type: string
          example: Discard on Success
        onSuccess:
          description: If the job should be discarded immediately after a successful
            execution.
          default: false
          type: boolean
          example: true
        onFailure:
          description: If the job should be discarded immediately after an unsuccessful
            execution.
          default: false
          type: boolean
          example: false
    WorkflowConfiguration:
      description: The configuration that is applied when the job gets loaded. This
        is dependent on the configuration nodes used in the workflow. A template of
        the configuration can be accessed via a GET request to the configuration endpoint
        of the workflow _/repository/*workflowId:configuration_.
      type: object
      additionalProperties:
        enum:
        - null
        anyOf:
        - type: array
          items: {}
        - type: object
        - type: string
        - type: number
        - type: boolean
      example:
        integer-configuration: 33
        string-configuration: my config
    InputParameters:
      description: The input of the job. This is dependent on the input nodes used
        in the workflow. See _inputParameters_ of the job.
      type: object
      additionalProperties:
        enum:
        - null
        anyOf:
        - type: array
          items: {}
        - type: object
        - type: string
        - type: number
        - type: boolean
      example:
        integer-configuration: 33
        string-configuration: my config
    BaseDeployment:
      description: Base body to update a deployment.
      type: object
      properties:
        name:
          description: The name of the deployment.
          type: string
          example: My shared deployment
        runMode:
          description: "The run mode of the deployment. In ACCOUNT runMode, jobs created\
            \ from the deployment are run as the team itself, with team member permissions.\
            \ In INITIATOR runMode, jobs created are run as the initiator, or as the\
            \ creator of the deployment."
          enum:
          - ACCOUNT
          - INITIATOR
          type: string
          example: ACCOUNT
        configuration:
          $ref: "#/components/schemas/WorkflowConfiguration"
        actions:
          description: Actions that are triggered after the execution of a job has
            been finished.
          default: []
          type: array
          items:
            anyOf:
            - $ref: "#/components/schemas/SendMailAction"
            - $ref: "#/components/schemas/SaveReportAction"
            - $ref: "#/components/schemas/CallWorkflowAction"
            - $ref: "#/components/schemas/DiscardAfterExecutionAction"
        maxJobTimeInMemory:
          format: duration
          description: The maximum time an inactive job stays loaded in the executor.
            The value is formatted according to ISO 8601.
          type: string
          example: PT1H
        maxJobLifeTime:
          format: duration
          description: The maximum time of an inactive job before it gets deleted.
            The value is formatted according to ISO 8601.
          type: string
          example: P144H
        maxJobExecutionTime:
          format: duration
          description: The maximum execution time of a job. The value is formatted
            according to ISO 8601.
          type: string
          example: PT5H
        discardAfterMaxExecutionTime:
          description: If the job should be discarded after the maximum execution
            time has been reached.
          type: boolean
          example: false
        loadTimeout:
          format: duration
          description: The timeout when loading a job. The value is formatted according
            to ISO 8601.
          type: string
          example: PT10M
        asyncLoadTimeout:
          format: duration
          description: The timeout when loading a job asynchronously. The value is
            formatted according to ISO 8601.
          type: string
          example: PT10M
        executionTimeout:
          format: duration
          description: The timeout when executing a job synchronously. The value is
            formatted according to ISO 8601.
          type: string
          example: PT10M
        reportTimeout:
          format: duration
          description: The timeout when rendering a report. The value is formatted
            according to ISO 8601.
          type: string
          example: PT10M
        swapTimeout:
          format: duration
          description: The timeout when swapping a job. The value is formatted according
            to ISO 8601.
          type: string
          example: PT10M
        cpuRequirement:
          format: double
          description: The number of vCores reserved in the executor when loading
            a job.
          minimum: 0
          type: number
          example: 1.5
        ramRequirement:
          format: int64
          description: The bytes of memory reserved in the executor when loading a
            job.
          minimum: 0
          type: integer
          example: 365000000
        saveWorkflowSummary:
          description: If the workflow summary of the job should be saved when the
            job is swapped.
          type: boolean
          example: true
        updateLinkedComponents:
          description: If linked components should be updated when loading a job.
          type: boolean
          example: true
        enabled:
          description: "If the deployment is currently enabled, i.e. if it is possible\
            \ to create new jobs from it."
          type: boolean
          example: false
    DeploymentCreation:
      description: Base body to create a deployment.
      required:
      - name
      type: object
      allOf:
      - type: object
        properties:
          executionContext:
            format: UUID
            description: The the execution context of the deployment.
            type: string
            example: 59f63531-22b4-48f4-ab1f-30724d097bac
      - $ref: "#/components/schemas/BaseDeployment"
    Deployment:
      description: Information concerning a deployment.
      type: object
      allOf:
      - type: object
        properties:
          '@controls':
            description: A (possibly empty) map with all controls for this object.
            type: object
            additionalProperties:
              $ref: "#/components/schemas/Control"
          '@namespaces':
            description: A (possibly empty) map with the namespaces for this object.
            type: object
            additionalProperties:
              $ref: "#/components/schemas/Namespace"
          type:
            description: The deployment's type
            enum:
            - rest
            - schedule
            - data-app
            - trigger
            type: string
            example: rest
          creator:
            description: The creator of the deployment.
            type: string
            example: account:user:7fcb5934-b65f-42bf-a7c5-f5828ba56940
          creatorName:
            description: The username of the creator.
            type: string
            example: user123
          createdAt:
            format: date-time
            description: The date and time this deployment was created.
            type: string
            example: "2022-02-22T22:10:00.000281+01:00[Europe/Berlin]"
          modifiedAt:
            format: date-time
            description: The date and time this deployment was modified.
            type: string
            example: "2022-02-22T22:10:00.000281+01:00[Europe/Berlin]"
          scope:
            format: fully qualified identifier
            description: The scope under which the deployment exists.
            type: string
            example: account:team:7fcb5934-b65f-42bf-a7c5-f5828ba56940
          workflowPath:
            description: The path of the workflow that is executed.
            type: string
            example: /Users/userX/Public Space/workflowA
          workflowId:
            description: The ID of the workflow.
            type: string
            example: '*workflowId'
          description:
            description: A description for this deployment.
            type: string
            example: Data App to create monthly report.
          tags:
            description: A list of tags for this deployment.
            type: array
            items:
              type: string
            example:
            - finance
            - sales
          itemVersion:
            description: The item version of the workflow. If set to 'most-recent'
              the latest version will be used.
            type: string
          defaultProperties:
            description: Properties that are taken from the execution context.
            type: array
            items:
              enum:
              - maxJobTimeInMemory
              - maxJobLifeTime
              - maxJobExecutionTime
              - discardAfterMaxExecutionTime
              - loadTimeout
              - asyncLoadTimeout
              - executionTimeout
              - reportTimeout
              - swapTimeout
              - cpuRequirement
              - ramRequirement
              - saveWorkflowSummary
              - updateLinkedComponents
              - maxLoadedJobsPerExecutor
              - perJobLogging
              - maxFailures
              type: string
            example:
            - maxJobTimeInMemory
          overridableProperties:
            description: The properties that can be overridden.
            type: array
            items:
              enum:
              - maxJobTimeInMemory
              - maxJobLifeTime
              - maxJobExecutionTime
              - discardAfterMaxExecutionTime
              - loadTimeout
              - asyncLoadTimeout
              - executionTimeout
              - reportTimeout
              - swapTimeout
              - cpuRequirement
              - ramRequirement
              - saveWorkflowSummary
              - updateLinkedComponents
              - maxLoadedJobsPerExecutor
              - perJobLogging
              type: string
            example:
            - maxJobTimeInMemory
          readOnlyProperties:
            description: The properties that are fixed by the execution context.
            type: array
            items:
              enum:
              - maxJobTimeInMemory
              - maxJobLifeTime
              - maxJobExecutionTime
              - discardAfterMaxExecutionTime
              - loadTimeout
              - asyncLoadTimeout
              - executionTimeout
              - reportTimeout
              - swapTimeout
              - cpuRequirement
              - ramRequirement
              - saveWorkflowSummary
              - updateLinkedComponents
              - maxLoadedJobsPerExecutor
              - perJobLogging
              type: string
            example:
            - maxJobTimeInMemory
      - $ref: "#/components/schemas/DeploymentCreation"
    BaseScheduleDeployment:
      description: The schedule deployment update body.
      type: object
      allOf:
      - type: object
        properties:
          reset:
            description: If the job should be reset before execution.
            type: boolean
            example: true
          schedule:
            $ref: "#/components/schemas/BaseSchedule"
          executionRetries:
            format: int32
            description: The number of retries that should be attempted in case the
              execution couldn't be started or the execution of the job failed. Note
              that even if the schedule deployment's schedule is disabled that it
              could still spawn new jobs until all jobs finished executing.
            minimum: 0
            type: integer
            example: 2
          maxFailures:
            format: int32
            description: The maximum number of consecutive failures of jobs run by
              this schedule. If the number of failures exceeds this limit the deployment's
              schedule gets disabled.
            minimum: 0
            type: integer
            example: 3
      - $ref: "#/components/schemas/BaseDeployment"
    ScheduleDeploymentCreation:
      description: The schedule deployment creation body.
      required:
      - schedule
      type: object
      allOf:
      - $ref: "#/components/schemas/DeploymentCreation"
      - $ref: "#/components/schemas/BaseScheduleDeployment"
    ScheduleDeployment:
      description: The schedule deployment.
      type: object
      allOf:
      - $ref: "#/components/schemas/Deployment"
      - $ref: "#/components/schemas/ScheduleDeploymentCreation"
      - type: object
        properties:
          id:
            description: The unique ID of the deployment.
            type: string
            example: schedule:a885bb42-d808-4557-9a7f-9f10c5777739
          creator:
            description: The creator of this deployment.
            type: string
            example: account:user:9a2c1ce1-cdc4-46f0-93dc-4bfa0aad2ae0
          targetName:
            description: The custom name a job should get. Note that a timestamp will
              be added to its name.
            type: string
            example: My Weekly Reports
          numFailures:
            format: int32
            description: The number of consecutive failures of jobs run by this schedule.
              This is used to disable the schedule if a defined number of maximum
              failures occurred.
            minimum: 0
            type: integer
            example: 4
          lastRun:
            format: date-time
            description: The last time a job was run.
            type: string
            example: "2022-02-25T09:10:00.001646+01:00[Europe/Berlin]"
          lastJob:
            format: uuid
            description: The last job that was run.
            type: string
            example: c151cdc8-b864-441f-9fce-a6e4a30afc0d
          schedule:
            $ref: "#/components/schemas/Schedule"
    DataAppDeployment:
      description: The data app deployment.
