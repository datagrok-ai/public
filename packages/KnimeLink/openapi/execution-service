  /deployments/{id}/jobs:
    post:
      tags:
      - Deployments
      summary: Creates a new job from the deployment.
      description: "Creates a new job from the deployment using its execution context,\
        \ post execution actions, and configuration. Optionally you can set input\
        \ parameters by sending certain query parameters. You have to take the input\
        \ parameter name as defined in the workflow - prefixed it with `pm:` - as\
        \ the query parameter name. The value of the query parameter is the value\
        \ of the corresponding input parameter to the job. For example, if you want\
        \ to set the input parameter _foo-1_ to _bar_ you append `pm:foo-1=bar` as\
        \ a query parameter."
      parameters:
      - name: id
        in: path
        description: The ID of the deployment.
        required: true
        schema:
          type: string
          example: rest:c151cdc8-b864-441f-9fce-a6e4a30afc0d
      - name: timeout
        in: query
        description: An optional load timeout in milliseconds. In case the job is
          not loaded within the provided timeout a respective response is returned.
          In case no timeout is provided the timeout of the deployment is used.
        schema:
          format: int64
          default: -1
          type: integer
          example: 60000
      - name: asyncLoading
        in: query
        description: "An optional flag to load the job asynchronously, i.e. the service\
          \ returns directly after sending a load message to the message broker. The\
          \ state of a job that has not been loaded yet is LOADING. This flag can\
          \ not be set to true if resetBeforeExecution is also set to true."
        schema:
          default: false
          type: boolean
          example: true
      - name: resetBeforeExecution
        in: query
        description: An optional flag to reset the job after it has been loaded.  If
          this flag is set the job will be loaded as usual and then immediatly reset.
          This flag can not be set to true if asyncLoading is also set to true.
        schema:
          default: false
          type: boolean
          example: true
      - $ref: "#/components/parameters/JobCreatedByHeader"
      - $ref: "#/components/parameters/PreferHeader"
      responses:
        "201":
          description: The created job
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/WorkflowJob"
            application/json:
              schema:
                $ref: "#/components/schemas/WorkflowJob"
        "403":
          description: The calling user does not have the rights to create a job from
            the deployment.
        "422":
          description: The provided deployment ID is invalid.
        "500":
          description: An internal error occurred.
        "504":
          description: The job was not loaded within time.
