        endTime:
          format: date-time
          description: "The end time of the schedule, i.e. the last time a job should\
            \ be executed."
          type: string
          example: "2022-02-14T20:10+01:00[Europe/Berlin]"
        disabled:
          description: "If the deployment's schedule is currently disabled, i.e. if\
            \ executions will be set out. Deprecated: Please use the 'enabled' flag\
            \ of the deployment."
          type: boolean
          example: false
