        \ By default the response contains full Mason information, i.e. both the possible\
        \ actions and their corresponding hyperlinks. If you pass `representation=minimal`\
        \ no Mason controls will be sent. If you pass `representation=basic` only\
        \ the possible actions without any hyperlinks and description will be sent."
      schema:
        enum:
        - representation=minimal
        - representation=basic
        type: string
    AccountFilterQuery:
      name: q
      in: query
      description: |
        An optional filter to only show the accounts that match the filter. Only a single attribute can be used for filtering right now. Available attributes are:
          - `team` : ID of a team in which the returned users must be members; only applies to searching user accounts
          - `member` : ID of a user which must be a member of the returned teams; only applies to searching team accounts
      schema:
        type: string
      examples:
        team:
          value: account:team:4009d85f-236a-420b-84fe-8ef273f2c2a8
          summary: filter users by membership in the provided team
        member:
          value: account:user:2a33bfef-ce10-4abf-a1bf-99c4cb44ff03
          summary: filter team by user which must be a member
    AccountSortQuery:
      name: sort
      in: query
      description: |
        An optional parameter for sorting. By default results are sorted in ascending order. If you prefix the attribute with `-` the sort order is descending. You can provide multiple attributes separated by commas. The default sorting is `id`. Available attributes for sorting are:
          - `id` : the ID of the accounts
          - `name` : the name of the accounts
          - `email`: the e-mail of the accounts; only applies to user accounts
          - `creationDate`: the timestamp when the account was created
          - `lastModificationDate`: the timestamp when the account was last modified
      schema:
        enum:
        - id
        - -id
        - name
        - -name
        - email
        - -email
        - creationDate
        - -creationDate
        - lastModificationDate
        - -lastModificationDate
        type: string
      examples:
        nonDescending:
          value: name
          summary: sort by account name in ascending order
        nonAscending:
          value: "-creationDate,name"
          summary: sort by creation timestamp in descending order and then by name
            in ascending order
    PageQuery:
      name: page
      in: query
      description: The page number to be displayed.
      schema:
        type: integer
      example: 1
    CursorQuery:
      name: cursor
      in: query
      description: "The cursor for the next page. It is provided by the previous response,\
        \ you cannot construct it yourself."
      schema:
        type: string
      example: eyJzIjpbIi1uYW1lIl0sImx2IjpbInVzZXIxIl0sInEiOiJqb2JTdGF0ZT1MT0FESU5HIn0
    PagelenQuery:
      name: pagelen
      in: query
      description: "Number of accounts to be displayed on a single page. An optional\
        \ parameter, if not provided a default value (usually 100) will be used. Note\
        \ that there is a limit on the page length (usually 100). In addition the\
        \ actual response may contain less items than requested."
      schema:
        maximum: 100
        minimum: 1
        type: integer
      example: 20
  securitySchemes:
    SecurityScheme:
      type: http
      scheme: bearer
      bearerFormat: JWT
      description: Authentication
