---
openapi: 3.0.3
info:
  title: KNIME Hub Account Service REST API
  description: RESTful services for the KNIME Hub account service.
  contact:
    name: KNIME Support
    url: http://www.knime.com
    email: support@knime.com
  version: v1
servers:
- url: /
  description: KNIME Hub
tags:
- name: Accounts
  description: Requests relating to accounts.
- name: Passwords
  description: Requests relating to application passwords
- name: SCIM
  description: Requests relating to the System for Cross-domain Identity Management
    (SCIM).
- name: Limits
  description: Requests related to limits.
- name: Permissions
  description: Requests related to permissions.
paths:
  /accounts:
    post:
      tags:
      - Accounts
      summary: Creates a new account.
      description: "Creates a new account. Currently it's only possible to create\
        \ team accounts. If no team name is supplied, it will be generated in the\
        \  style of 'MyUser's Team', with a rolling index if that name is  already\
        \ taken."
      parameters:
      - $ref: "#/components/parameters/PreferHeader"
      requestBody:
        description: An account.
        content:
          application/json:
            schema:
              required:
              - creator
              allOf:
              - type: object
                properties:
                  creator:
                    description: The id of the team account creator
                    type: string
                    example: account:user:a885bb42-d808-4557-9a7f-9f10c5777739
              - $ref: "#/components/schemas/UpdateTeamAccount"
      responses:
        "201":
          description: The created account.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/TeamAccount"
            application/json:
              schema:
                $ref: "#/components/schemas/TeamAccount"
        "403":
          description: The calling user does not have the rights to create an account.
        "404":
          description: The calling account cannot be found in the identity provider.
        "422":
          description: The provided account information is invalid.
        "500":
          description: An internal error occurred.
    get:
      tags:
      - Accounts
      summary: List all existing user or team accounts.
      description: "Allows you to list all existing user and team accounts. This functionality\
        \ is only available to super admins and internal service accounts. If called\
        \ without the `page` parameter, cursor-based pagination will be used. It is\
        \ much faster than page-based pagination and should be preferred. The Mason\
        \ controls and the `pagination` property contain the cursor information for\
        \ the next page."
      parameters:
      - name: type
        in: query
        description: "The requested account type, either team or user."
        required: true
        schema:
          default: team
          enum:
          - team
          - user
          type: string
          example: user
      - $ref: "#/components/parameters/AccountFilterQuery"
      - $ref: "#/components/parameters/AccountSortQuery"
      - $ref: "#/components/parameters/PageQuery"
      - $ref: "#/components/parameters/CursorQuery"
      - $ref: "#/components/parameters/PagelenQuery"
      - $ref: "#/components/parameters/PreferHeader"
      responses:
        "200":
          description: A list of accounts.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/AccountList"
        "400":
          description: The requested account type is unknown
        "403":
          description: The calling user does not have the rights to create an account.
        "500":
          description: An internal error occurred.
  /accounts/{id}:
    get:
      tags:
      - Accounts
      summary: Returns the information of the account.
      description: "Returns the information of the account, such as name, avatar URL\
        \ etc."
      parameters:
      - name: id
        in: path
        description: The account's ID.
        required: true
        schema:
          type: string
          example: account:team:c151cdc8-b864-441f-9fce-a6e4a30afc0d
      - $ref: "#/components/parameters/PreferHeader"
      responses:
        "200":
          description: The account information.
          content:
            application/vnd.mason+json:
              schema:
                anyOf:
                - $ref: "#/components/schemas/TeamAccount"
                - $ref: "#/components/schemas/UserAccount"
                - $ref: "#/components/schemas/ApplicationPassword"
            application/json:
              schema:
                anyOf:
                - $ref: "#/components/schemas/TeamAccount"
                - $ref: "#/components/schemas/UserAccount"
                - $ref: "#/components/schemas/ApplicationPassword"
        "400":
          description: The caller is not a valid user.
        "403":
          description: The calling user does not have the rights to retrieve the information.
        "404":
          description: The account is unknown.
        "500":
          description: An internal error occurred.
    put:
      tags:
      - Accounts
      summary: Updates an account
      description: "Updates an account, such as email and description for users or\
        \ description and name for teams."
      requestBody:
        description: An account.
        content:
          application/json:
            schema:
              anyOf:
              - $ref: "#/components/schemas/UpdateTeamAccount"
              - $ref: "#/components/schemas/UpdateUserAccount"
      parameters:
      - name: id
        in: path
        description: The account's ID.
        required: true
        schema:
          type: string
          example: account:team:c151cdc8-b864-441f-9fce-a6e4a30afc0d
      - $ref: "#/components/parameters/PreferHeader"
      responses:
        "200":
          description: The updated account information.
          content:
            application/vnd.mason+json:
              schema:
                anyOf:
                - $ref: "#/components/schemas/TeamAccount"
                - $ref: "#/components/schemas/UserAccount"
            application/json:
              schema:
                anyOf:
                - $ref: "#/components/schemas/TeamAccount"
                - $ref: "#/components/schemas/UserAccount"
        "400":
          description: The caller is not a valid user.
        "403":
          description: The calling user does not have the rights to update the account
            metadata.
        "404":
          description: The account is unknown.
        "500":
          description: An internal error occurred.
    delete:
      tags:
      - Accounts
      summary: Deletes an account.
      description: Deletes the account and all related information like groups.
      parameters:
      - name: id
        in: path
        description: The account's ID.
        required: true
        schema:
          type: string
          example: account:team:c151cdc8-b864-441f-9fce-a6e4a30afc0d
      responses:
        "204":
          description: The account has been deleted.
        "403":
          description: The calling user does not have the rights to delete the account.
        "404":
          description: The account is unknown.
        "500":
          description: An internal error occurred.
  /accounts/hub:global:
    get:
      tags:
      - Accounts
      summary: "Returns information about this KNIME Hub installation, including global\
        \ groups."
      description: Returns information about this KNIME Hub installation such as the
        enabled features or global groups (both external and internal).
      responses:
        "200":
          description: The KNIME Hub information.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/HubInstallationAccount"
  /accounts/identity:
    get:
      tags:
      - Accounts
      summary: Returns the information of the account doing the request.
      description: "Returns the information of the account doing the request, such\
        \ as name, avatar URL etc."
      parameters:
      - $ref: "#/components/parameters/PreferHeader"
      - name: include
        in: query
        description: "A list of field names to be additionally included in the response,\
          \ currently only \"managedProperties\" is supported. Unsupported values\
          \ are ignored."
        required: false
      responses:
        "200":
          description: The account information.
          content:
            application/vnd.mason+json:
              schema:
                anyOf:
                - $ref: "#/components/schemas/UserAccount"
                - $ref: "#/components/schemas/ServiceAccount"
                - $ref: "#/components/schemas/ApplicationPassword"
                - $ref: "#/components/schemas/UserAccountWithManagedProperties"
            application/json:
              schema:
                anyOf:
                - $ref: "#/components/schemas/UserAccount"
                - $ref: "#/components/schemas/ServiceAccount"
                - $ref: "#/components/schemas/ApplicationPassword"
        "400":
          description: The caller is not a valid user.
        "403":
          description: The calling user does not have the rights to retrieve the information.
        "404":
          description: The account is unknown.
        "500":
          description: An internal error occurred.
  /accounts/identity/identifiers:
    get:
      tags:
      - Accounts
      summary: Returns the identifiers of the account doing the request.
      description: "Returns the identifiers of the account doing the request, used\
        \ for permission checks."
      responses:
        "200":
          description: The identifiers.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/IdentifierResponse"
        "400":
          description: The caller is not a valid user.
        "403":
          description: The calling user does not have the rights to retrieve the information.
        "404":
          description: The account is unknown.
        "500":
          description: An internal error occurred.
  /accounts/identity/properties:
    get:
      tags:
      - Accounts
      - Properties
      summary: Gets all properties attached to the user account making the request.
      description: Returns all properties that are known for the account. The response
        is a JSON object with the keys at the root being the property keys and their
        values being the corresponding property values. If there are no properties
        yet an empty object will be returned.
      responses:
        "200":
          description: All properties for the account.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/AnyValue"
              example: "{\"string\": \"value\", \"object\": { \"foo\": 42 }}"
        "404":
          description: The account is unknown.
        "500":
          description: An internal error occurred.
    delete:
      tags:
      - Accounts
      - Properties
      summary: Deletes all properties attached to the user account making the request.
      responses:
        "204":
          description: All properties were successfully deleted.
        "404":
          description: The account is unknown.
        "500":
          description: An internal error occurred.
  /accounts/identity/properties/{key}:
    get:
      tags:
      - Accounts
      - Properties
      summary: Gets the account property with the provided key.
      description: Returns a single property for the account. The response is the
        property value which can be an arbitrary JSON value.
      parameters:
      - name: key
        in: path
        description: The property key.
        required: true
        schema:
          type: string
          example: property-name
      responses:
        "200":
          description: A single property for the account.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/AnyValue"
              examples:
                object:
                  value: "{ \"this-is-the-value\": 42 }"
                array:
                  value: "[ \"foo\", \"bar\" ]"
                string:
                  value: '"foo"'
                number:
                  value: "42"
        "404":
          description: The account or the property is unknown.
        "500":
          description: An internal error occurred.
    put:
      tags:
      - Accounts
      - Properties
      summary: Create or updates the account property with the provided key.
      description: Creates or updates a single property for the account. The request
        body must contain the property as an arbitrary JSON value. Note that there
        is a size limit for both the key and the value.
      parameters:
      - name: key
        in: path
        description: The property key.
        required: true
        schema:
          type: string
          example: property-name
      requestBody:
        description: An arbitrary JSON value.
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/AnyValue"
      responses:
        "200":
          description: The property has been successfully created or updated.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/AnyValue"
        "404":
          description: The account or the property is unknown.
        "413":
          description: The size limit for either the key or the value has been exceeded.
        "500":
          description: An internal error occurred.
    delete:
      tags:
      - Accounts
      - Properties
      summary: Deletes the account property with the provided key.
      description: Deletes a single property for the account.
      parameters:
      - name: key
        in: path
        description: The property key.
        required: true
        schema:
          type: string
          example: property-name
      responses:
        "204":
          description: The property was successfully deleted.
        "404":
          description: The account or the property is unknown.
        "500":
          description: An internal error occurred.
  /accounts/name/{name}:
    get:
      tags:
      - Accounts
      summary: Returns the information of the account.
      description: "Returns the information of the account, such as name, avatar URL\
        \ etc."
      parameters:
      - name: name
        in: path
        description: The account's name.
        required: true
        schema:
          type: string
          example: MyTeam
      - $ref: "#/components/parameters/PreferHeader"
      responses:
        "200":
          description: The account information.
          content:
            application/vnd.mason+json:
              schema:
                anyOf:
                - $ref: "#/components/schemas/TeamAccount"
                - $ref: "#/components/schemas/UserAccount"
            application/json:
              schema:
                anyOf:
                - $ref: "#/components/schemas/TeamAccount"
                - $ref: "#/components/schemas/UserAccount"
        "400":
          description: The caller is not a valid user.
        "403":
          description: The calling user does not have the rights to retrieve the information.
        "404":
          description: The account is unknown.
        "500":
          description: An internal error occurred.
  /accounts/hub:global/groups/{name}:
    put:
      tags:
      - Groups
      summary: Creates or modifies a global group.
      description: Creates a new group if it does not exist. Updates the group information
        otherwise.
      parameters:
      - name: name
        in: path
        description: The name of the group. In case of an externally managed group
          it must match the group name in the external identity provider.
        required: true
        schema:
          type: string
          example: MyGroup
      - $ref: "#/components/parameters/PreferHeader"
      requestBody:
        description: Information about the group.
        content:
          application/json:
            schema:
              type: object
              properties:
                displayName:
                  description: An arbitrary display name for the group.
                  type: string
                  example: My Fäncy Speciäl Gröup Näme
                external:
                  description: "Whether this group is an external group, i.e. membership\
                    \ is provided externally through JWT properties."
                  default: false
                  type: boolean
      responses:
        "200":
          description: The updated group in case it already existed.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/Group"
            application/json:
              schema:
                $ref: "#/components/schemas/Group"
        "201":
          description: The created group.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/Group"
            application/json:
              schema:
                $ref: "#/components/schemas/Group"
        "403":
          description: The calling user does not have the rights to create a group.
        "422":
          description: The requested group name is invalid.
        "500":
          description: An internal error occurred.
    delete:
      tags:
      - Groups
      summary: Deletes a global group.
      description: Deletes the global group.
      parameters:
      - name: name
        in: path
        description: The name of the group to delete.
        required: true
        schema:
          type: string
          example: MyGroup
      responses:
        "204":
          description: The group has been deleted.
        "403":
          description: The calling user does not have the rights to delete the group.
        "404":
          description: The group is unknown.
        "500":
          description: An internal error occurred.
    get:
      tags:
      - Groups
      summary: Retrieves information about this global group.
      parameters:
      - name: name
        in: path
        description: The name of the group.
        required: true
        schema:
          type: string
          example: MyGroup
      - $ref: "#/components/parameters/PreferHeader"
      responses:
        "200":
          description: The group information.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/Group"
            application/json:
              schema:
                $ref: "#/components/schemas/Group"
        "404":
          description: The group is unknown.
        "500":
          description: An internal error occurred.
  /accounts/hub:global/groups/{name}/members:
    post:
      tags:
      - Groups
      summary: Adds members to an existing global group
      description: "Sending this requests with a list of user account IDs and/or group\
        \ IDs in the request body lets you add members to a global group. If a user\
        \ account or group in the list does not exist, the whole request will fail.\
        \ I.e. either all members/groups are added or none. User accounts or groups\
        \ that are already group members will be silently ignored. In order to add\
        \ group members the caller must have appropriate permissions."
      parameters:
      - name: name
        in: path
        description: The name of the group.
        required: true
        schema:
          type: string
          example: MyGroup
      - $ref: "#/components/parameters/PreferHeader"
      requestBody:
        description: The users and/or groups that should be added to this group.
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/GroupMembershipChangeList"
      responses:
        "200":
          description: The group information.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/Group"
            application/json:
              schema:
                $ref: "#/components/schemas/Group"
        "400":
          description: If not all required information has been provided in the request.
        "403":
          description: The calling user does not have the rights to add members to
            the group.
        "404":
          description: The group does not exist.
        "500":
          description: An internal error occurred.
    delete:
      tags:
      - Groups
      summary: Removes members from an existing global group
      description: Sending this requests with a list of user account IDs and/or group
        IDs in the request body lets you remove members from a global group. User
        accounts or groups that are not group members will be silently ignored. In
        order to remove group members the caller must have appropriate permissions.
      parameters:
      - name: name
        in: path
        description: The name of the group.
        required: true
        schema:
          type: string
          example: MyGroup
      requestBody:
        description: The users and/or groups that should be removed from this group.
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/GroupMembershipChangeList"
      responses:
        "200":
          description: The group information.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/Group"
            application/json:
              schema:
                $ref: "#/components/schemas/Group"
        "400":
          description: If not all required information has been provided in the request.
        "403":
          description: The calling user does not have the rights to remove members
            from the group.
        "404":
          description: The group does not exist.
        "500":
          description: An internal error occurred.
  /accounts/{id}/groups/{name}:
    put:
      tags:
      - Groups
      summary: Creates a new group in a team account.
      description: Creates a new group if it does not exist. Updates the group information
        otherwise.
      parameters:
      - name: id
        in: path
        description: The account's ID. Must be a team account.
        required: true
        schema:
          type: string
          example: account:team:c151cdc8-b864-441f-9fce-a6e4a30afc0d
      - name: name
        in: path
        description: The name of the group.
        required: true
        schema:
          type: string
          example: MyGroup
      - $ref: "#/components/parameters/PreferHeader"
      requestBody:
        description: "Optionally a display name. If no display name is supplied, the\
          \ group name is used instead."
        content:
          application/json:
            schema:
              description: The group's changed values.
              type: object
              properties:
                displayName:
                  type: string
                  example: My Fäncy Speciäl Gröup Näme
      responses:
        "200":
          description: The updated group.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/Group"
            application/json:
              schema:
                $ref: "#/components/schemas/Group"
        "201":
          description: The created group.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/Group"
            application/json:
              schema:
                $ref: "#/components/schemas/Group"
        "403":
          description: The calling user does not have the rights to create a group.
        "404":
          description: The account or group is unknown.
        "422":
          description: The account id does not reference a team account or the account
            id or  provided group information is invalid.
        "500":
          description: An internal error occurred.
    delete:
      tags:
      - Groups
      summary: Deletes a group from an account.
      description: Deletes the group and all related information like its members.
      parameters:
      - name: id
        in: path
        description: The account's ID. Must be a team account.
        required: true
        schema:
          type: string
          example: account:team:c151cdc8-b864-441f-9fce-a6e4a30afc0d
      - name: name
        in: path
        description: The name of the group to delete.
        required: true
        schema:
          type: string
          example: MyGroup
      responses:
        "204":
          description: The group has been deleted.
        "403":
          description: The calling user does not have the rights to delete the group.
        "404":
          description: The account or group is unknown.
        "422":
          description: The account id does not reference a team account or is invalid.
        "500":
          description: An internal error occurred.
    get:
      tags:
      - Groups
      summary: Retrieves the members of the group.
      description: Retrieves the members of the group.
      parameters:
      - name: id
        in: path
        description: The account's ID. Must be a team account.
        required: true
        schema:
          type: string
          example: account:team:c151cdc8-b864-441f-9fce-a6e4a30afc0d
      - name: name
        in: path
        description: The name of the group.
        required: true
        schema:
          type: string
          example: MyGroup
      - $ref: "#/components/parameters/PreferHeader"
      responses:
        "200":
          description: The group members.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/Group"
            application/json:
              schema:
                $ref: "#/components/schemas/Group"
        "403":
          description: The calling user does not have the rights to view the members.
        "404":
          description: The account or group is unknown.
        "422":
          description: The account id does not reference a team account or the account
            id or  provided group information is invalid.
        "500":
          description: An internal error occurred.
  /accounts/{id}/groups/{name}/members:
    post:
      tags:
      - Groups
      summary: Adds members to an existing group of an account
      description: "Sending this requests with a list of user account IDs and/or a\
        \ list of group IDs in the request body lets you add members to a group of\
        \ a team. If a user account or group in the list does not exist, or a user\
        \ is not a member of the team, the whole request will fail. I.e. either all\
        \ members/groups are added or none. User accounts or groups that are already\
        \ group members will be silently ignored. In order to add group members the\
        \ caller must have appropriate permissions for the team account."
      parameters:
      - name: id
        in: path
        description: The account's ID. Must be a team account.
        required: true
        schema:
          type: string
          example: account:team:c151cdc8-b864-441f-9fce-a6e4a30afc0d
      - name: name
        in: path
        description: The name of the group.
        required: true
        schema:
          type: string
          example: MyGroup
      - $ref: "#/components/parameters/PreferHeader"
      requestBody:
        description: The users and/or groups that should be added to this group.
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/GroupMembershipChangeList"
      responses:
        "200":
          description: The group information.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/Group"
            application/json:
              schema:
                $ref: "#/components/schemas/Group"
        "400":
          description: If not all required information has been provided in the request.
        "403":
          description: The calling user does not have the rights to add members to
            the group of the team.
        "404":
          description: The team or the group does not exist.
        "500":
          description: An internal error occurred.
    delete:
      tags:
      - Groups
      summary: Removes members from an existing group of an account
      description: Sending this requests with a list of user account IDs in the request
        body lets you remove members from a group of a team. User accounts or groups
        that are not group members will be silently ignored. In order to remove group
        members the caller must have appropriate permissions.
      parameters:
      - name: id
        in: path
        description: The account's ID. Must be a team account.
        required: true
        schema:
          type: string
          example: account:team:c151cdc8-b864-441f-9fce-a6e4a30afc0d
      - name: name
        in: path
        description: The name of the group.
        required: true
        schema:
          type: string
          example: MyGroup
      requestBody:
        description: The users and/or groups that should be added to this group.
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/GroupMembershipChangeList"
      responses:
        "200":
          description: The group information.
          content:
            application/vnd.mason+json:
              schema:
                $ref: "#/components/schemas/Group"
            application/json:
              schema:
