          description: The feature's symbolic name.
          type: string
          example: org.knime.features.js.views
        featureOwner:
          description: "the owner of this feature, this field is missing for features/extensions\
            \ which are not part of the hub's extension catalog"
          type: string
          example: knime
        featureTrusted:
          description: "if the feature is trusted or not, this field is missing for\
            \ features/extensions which are not part of the hub's extension catalog"
          type: boolean
        featureLatestVersion:
          description: "the latest version of this feature on the hub, this field\
            \ is missing for features/extensions which are not part of the hub's extension\
            \ catalog"
          pattern: ^\d+\.\d+\.\d+(?:\..+)?$
          type: string
          example: 4.0.0.v201906060925
        featureId:
          description: "the unique ID of this feature on the hub, this field is missing\
            \ for features/extensions which are not part of the hub's extension catalog"
          pattern: "^\\*[0-9a-zA-Z_\\-]{16}$"
          type: string
          example: '*J7ZpUxHXjbIEQBMF'
    AggregatedComponentInstance:
