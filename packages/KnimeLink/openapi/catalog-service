                $ref: "#/components/schemas/DetailedWorkflow"
            application/json; profile=knime.com/cloud.repository.component.detailed.v20190725:
              schema:
                $ref: "#/components/schemas/DetailedComponent"
        "404":
          description: This error is returned if either the parent workflow group
            of the target location doesn't exist or in case of a server-side copy/move
            operation if the source location doesn't exist.
        "400":
          description: This error is returned if for example an item already exists
            at the target location but doesn't have the same type as the source item
            (either for an upload or a server-side copy/move operation)
        "401":
          description: Response if the request is unauthenticated
        "403":
          description: Response if the requester does not have permission to upload
            to the given location
  /repository/{id}/copies:
    post:
      tags:
      - Repository
      summary: Copies a repository item.
      operationId: copy
      parameters:
      - $ref: "#/components/parameters/PreferHeader"
      - name: id
        in: path
        description: The ID of the repository item to copy.
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
        example: '*YK_q3iKGm3WUlAzo'
      requestBody:
        description: "The path where to create the copy, and whether to force the\
          \ copy, i.e. overwrite existing items."
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CopyRequestBody"
      responses:
        "200":
          description: "The copy was successfully created, overwriting an existing\
            \ item at the path."
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/RepositoryItem"
            application/json; profile=knime.com/cloud.repository.workflow.simple.v20190220:
              schema:
                $ref: "#/components/schemas/SimpleWorkflow"
            application/json; profile=knime.com/cloud.repository.component.simple.v20190725:
              schema:
                $ref: "#/components/schemas/SimpleComponent"
            application/json; profile=knime.com/cloud.repository.workflow.detailed.v20190725:
              schema:
                $ref: "#/components/schemas/DetailedWorkflow"
            application/json; profile=knime.com/cloud.repository.component.detailed.v20190725:
              schema:
                $ref: "#/components/schemas/DetailedComponent"
        "201":
          description: "The copy was successfully created, without overwriting an\
            \ existing item at the path. The `Location` header contains a link to\
            \ it."
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/RepositoryItem"
            application/json; profile=knime.com/cloud.repository.workflow.simple.v20190220:
              schema:
                $ref: "#/components/schemas/SimpleWorkflow"
            application/json; profile=knime.com/cloud.repository.component.simple.v20190725:
              schema:
                $ref: "#/components/schemas/SimpleComponent"
            application/json; profile=knime.com/cloud.repository.workflow.detailed.v20190725:
              schema:
                $ref: "#/components/schemas/DetailedWorkflow"
            application/json; profile=knime.com/cloud.repository.component.detailed.v20190725:
              schema:
                $ref: "#/components/schemas/DetailedComponent"
        "400":
          description: |-
            Response if
              - The item to copy or the specified path for the copy are above the space level
              - The specified path is the same as the path of the item to copy
              - The copy would overwrite an existing item that has a different type
              - The designated parent at the specified path is not a workflow group or space
              - Trying to copy a file larger than the allowed file size (5 GiB)
              - Trying to copy an item into one of its descendants
              - Trying to copy the trash bin or to/from it
              - Trying to copy to a non-canonical path
              - Trying to copy a space to a non-space level
              - Trying to copy a non-space item to the space level
              - `force=false` and `If-Target-Match` is provided — always rejected.
        "401":
          description: Response if the request is unauthenticated.
        "403":
          description: Response if the requester does not have permission to copy
            the item.
        "404":
          description: Response if the item with the given ID or the designated parent
            at the specified path do not exist.
        "409":
          description: Response if there is an existing item that would be overwritten
            and copy is not forced.
        "412":
          description: |-
            Response if
              - The current Etag of the target item does not match the provide Etag
              - The request includes `If-None-Match` and the source item *does* exist with a matching ETag.
              - The request includes `If-Match` and the source item does *not* exist or its ETag does not match.
  /repository/{id}/path:
    put:
      tags:
      - Repository
      summary: Moves or renames a repository item.
      operationId: moveOrRename
      parameters:
      - $ref: "#/components/parameters/PreferHeader"
      - name: id
        in: path
        description: The ID of the repository item to move or rename.
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
        example: '*YK_q3iKGm3WUlAzo'
      requestBody:
        description: "The new path for the repository item, and whether to force the\
          \ move or rename, i.e. overwrite existing items."
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/MoveRenameRequestBody"
      responses:
        "200":
          description: The repository item was successfully moved or renamed. Returns
            the moved item.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/RepositoryItem"
            application/json; profile=knime.com/cloud.repository.workflow.detailed.v20190220:
              schema:
                $ref: "#/components/schemas/DetailedWorkflow"
            application/json; profile=knime.com/cloud.repository.component.detailed.v20190725:
              schema:
                $ref: "#/components/schemas/DetailedComponent"
        "400":
          description: |-
            Response if
              - The item to move or rename or the specified new path is at or above the space level
              - The new path is the same as the current path of the repository item
              - The move or rename would overwrite an existing item that has a different type than the item overwriting
                it
              - The designated parent at the new path is not a workflow group or space
              - Trying to move an item into one of its descendants
              - Trying to move the trash bin or to/from it
              - `force=false` and `If-Target-Match` is provided — always rejected.
        "401":
          description: Response if the request is unauthenticated.
        "403":
          description: Response if the requester does not have permission to move
            or rename the item.
        "404":
          description: Response if the item with the given ID or the designated parent
            at the new path do not exist.
        "409":
          description: Response if there is an existing item that would be overwritten
            and the move or rename is not forced.
        "412":
          description: |-
            Response if
              - The current Etag of the target item does not match the provide Etag
              - The request includes `If-None-Match` and the source item *does* exist with a matching ETag.
              - The request includes `If-Match` and the source item does *not* exist or its ETag does not match.
  /repository/{id}/versions:
    get:
      tags:
      - Repository
      summary: List all versions for a certain repository item.
      operationId: getItemVersionsByItemId
      parameters:
      - name: id
        in: path
        description: The repository item or its unique ID which always starts with
          a *.
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
        examples:
          id:
            value: '*YK_q3iKGm3WUlAzo'
      - name: limit
        in: query
        description: Maximum number of versions returned in the response. All versions
          will be returned by using -1.
        required: false
        schema:
          default: 10
          type: integer
      responses:
        "200":
          description: Returns a list with all item versions for the requested item.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/NamedItemVersionList"
        "400":
          description: Response if given knime ID targets a non leaf item.
        "401":
          description: Response if the user is not authorized.
        "403":
          description: Response if the logged in user is not permitted to read the
            item.
        "404":
          description: Response if no item with the specified ID or path exists.
    post:
      tags:
      - Repository
      summary: Creates a new version for the repository item with the given ID.
      operationId: createItemVersion
      parameters:
      - name: id
        in: path
        description: The unique ID of the repository item for which to create the
          version.
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
        example: '*YK_q3iKGm3WUlAzo'
      requestBody:
        description: The title and optional description of the version to be created.
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateNamedItemVersionRequestBody"
      responses:
        "201":
          description: Item version was successfully created. Returns metadata about
            the created version.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/NamedItemVersion"
        "400":
          description: |-
            One of:
              - Request body does not specify a title
              - Repository item is not a component, workflow, or data item
              - Repository item does not have any unversioned changes
        "401":
          description: User is not authorized.
        "403":
          description: User does not have permission to create a version for the given
            repository item.
        "404":
          description: The repository item with the given ID does not exist.
  /repository/{id}/versions/{versionNumber}:
    delete:
      tags:
      - Repository
      summary: Deletes the specified repository item at the given version
      operationId: deleteItemVersion
      parameters:
      - name: id
        in: path
        description: "The unique ID for a repository item, always starts with a *."
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
        examples:
          id:
            value: '*YK_q3iKGm3WUlAzo'
      - name: versionNumber
        in: path
        description: The number of the version
        required: true
        schema:
          type: integer
        examples:
          versionNumber:
            value: 3
      responses:
        "204":
          description: "The version of the item was successfully deleted. If the version\
            \ was the most recent and there are no changes in the \"working area\"\
            , then the version will be deleted and the changes will be moved to the\
            \ \"working area\"."
        "401":
          description: Response if the request is unauthenticated
        "403":
          description: The user does not have the permission to delete the requested
            item version
  /repository/{id}/workingArea:
    delete:
      tags:
      - Repository
      summary: Deletes the unversioned changes (if any) for the specified leaf item.
      operationId: deleteUnversionedChanges
      parameters:
      - name: id
        in: path
        description: "The unique ID for a repository item, always starts with a *."
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
        examples:
          id:
            value: '*YK_q3iKGm3WUlAzo'
      responses:
        "204":
          description: "Unversioned changes were successfully deleted, if any existed."
        "400":
          description: "If the specified item does not have any versions, or if the\
            \ targeted item is not a leaf item."
        "401":
          description: Response if the request is unauthenticated
        "403":
          description: The user does not have the permission to delete the requested
            item version
        "404":
          description: If no item with the specified ID exists.
    post:
      tags:
      - Repository
      summary: Restores the state of the specified item in the specified version to
        the working area.
      operationId: restoreWorkingAreaFromVersion
      parameters:
      - $ref: "#/components/parameters/PreferHeader"
      - name: id
        in: path
        description: "The unique ID for a repository item, always starts with a *."
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
          example: '*YK_q3iKGm3WUlAzo'
      - name: fromVersion
        in: query
        description: The version number of the item to restore to the working area.
        required: true
        schema:
          minimum: 1
          type: integer
          example: 1
      responses:
        "200":
          description: Returns the working area of the item in its restored state.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/RepositoryItem"
            application/json; profile=knime.com/cloud.repository.workflow.simple.v20190220:
              schema:
                $ref: "#/components/schemas/SimpleWorkflow"
            application/json; profile=knime.com/cloud.repository.workflow.detailed.v20190220:
              schema:
                $ref: "#/components/schemas/DetailedWorkflow"
            application/json; profile=knime.com/cloud.repository.workflow.aggregated.v20190220:
              schema:
                $ref: "#/components/schemas/AggregatedWorkflow"
            application/json; profile=knime.com/cloud.repository.component.simple.v20190725:
              schema:
                $ref: "#/components/schemas/SimpleComponent"
            application/json; profile=knime.com/cloud.repository.component.detailed.v20190725:
              schema:
                $ref: "#/components/schemas/DetailedComponent"
            application/json; profile=knime.com/cloud.repository.component.aggregated.v20190725:
              schema:
                $ref: "#/components/schemas/AggregatedComponent"
        "400":
          description: |-
            - If the item with the specified ID is not a component, data file, or workflow.
            - If the mandatory query param 'fromVersion' is missing.
            - If 'fromVersion' does not specify a positive number.
        "401":
          description: If the user is not authenticated.
        "403":
          description: If the user has not the required permissions to restore the
            item.
        "404":
          description: If the item with the specified ID does not exist or does not
            exist in the specified version.
  /repository/{id}/savepoints:
    get:
      tags:
      - Repository
      summary: "List savepoints for a certain repository item. The list is ordered\
        \ such that the latest savepoint is always on top, and after that they are\
        \ ordered by creation date and then savepoint number. For items which were\
        \ migrated from \"space-level\" versioning to \"item-level\" versioning this\
        \ ordering may not always reflect the real timeline of the savepoints created\
        \ in \"space-level\" versioning. But it will be accurate for new savepoints\
        \ created after the migration."
      operationId: getSavepoints
      parameters:
      - name: id
        in: path
        description: The repository item or its unique ID which always starts with
          a *.
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
        examples:
          id:
            value: '*YK_q3iKGm3WUlAzo'
      - name: limit
        in: query
        description: Maximum number of savepoints returned in the response. All versions
          will be returned by using -1.
        required: false
        schema:
          default: 10
          type: integer
      responses:
        "200":
          description: "Returns a list with all item savepoints for the requested\
            \ item. If a savepoint is not associated with a  version, the 'version'\
            \ property will be omitted."
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ItemSavepointList"
        "400":
          description: "Response if the knime ID is not a workflow, component, or\
            \ data file OR the limit value is invalid"
        "401":
          description: Response if the request is unauthenticated
        "403":
          description: Response if the logged in user is not permitted to read the
            item.
        "404":
          description: Response if no item with the specified ID exists
  /counts:
    get:
      tags:
      - Repository
      - Node Catalog
      - Extension Catalog
      summary: "Returns the total number of entities of each type in the catalog.\
        \ When a user accountId is passed as a query parameter, only entities whose\
        \ canonical path contains the user accountId passed will be counted, plus\
        \ a count of all kudos received by the user. If the user accountId parameter\
        \ is passed and the authentication token matches the account name, the counts\
        \ will also include private entities owned by the specified user. If user\
        \ account name is passed as a query parameter, the user accountId will be\
        \ retrieved. Then the entities will be calculated as described above. The\
        \ username parameter is deprecated."
      operationId: getTotalCounts
      parameters:
      - name: username
        in: query
        description: "Username of the owner, the matching is case insensitive. This\
          \ is a deprecated parameter."
        required: false
        schema:
          type: string
      - name: accountId
        in: query
        description: Account ID of the owner
        required: false
        schema:
          pattern: "(?:account(?::|%3A))?(?:team|user)(?::|%3A)[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}"
          type: string
        examples:
          accountId:
            value: account:user:b97a3838-ac7b-3df9-8f39-b6de3b140d6b
      responses:
        "200":
          description: a JSON object with the total counts of each entity type
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/TotalCounts"
        "400":
          description: "Response if the getTotalCounts endpoint was called with two\
            \ query parameters (username and accountId). When calling getTotalCounts\
            \ endpoint, only one of the two parameters may be present. Either accountId\
            \ or username, but not both at the same time."
        "404":
          description: Response if getTotalCounts endpoint was called with username
            or accountId parameter but the referenced account does not exist.
  /list/components:
    get:
      tags:
      - Components
      summary: "Returns a list of components in the server repository. If no query\
        \ parameter is provided, then a paginated list of all public components will\
        \ be returned. If the query parameter is provided, only the components with\
        \ the listed IDs will be returned (without pagination)."
      operationId: getComponentList
      parameters:
      - $ref: "#/components/parameters/PreferHeader"
      - in: query
        name: q
        style: form
        explode: false
        schema:
          type: array
          items:
            type: string
        description: "Optional query parameter containing comma separated list of\
          \ component template IDs. Mutually exclusive to 'spaceId' query param. Overrides\
          \ 'limit' and 'startingAfter' query params. Example '*NTuSu50ZmuP6GacH,*EyBAgtSLjhNMIUhv,*qNKuMT32RI-gVS9o'"
      - name: details
        in: query
        description: "Specifies whether details should be shown and in what form (full\
          \ details, aggregated, ...)."
        schema:
          default: none
          enum:
          - full
          - aggregated
          - search
          - none
          type: string
      - name: version
        in: query
        description: "Optional query parameter which indicates the version of components\
          \ to filter by. \nSpecific version references are not allowed.\nOne of:\n\
          \  - The special value 'most-recent', which points to the latest version\
          \ of the item.\n  - The special value 'current-state', which points to the\
          \ latest overall state of the item, i.e. including\n    unversioned changes."
        required: false
        schema:
          default: current-state
          enum:
          - current-state
          - most-recent
          type: string
      - name: limit
        description: The maximum number of components to return at once. Must be a
          positive integer. Ignored if 'q' is specified. Note that fewer components
          than the specified limit may be returned also for pages which are not the
          last page.
        in: query
        schema:
          default: 500
          minimum: 1
          type: integer
      - name: startingAfter
        in: query
        description: "Optional (exclusive) start of the page. If not specified, the\
          \ page starts at the beginning of the internal order. Ignored if 'q' is\
          \ specified."
        schema:
          pattern: "^\\*[0-9a-zA-Z_\\-]{16}$"
          type: string
      responses:
        "200":
          description: "Returns a (possibly paginated) list of component metadata.\
            \ If paginated, clients should make no assumptions about the order of\
            \ the returned pages or the items within each page but treat them as unordered.\
            \ Also, the returned pointer to the next page should be treated as an\
            \ opaque token without any additional semantics."
          content:
            application/json:
              schema:
                oneOf:
                - $ref: "#/components/schemas/ComponentPage"
                - $ref: "#/components/schemas/ComponentList"
  /list/workflows:
    get:
      tags:
      - Workflows
      summary: Returns a paginated list of public workflows in the server repository.
      operationId: getWorkflowList
      parameters:
      - $ref: "#/components/parameters/PreferHeader"
      - name: details
        in: query
        description: "Specifies whether details should be shown and in what form (full\
          \ details, aggregated, ...)."
        schema:
          default: none
          enum:
          - full
          - aggregated
          - search
          - none
          type: string
      - name: version
        in: query
        description: "Optional query parameter which indicates the version of workflows\
          \ to filter by. \nSpecific version references are not allowed.\nOne of:\n\
          \  - The special value 'most-recent', which points to the latest version\
          \ of the item.\n  - The special value 'current-state', which points to the\
          \ latest overall state of the item, i.e. including\n    unversioned changes."
        required: false
        schema:
          default: current-state
          enum:
          - current-state
          - most-recent
          type: string
      - name: limit
        description: The maximum number of workflows to return at once. Must be a
          positive integer. Note that fewer workflows than the specified limit may
          be returned also for pages which are not the last page.
        in: query
        schema:
          default: 500
          minimum: 1
          type: integer
      - name: startingAfter
        in: query
        description: "Optional (exclusive) start of the page. If not specified, the\
          \ page starts at the beginning of the internal order."
        schema:
          pattern: "^\\*[0-9a-zA-Z_\\-]{16}$"
          type: string
      responses:
        "200":
          description: "Returns a page of workflow metadata. Clients should make no\
            \ assumptions about the order of the returned pages or the items within\
            \ each page but treat them as unordered. Also, the returned pointer to\
            \ the next page should be treated as an opaque token without any additional\
            \ semantics."
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/WorkflowPage"
  /list/accounts:
    get:
      tags:
      - Repository
      summary: Returns a list of accounts (user directories) in the server repository.
      operationId: getAccountList
      responses:
        "200":
          description: Returns a list of account metadata
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/WorkflowGroupList"
  /list/resources/index:
    get:
      tags:
      - Repository
      summary: Returns an index of all public resources in the catalog.
      operationId: getResourceIndex
      parameters:
      - name: types
        in: query
        description: "Comma separated list of resource types which should be included\
