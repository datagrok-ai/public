          enum:
          - minimum
          - basic
          - full
          type: string
      - name: sort
        in: query
        description: Specifies how the returned node list should be sorted.
        schema:
          default: REQUESTED
          enum:
          - REQUESTED
          - ALPHABETICAL
          type: string
      responses:
        "200":
          description: Returns the external representation of a node list.
          content:
            application/json; profile=knime.com/cloud.repository.node.list.full.v20190220:
