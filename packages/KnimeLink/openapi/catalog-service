---
openapi: 3.0.1
info:
  title: KNIME Catalog Microservice REST API
  description: RESTful services for the catalog microservice
  contact:
    name: KNIME Support
    url: http://www.knime.com
    email: support@knime.com
  version: v4
servers:
- url: /catalog
  description: Default catalog microservice
tags:
- name: Repository
  description: Requests relating to the KNIME Hub repository.
- name: Uploads
  description: Requests related to uploading items to the repository.
- name: Downloads
  description: Requests related to downloading items from the repository.
- name: Components
  description: Requests relating to the components catalog
- name: Node Catalog
  description: Requests relating to the KNIME Hub node catalog.
- name: Extension Catalog
  description: Requests relating to the KNIME Hub extension catalog.
- name: Search
  description: Endpoints related to searches across different entities.
- name: Node Mappings
  description: Requests relating to node mappings.
- name: Management
  description: Requests relating to admin management functionality.
- name: Collections
  description: Requests relating to collections.
- name: Limits
  description: Requests related to limits.
- name: Spaces
  description: Requests related to spaces.
- name: AccountRoots
  description: Requests related to accounts roots (former user folders).
paths:
  /repository/{id}:
    get:
      tags:
      - Repository
      summary: Returns the repository item at the given path or with the given ID
        in the server repository.
      operationId: getRepositoryItemMetaData
      parameters:
      - $ref: "#/components/parameters/PreferHeader"
      - name: id
        in: path
        description: The item's unique ID. It always starts with a * and does not
          change even if the repository item is renamed or moved.  May also be a concatenation
          of path followed by the '~' character and the ID without the leading '*'
          character.  This occurs when the request originates from an older AP that
          cannot handle the new URI format which adds the  ID to the end of the path.
        required: true
        schema:
          pattern: "^(?:\\*[0-9a-zA-Z_\\-]{16}|[^*?#:\\\"<>|~]+~[0-9a-zA-Z_-]{16})$"
          type: string
        examples:
          unique ID:
            value: '*YK_q3iKGm3WUlAzo'
          legacy format:
            value: path/to/workflow~YK_q3iKGm3WUlAzo
      - name: details
        in: query
        description: "Specifies whether details should be shown and in what form (full\
          \ details, aggregated, ...)."
        schema:
          enum:
          - full
          - aggregated
          - none
          type: string
      - name: deep
        in: query
        description: Optional query parameter which enables deep listing of all children.
        schema:
          type: boolean
      - name: spaceDetails
        in: query
        description: Optional query parameter which when true provides additional
          information about a space (i.e. kudos and stats)
        schema:
          type: boolean
      - name: contribSpaces
        in: query
        description: "An optional query parameter which determines if the spaces a\
          \ user can contribute to are included when requesting a user's directory,\
          \ and the format these spaces should be written in. This parameter is ignored\
          \ if another other than a user's directory is requested."
        schema:
          default: none
          enum:
          - none
          - children
          - filesystem
          type: string
      - name: version
        in: query
        description: |-
          Optional query parameter which specifies the version of the item to retrieve.
          One of:
            - The version number of an existing item version. Must be a positive integer.
            - The special value 'most-recent', which points to the latest version of the item.
            - The special value 'current-state', which points to the latest overall state of the item, i.e. including
              unversioned changes. Note that this is the only valid option for items that do not support versioning.

          If used together with query parameter 'spaceVersion' the two parameters need to refer to the same version.
        required: false
        schema:
          default: current-state
          oneOf:
          - minimum: 1
            type: integer
            example: 1
          - enum:
            - current-state
            - most-recent
            type: string
            example: current-state
      - name: spaceVersion
        in: query
        description: |-
          Legacy: Optional query parameter which indicates the version of the space where the item is stored. It can be either:
            - The version number of an existing space version (e.g. '1')
            - 'latest' to target the latest space version (corresponds to value 'most-recent' of query parameter
              'version')
            - '-1' to target the current state, i.e. including unversioned changes (corresponds to value
              'current-state' of query parameter 'version')

          If used together with query parameter 'version' the two parameters need to refer to the same version.  Clients are encouraged to only use the 'version' parameter instead.
        required: false
        schema:
          default: "-1"
          type: string
        example: "-1"
      responses:
        "200":
          description: "Returns the external representation of an item in the workflow\
            \ repository. It has one of several possible types, see the schema description\
            \ for details."
          content:
            application/json:
              schema:
                oneOf:
                - $ref: "#/components/schemas/RepositoryItemAsMason"
                - $ref: "#/components/schemas/Space"
            application/json; profile=knime.com/cloud.repository.workflow.simple.v20190220:
              schema:
                $ref: "#/components/schemas/SimpleWorkflow"
            application/json; profile=knime.com/cloud.repository.workflow.detailed.v20190220:
              schema:
                $ref: "#/components/schemas/DetailedWorkflow"
            application/json; profile=knime.com/cloud.repository.workflow.aggregated.v20190220:
              schema:
                $ref: "#/components/schemas/AggregatedWorkflow"
            application/json; profile=knime.com/cloud.repository.component.simple.v20190725:
              schema:
                $ref: "#/components/schemas/SimpleComponent"
            application/json; profile=knime.com/cloud.repository.component.detailed.v20190725:
              schema:
                $ref: "#/components/schemas/DetailedComponent"
            application/json; profile=knime.com/cloud.repository.component.aggregated.v20190725:
              schema:
                $ref: "#/components/schemas/AggregatedComponent"
        "400":
          description: |-
            - If both 'version' and 'spaceVersion' are specified
            - If the requested item is not a leaf item and 'version' or 'spaceVersion' are specified with a value
              different from 'current-state' or '-1', respectively
            - If the request is otherwise malformed
        "404":
          description: Response if the requested ID doesn't exist in the repository.
        "403":
          description: User does not have permission to view the item
        "401":
          description: Unauthenicated request cannot view item
    delete:
      tags:
      - Repository
      summary: Deletes an item from the repository.
      description: "Deletes an item (workflow, data file, a whole workflow group)\
        \ from the repository."
      operationId: deleteItemById
      parameters:
      - $ref: "#/components/parameters/PreferHeader"
      - name: id
        in: path
        description: The item's unique ID. It always starts with a * and does not
          change even if the repository item is renamed or moved.
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
        examples:
          unique ID:
            value: '*YK_q3iKGm3WUlAzo'
      - name: softDelete
        in: query
        description: "Optional parameter that enables soft deletion of repository\
          \ items, which means that deleted items get moved to the trash bin."
        schema:
          default: false
          type: boolean
      responses:
        "204":
          description: No content if the item was successfully removed.
        "403":
          description: Response if the requester does not have permission to delete
            the requested item
        "401":
          description: Response if the requester is unauthenticated
  /repository/{path}:
    get:
      tags:
      - Repository
      summary: Returns the repository item at the given path in the server repository.
      operationId: getRepositoryItemByPath
      parameters:
      - $ref: "#/components/parameters/PreferHeader"
      - name: path
        in: path
        description: The absolute path to the repository item.
        required: true
        schema:
          pattern: "^[^*?#:\\\"<>|]+$"
          type: string
        examples:
          path:
            value: /Users/knime/Examples/00_Components/Automation/AutoML
      - name: details
        in: query
        description: "Specifies whether details should be shown and in what form (full\
          \ details, aggregated, ...)."
        schema:
          enum:
          - full
          - aggregated
          - none
          type: string
      - name: deep
        in: query
        description: Optional query parameter which enables deep listing of all children.
        schema:
