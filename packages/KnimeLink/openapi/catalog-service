            items:
              anyOf:
              - $ref: "#/components/schemas/NativeNodeInstance"
              - $ref: "#/components/schemas/ComponentInstance"
              - $ref: "#/components/schemas/MetaNodeInstance"
          space:
            $ref: "#/components/schemas/SpacePermissionAttributes"
      - $ref: "#/components/schemas/BasicComponentMetaInfo"
    FullWorkflowMetaInfo:
      allOf:
      - required:
        - nodes
        type: object
        properties:
          nodes:
            description: "An array of all nodes in the workflow, these can be native\
              \ nodes, components, or metanodes"
            type: array
            items:
              anyOf:
              - $ref: "#/components/schemas/NativeNodeInstance"
              - $ref: "#/components/schemas/ComponentInstance"
              - $ref: "#/components/schemas/MetaNodeInstance"
          space:
            $ref: "#/components/schemas/SpacePermissionAttributes"
      - $ref: "#/components/schemas/BasicWorkflowMetaInfo"
    SpacePermissionAttributes:
      description: An SpacePermissionAttributes object
