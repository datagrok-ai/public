          description: Dimensions of the workflow's SVG image
          type: object
          properties:
            height:
              description: The image's height in pixels.
              type: integer
              example: 123
            width:
              description: The image's width in pixels.
              type: integer
              example: 244
        encryption:
          $ref: "#/components/schemas/BasicEncryption"
    BasicComponentMetaInfo:
      required:
      - templateInformation
      - inPorts
      - outPorts
      - dialog
      - views
      - kudos
      - encryption
      type: object
