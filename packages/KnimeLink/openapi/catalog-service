            format: byte
            description: base64 encoded representation of a node's image icon
            type: string
          deprecated:
            type: boolean
          streamable:
            type: boolean
          inPorts:
            type: array
            items:
              $ref: "#/components/schemas/NodePortInfo"
          outPorts:
            type: array
            items:
