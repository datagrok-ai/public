  /repository/Users/{accountId}/{subPath}:
    get:
      tags:
      - Repository
      summary: Returns the repository item at the given canonical path in the catalog
      operationId: getRepositoryItemByCanonicalPath
      parameters:
      - $ref: "#/components/parameters/PreferHeader"
      - name: accountId
        in: path
        description: The ID of the account the repository item is associated with
        required: true
        schema:
          pattern: "(?:account(?::|%3A))?(?:team|user)(?::|%3A)[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}"
          type: string
        example: account:team:a885bb42-d808-4557-9a7f-9f10c5777739
      - name: subPath
        in: path
        description: The '/' delimited path to the resource below the account root
          level
        required: false
        schema:
          type: string
        example: /spaceName/groupName/workflowName
      - name: details
        in: query
        description: "Specifies whether details should be shown and in what form (full\
          \ details, aggregated, ...)."
        schema:
          enum:
          - full
          - aggregated
          - none
          type: string
      - name: deep
        in: query
        description: Optional query parameter which enables deep listing of all children.
        schema:
          type: boolean
      - name: spaceDetails
        in: query
        description: Optional query parameter which when true provides additional
          information about a space (i.e. kudos and stats)
        schema:
          type: boolean
      - name: contribSpaces
        in: query
        description: "An optional query parameter which determines if the spaces a\
          \ user can contribute to are included when requesting a user's directory,\
          \ and the format these spaces should be written in. This parameter is ignored\
          \ if another other than a user's directory is requested."
        schema:
          default: none
          enum:
          - none
          - children
          - filesystem
          type: string
      - name: version
        in: query
        description: |-
          Optional query parameter which specifies the version of the item to retrieve.
          One of:
            - The version number of an existing item version. Must be a positive integer.
            - The special value 'most-recent', which points to the latest version of the item.
            - The special value 'current-state', which points to the latest overall state of the item, i.e. including
              unversioned changes. Note that this is the only valid option for items that do not support versioning.

          If used together with query parameter 'spaceVersion' the two parameters need to refer to the same version.
        required: false
        schema:
          default: current-state
          oneOf:
          - minimum: 1
            type: integer
            example: 1
          - enum:
            - current-state
            - most-recent
            type: string
            example: current-state
      - name: spaceVersion
        in: query
        description: |-
          Legacy: Optional query parameter which indicates the version of the space where the item is stored. It can be either:
            - The version number of an existing space version (e.g. '1')
            - 'latest' to target the latest space version (corresponds to value 'most-recent' of query parameter
              'version')
            - '-1' to target the current state, i.e. including unversioned changes (corresponds to value
              'current-state' of query parameter 'version')

          If used together with query parameter 'version' the two parameters need to refer to the same version.  Clients are encouraged to only use the 'version' parameter instead.
        required: false
        schema:
          default: "-1"
          type: string
        example: "-1"
      responses:
        "200":
          description: "Returns the external representation of an item in the catalog.\
            \ It has one of several possible types, see the schema description for\
            \ details."
          content:
            application/json:
              schema:
                oneOf:
                - $ref: "#/components/schemas/RepositoryItemAsMason"
                - $ref: "#/components/schemas/Space"
            application/json; profile=knime.com/cloud.repository.workflow.simple.v20190220:
              schema:
                $ref: "#/components/schemas/SimpleWorkflow"
            application/json; profile=knime.com/cloud.repository.workflow.detailed.v20190220:
              schema:
                $ref: "#/components/schemas/DetailedWorkflow"
            application/json; profile=knime.com/cloud.repository.workflow.aggregated.v20190220:
              schema:
                $ref: "#/components/schemas/AggregatedWorkflow"
            application/json; profile=knime.com/cloud.repository.component.simple.v20190725:
              schema:
                $ref: "#/components/schemas/SimpleComponent"
            application/json; profile=knime.com/cloud.repository.component.detailed.v20190725:
              schema:
                $ref: "#/components/schemas/DetailedComponent"
            application/json; profile=knime.com/cloud.repository.component.aggregated.v20190725:
              schema:
                $ref: "#/components/schemas/AggregatedComponent"
        "400":
          description: |-
            - If both 'version' and 'spaceVersion' are specified
            - If the requested item is not a leaf item and 'version' or 'spaceVersion' are specified with a value
              different from 'current-state' or '-1', respectively
            - If the request is otherwise malformed
        "404":
          description: Returned if no item exists at that path
        "401":
          description: "Response if the request is unauthenticated, and authentication\
            \ is needed to view this item"
        "403":
          description: Returned if the requesting user does not have read access to
            the item at the given path
    put:
      tags:
      - Repository
      summary: |-
        Creates a repository item at the given path. Currently, only workflow groups, spaces, and workflows are supported.
        To create a new workflow group, issue a PUT request to a path below a space. If the group already exists,  it will be returned. If no body is sent and the path target is below a space, a group will be created. Specifying the item type is optional (has to be 'WorkflowGroup' if specified).
        To create a new space, issue a PUT request with a request to a space path (i.e. in a user directory) with an  optional request body specifying space metadata. If the space already exists an error will be returned.  Space metadata properties not specified in the request body will be set to their default values. If no body  is sent and the path target is a space, a space using default values will be created. Specifying the item type  is optional (has to be 'Space' if specified).
        To create a new empty workflow, issue a PUT request to a path below a space and specify the type 'Workflow' in  the request body.
      operationId: createItemByCanonicalPath
      requestBody:
        description: Optional item metadata
        required: false
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateRepositoryItemRequestBody"
      parameters:
      - $ref: "#/components/parameters/PreferHeader"
      - name: accountId
        in: path
        description: The ID of the account the repository item is associated with
        required: true
        schema:
          pattern: "(?:account(?::|%3A))?(?:team|user)(?::|%3A)[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}"
          type: string
        example: account:team:a885bb42-d808-4557-9a7f-9f10c5777739
      - name: subPath
        in: path
        description: The '/' delimited path to the resource below the account root
          level
        required: false
        schema:
          type: string
        example: /spaceName/groupName
      responses:
        "201":
          description: Returns the external representation of the created item
          content:
            application/json:
              schema:
                oneOf:
                - $ref: "#/components/schemas/WorkflowGroup"
                - $ref: "#/components/schemas/Space"
                - $ref: "#/components/schemas/SimpleWorkflow"
        "200":
          description: Returns the external representation of the workflow group that
            already exists.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/WorkflowGroup"
        "400":
          description: |-
            Response if,
              the request path targets a space but a different type is requested in the request body,
              the request path targets below a space but a type other than 'Workflow' or 'WorkflowGroup' is requested in the request body,
              the request is missing a user ID (provided by a JWT token),
              the request body is malformed.
        "403":
          description: |-
            Response if,
              the user does not have write permissions to the specified path,
              the path points to a user directory for a workflow group creation,
              the path parent does not point to a user directory for a space creation.
        "401":
          description: Response if the request is unauthenticated
        "409":
          description: |-
            Response if,
              an item already exists at the specified location but is not a workflow group.
    delete:
      tags:
      - Repository
      summary: Deletes an item from the repository.
      description: "Deletes an item (workflow, data file, a whole workflow group)\
        \ from the repository."
      operationId: deleteItemByCanonicalPath
      parameters:
      - name: accountId
        in: path
        description: The ID of the account the repository item is associated with
        required: true
        schema:
          pattern: "(?:account(?::|%3A))?(?:team|user)(?::|%3A)[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}"
          type: string
        example: account:team:a885bb42-d808-4557-9a7f-9f10c5777739
      - name: subPath
        in: path
        description: The '/' delimited path to the resource below the account root
          level
        required: false
        schema:
          type: string
        example: /spaceName/groupName
      - name: softDelete
        in: query
        description: "Optional parameter that enables soft deletion of repository\
          \ items, which means that deleted items get moved to the trash bin."
        schema:
          default: false
          type: boolean
      responses:
        "204":
          description: No content if the item was successfully removed.
        "401":
          description: Response if the request is unauthenticated
        "403":
          description: Response if the user does not have permission to delete the
            requested item
  /collections:
