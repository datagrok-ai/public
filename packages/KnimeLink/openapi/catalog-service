    PrepareUploadRequestBody:
      description: Request body for preparing the upload of one or more repository
        items.
      type: object
      properties:
        items:
          description: "Each entry specifies the upload of a single repository item\
            \ or an empty workflow group, where the key of the entry is the relative\
            \ path of the item or workflow group. A single request can at most initiate\
            \ 500 initial part uploads."
          type: object
          additionalProperties:
            description: Specifies the upload of a single repository item.
            required:
            - itemContentType
            type: object
            properties:
              itemContentType:
                description: The content type of the item which will be uploaded.
                type: string
              initialPartCount:
                description: "The number of parts whose uploads to prepare right away.\
                  \ Clients can specify a non-zero number if they anticipate to start\
                  \ uploading the item's parts in a timely manner, which allows them\
                  \ to save additional calls for their preparation. Additional part\
                  \ uploads can still be prepared via the respective endpoint afterward\
                  \ if needed."
                default: 0
                maximum: 500
                minimum: 0
                type: integer
      example:
        items:
          my-workflow:
            itemContentType: application/vnd.knime.workflow+zip
          my-group/my-data-file:
            itemContentType: text/plain
            initialPartCount: 3
          my-group/my-empty-group:
            itemContentType: application/vnd.knime.workflow-group
    PrepareUploadResponseBody:
      description: Response body for the prepared upload of one or more repository
        items.
      type: object
      properties:
        items:
          description: "Each entry specifies the prepared upload of a single repository\
            \ item, where the key of the entry is the relative path of the item."
          type: object
          additionalProperties:
            description: The prepared upload of a single repository item.
            required:
            - uploadId
            type: object
            properties:
              uploadId:
                description: "The ID of the upload. Allows clients to complete or\
                  \ abort an upload, as well as to keep track of its status. Clients\
                  \ should make no assumptions about the format of the ID but should\
                  \ treat it as an opaque token."
                type: string
                example: d63ec9e1-24a7-4015-82b4-476ca4f4a57b~7fbeb904-2272-4dd7-b2e1-d3f49b8373a0
              parts:
                description: "The prepared part uploads of the item. Each entry specifies\
                  \ the prepared upload of a single part, where the key of the entry\
                  \ is the number of the part. The number of prepared parts is governed\
                  \ by the initial part count specified in the request body."
                type: object
                additionalProperties:
                  $ref: "#/components/schemas/PartUpload"
        '@controls':
          description: A (possibly empty) map with all controls for this object.
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Control"
        '@namespaces':
          description: A (possibly empty) map with the namespaces for this object.
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Namespace"
      example:
        items:
          my-workflow:
            workflowGroup: false
            uploadId: d63ec9e1-24a7-4015-82b4-476ca4f4a57b~7fbeb904-2272-4dd7-b2e1-d3f49b8373a0
          my-group/my-data-file:
            workflowGroup: false
            uploadId: 7227362d-c1ae-452c-a53c-cf0d609caef4~874d4805-f51f-4c83-81c1-10919e3dee48
            parts:
              "1":
                method: PUT
                url: https://example.com/foo?X-Amz-Algorithm=...
                header:
                  Host:
                  - example.com
              "2":
                method: PUT
                url: https://example.com/foo?X-Amz-Algorithm=...
                header:
                  Host:
                  - example.com
              "3":
                method: PUT
                url: https://example.com/foo?X-Amz-Algorithm=...
                header:
                  Host:
                  - example.com
          my-group/my-empty-group:
            workflowGroup: true
        '@namespaces':
          knime:
            name: http://www.knime.com/server/rels#
        '@controls':
          knime:upload-status:
            href: "http://localhost:9080/uploads/{uploadId}/status"
            isHrefTemplate: true
            method: GET
            title: Retrieves the status of the upload
          knime:create-upload-part:
            href: "http://localhost:9080/uploads/{uploadId}/parts{?partNumber}"
            isHrefTemplate: true
            method: POST
            title: Creates a URI to upload another part
          knime:complete-upload:
            href: "http://localhost:9080/uploads/{uploadId}"
            isHrefTemplate: true
            method: POST
            title: Completes the upload
          knime:abort-upload:
            href: "http://localhost:9080/uploads/{uploadId}"
            isHrefTemplate: true
            method: DELETE
            title: Aborts the upload
    PreparePartUploadResponseBody:
      description: Response body for the prepared upload of a part of a repository
        items.
      type: object
      allOf:
      - $ref: "#/components/schemas/PartUpload"
    PartUpload:
      description: The prepared upload of a part of a repository item.
      required:
      - method
      - url
      - header
      type: object
      properties:
        method:
          description: The HTTP method to use for the upload request.
          type: string
          example: PUT
        url:
          description: The URL to upload the part's data to. Note that the URL may
            expire after a certain period of time. Clients are expected to recover
            from an expiration by refreshing the part upload (i.e. preparing it again)
            using the respective endpoint.
          type: string
          example: https://example.com/foo?X-Amz-Algorithm=...
        header:
          description: "Headers that must be sent with the upload request. Returned\
            \ as key-value pairs, where the key of each pair is the name of the corresponding\
            \ header and the value is an array of the values of the header."
          type: object
          additionalProperties:
            type: array
            items:
              type: string
          example:
            Host:
            - example.com
    CompleteUploadRequestBody:
      description: "Request body for completing the upload of a repository item. Each\
        \ entry in the body specifies an uploaded part of the item, where the key\
        \ of the entry is the number of the part."
      type: object
      additionalProperties:
        description: The ETag of the uploaded part. May be null or empty.
        type: string
      example:
        "1": ""
        "2": ""
        "3": ""
    UploadStatus:
      description: The status of an upload.
      required:
      - uploadId
      - initiatorAccountId
      - status
      - statusMessage
      - lastUpdated
      - targetCanonicalPath
      type: object
      properties:
        uploadId:
          description: The ID of the upload.
          type: string
          example: d63ec9e1-24a7-4015-82b4-476ca4f4a57b~7fbeb904-2272-4dd7-b2e1-d3f49b8373a0
        initiatorAccountId:
          description: The account ID of the user who initiated the upload.
          type: string
          example: account:user:c1df863a-0410-4b27-97fc-5ceb3a515176
        status:
          description: The status of the upload.
          enum:
          - PREPARED
          - ANALYSIS_PENDING
          - COMPLETED
          - ABORTED
          - FAILED
          type: string
        statusMessage:
          description: A human readable message describing the upload's status. This
            message is also used for communicating errors to the client.
          type: string
          example: Waiting for item to be fully uploaded.
        lastUpdated:
          format: date-time
          description: The date/time the status was last updated.
          type: string
          example: 2023-08-22T09:11:02+00:00
        targetCanonicalPath:
          description: "The target location of the upload, e.g. the canonical path\
            \ the item is being uploaded to."
          type: string
          example: /Users/account:user:c1df863a-0410-4b27-97fc-5ceb3a515176/my-space/my-workflow
        '@controls':
          description: A (possibly empty) map with all controls for this object.
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Control"
        '@namespaces':
          description: A (possibly empty) map with the namespaces for this object.
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Namespace"
    UploadId:
      type: string
      example: d63ec9e1-24a7-4015-82b4-476ca4f4a57b~7fbeb904-2272-4dd7-b2e1-d3f49b8373a0
    LeafItemDownloadResponseBody:
      description: Response body for a download in preparation.
      type: object
      properties:
        downloadUrl:
          description: The actual download URL. This is set once the download is ready.
          type: string
          example: https://example.com
