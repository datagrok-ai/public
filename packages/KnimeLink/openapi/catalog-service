        "401":
          description: Response if the request is unauthenticated
  /repository/{id}:data:
    get:
      tags:
      - Repository
      - Downloads
      summary: Downloads the given repository item.
      deprecated: true
      description: |-
        Deprecated, use `GET /repository/{id}/artifact` for downloading and `GET /components/{id}/updates` to check for
        component updates instead.

        The returned content depends on the item's type. If it's a workflow then a ZIP archive is returned. If
        it's a data file then the file will be returned as is with an auto-guessed content types (based on the file
        extension).
      operationId: downloadItemById
      parameters:
      - name: id
        in: path
        description: The repository item's unique ID. It always starts with a * and
          does not change even if the repository item is renamed or moved. May also
          be a concatenation of path followed by the '~' character and the ID without
          the leading '*' character.  This occurs when the request originates from
          an older AP that cannot handle the new URI format which adds the  ID to
          the end of the path.
        required: true
        schema:
          pattern: "^(?:\\*[0-9a-zA-Z_\\-]{16}|[^*?#:\\\"<>|~]+~[0-9a-zA-Z_-]{16})$"
          type: string
        examples:
          unique ID:
            value: '*YK_q3iKGm3WUlAzo'
          legacy format:
            value: /path/to/workflow~YK_q3iKGm3WUlAzo
      - name: version
        in: query
        description: |-
          Optional query parameter which specifies the version of the item to retrieve.
          One of:
            - The version number of an existing item version. Must be a positive integer.
            - The special value 'most-recent', which points to the latest version of the item.
            - The special value 'current-state', which points to the latest overall state of the item, i.e. including
              unversioned changes. Note that this is the only valid option for items that do not support versioning.

          If used together with query parameter 'spaceVersion' the two parameters need to refer to the same version.
        required: false
        schema:
          default: current-state
          oneOf:
          - minimum: 1
            type: integer
            example: 1
          - enum:
            - current-state
            - most-recent
            type: string
            example: current-state
      - name: spaceVersion
        in: query
        description: |-
          Legacy: Optional query parameter which indicates the version of the space where the item is stored. It can be either:
            - The version number of an existing space version (e.g. "1")
            - 'latest' to target the latest space version (corresponds to value 'most-recent' of query parameter
              'version')
            - '-1' to target the current state, i.e. including unversioned changes (corresponds to value
              'current-state' of query parameter 'version')

          If used together with query parameter 'version' the two parameters need to refer to the same version.  Clients are encouraged to only use the 'version' parameter instead.
        required: false
        schema:
          default: "-1"
          type: string
        example: "-1"
      responses:
        "200":
          description: The requested repository item. Depending on the item's type
            a different content type will be returned.
          content:
            application/vnd.knime.workflow+zip:
              schema:
                format: binary
                description: A ZIP archive that contains a single workflow.
                type: string
            application/vnd.knime.workflow-group+zip:
              schema:
                format: binary
                description: A ZIP archive that contains a workflow group.
                type: string
            '*/*':
              schema:
                format: binary
                description: A data file that is sent as-is.
                type: string
        "307":
          description: Response if the requested item is a leaf item which leads to
            a redirect to a storage provider.
        "404":
          description: Response if the requested path doesn't exist in the repository.
        "400":
          description: |-
            Response if
            - Both 'version' and 'spaceVersion' are specified
            - The requested item is not a leaf item and 'version' or 'spaceVersion' are specified with a value different
              from 'current-state' or '-1', respectively
        "401":
          description: "Response if the request is unauthenticated, and authentication\
            \ is required to download the specified item"
        "403":
          description: Response if the requester does not have permission to download
            the specified item
    put:
      tags:
      - Repository
      - Uploads
      summary: Uploads a workflow or data file.
      deprecated: true
      description: |-
        Deprecated, use `POST /repository/{parentId}/manifest` for uploading, `POST /repository/{id}/copies` for copying,
        `PUT /repository/{id}/path` for moving or renaming items below the space level, and `PUT /spaces/{id}/name` for
        renaming spaces.

        Upload a workflow or data file to the server. Depending on the content type of the request the upload is either
        a workflow/template (application/vnd.knime.workflow+zip) or a data file (all other content types).
      operationId: uploadItemById
      parameters:
      - name: id
        in: path
        description: The repository item's unique ID. It always starts with a * and
          does not change even if the repository item is renamed or moved.
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
        examples:
          unique ID:
            value: '*YK_q3iKGm3WUlAzo'
      - name: from-repository
        in: query
        description: Optional parameter then enables server-side copy or move of repository
          items. Instead of providing data in the request body the source is provided
          as a path by this query parameter.
        schema:
          type: string
        examples:
          path:
            value: /Users/knime/Examples/00_Components/Automation/AutoMLCopy
      - name: move
        in: query
        description: "Optional parameter that is used in combination with the from-repository\
          \ parameter. If the latter is set and this parameter is true a server-side\
          \ move will be performed instead of a server-side copy. Deprecated, use\
          \ PUT /repository/{id}/path instead for moving repository items."
        deprecated: true
        schema:
          type: boolean
      responses:
        "201":
          description: Response in case a new item has been created by the operation.
            The Location header will contain the link to the item.
        "200":
          description: Returns the external representation the existing target item
            in the workflow repository.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/RepositoryItem"
            application/json; profile=knime.com/cloud.repository.workflow.simple.v20190220:
              schema:
                $ref: "#/components/schemas/SimpleWorkflow"
            application/json; profile=knime.com/cloud.repository.component.simple.v20190725:
              schema:
                $ref: "#/components/schemas/SimpleComponent"
            application/json; profile=knime.com/cloud.repository.workflow.detailed.v20190725:
              schema:
                $ref: "#/components/schemas/DetailedWorkflow"
            application/json; profile=knime.com/cloud.repository.component.detailed.v20190725:
              schema:
                $ref: "#/components/schemas/DetailedComponent"
        "404":
          description: This error is returned if either the parent workflow group
            of the target location doesn't exist or in case of a server-side copy/move
            operation if the source location doesn't exist.
        "400":
          description: This error is returned if for example an item already exists
            at the target location but doesn't have the same type as the source item
            (either for an upload or a server-side copy/move operation)
        "403":
          description: Response if the requester does not have permission to upload
            to the given location
        "401":
          description: Response if the request is unauthenticated
