            - $ref: "#/components/schemas/SearchComponent"
        startingAfter:
          description: pointer to the next page. Not returned with the last page.
          type: string
          example: '*vpE_LTbAOn96ZOg9'
    WorkflowGroupList:
      description: a list of workflow groups
      type: array
      items:
        $ref: "#/components/schemas/WorkflowGroup"
    SearchComponent:
      required:
      - title
      - itemType
      - tags
      - pathToResource
      - id
      - owner
      - breadcrumb
      - icon
