        outPorts:
          description: an array of all outports
          type: array
          items:
            $ref: "#/components/schemas/ComponentPortInfo"
        dialog:
          description: an array of dialog options
          type: array
          items:
            $ref: "#/components/schemas/Dialog"
        views:
          description: name/description of all nodes producing an interactive view
