            example: true
          aggregatedLinkedComponents:
            description: An array of all linked components in the component
            type: array
            items:
              $ref: "#/components/schemas/AggregatedComponentInstance"
      - $ref: "#/components/schemas/BasicComponentMetaInfo"
    AggregatedWorkflowMetaInfo:
      allOf:
