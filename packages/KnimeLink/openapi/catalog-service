      - required:
        - description
        - keywords
        - dialog
        - bundleInformation
        - icon
        - deprecated
        - streamable
        - views
        - inPorts
        - outPorts
        - links
        - kudos
        - dynInPorts
        - dynOutPorts
        type: object
        properties:
          description:
            description: node's description including HTML tags
            type: string
          shortDescription:
            description: node's short description
            type: string
          keywords:
            description: node's keywords
            type: array
            items:
              type: string
          dialog:
            type: array
            items:
              $ref: "#/components/schemas/NodeDialogSectionInfo"
          views:
            type: array
            items:
              $ref: "#/components/schemas/NodeFieldInfo"
          interactiveView:
            $ref: "#/components/schemas/NodeFieldInfo"
          links:
            description: array of more information links
            type: array
            items:
              $ref: "#/components/schemas/LinkInfo"
          bundleInformation:
            $ref: "#/components/schemas/BundleInfo"
