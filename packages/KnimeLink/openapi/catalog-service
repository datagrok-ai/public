        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/RenameSpaceRequestBody"
      responses:
        "200":
          description: The repository item was successfully moved or renamed. Returns
            the moved item.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Space"
        "400":
          description: |-
            Response if
              - The item to rename is not a space
              - The new name is the same as the current name of the space
              - `force=false` and `If-Target-Match` is provided — always rejected.
        "401":
          description: Response if the request is unauthenticated.
        "403":
          description: Response if the requester does not have permission to rename
            the space.
        "404":
          description: Response if the space with the given ID does not exist.
        "409":
          description: Response if there is an existing space that would be overwritten
            and the rename is not forced.
        "412":
          description: |-
            Response if
              - The current Etag of the target item does not match the provide Etag
              - The request includes `If-None-Match` and the source item *does* exist with a matching ETag.
              - The request includes `If-Match` and the source item does *not* exist or its ETag does not match.
