            application/json; profile=knime.com/cloud.repository.node.list.basic.v20190220:
              schema:
                $ref: "#/components/schemas/BasicNodeMetaInfoList"
            application/json; profile=knime.com/cloud.repository.node.list.minimum.v20190220:
              schema:
                $ref: "#/components/schemas/MinimumNodeMetaInfoList"
        "400":
