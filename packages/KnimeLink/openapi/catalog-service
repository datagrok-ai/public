        "204":
          description: "Response for successful deletion,  or if there are no items\
            \ in the trash bin,  or if the trash bin does not exist (no items have\
            \ been deleted yet)."
        "403":
          description: Response if the authenticated user does not have permissions
            for any space in the give account root or in the specified space
        "401":
          description: Response if the request is unauthenticated.
        "404":
          description: Response if no account root associated with the give account
            id exists.
        "400":
          description: Response if the specified space id is not contained in the
            account root.
  /accountRoots/{accountId}/trash/{trashItemId}:
    post:
      tags:
      - AccountRoots
      summary: Restores the given repository item from the trash bin to the last know
        location. If this location does not exist anymore the item gets moved to the
        top level directory of the space of the bin.
      operationId: restoreTrashItem
      parameters:
      - name: accountId
        in: path
        description: The account id of a user or team.
        required: true
        schema:
          type: string
        examples:
          accountId:
            value: account:team:a885bb42-d808-4557-9a7f-9f10c5777739
      - name: trashItemId
        in: path
        description: The id of an item in the trash of the given account root.
        required: true
        schema:
          type: string
      responses:
        "204":
          description: Response for successful restoring of repository item
        "403":
          description: Response if the user does not have permission to restore items
            from the trash bin.
        "401":
          description: Response if the request is unauthenticated.
        "404":
          description: Response if no account root associated with the give account
            id exists.
    delete:
      tags:
      - AccountRoots
      summary: Permanently deletes a single item from the trash bin in the given account
        root.
      operationId: deleteTrashItem
      parameters:
      - name: accountId
        in: path
        description: The account id of a user or team.
        required: true
        schema:
          type: string
        examples:
          accountId:
            value: account:team:a885bb42-d808-4557-9a7f-9f10c5777739
      - name: trashItemId
        in: path
        description: The id of an item in the trash of the given account root.
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
        examples:
          id:
            value: '*YK_q3iKGm3WUlAzo'
      responses:
        "204":
          description: "Response for successful deletion,  or if the the target item\
            \ does not exist,  or if the trash bin does not exist (no items have been\
            \ deleted yet)."
        "403":
          description: Response if the user does not have permission to delete items
            in the trash bin.
        "401":
          description: Response if the request is unauthenticated.
        "404":
          description: Response if no account root associated with the give account
            id exists.
        "400":
          description: Response if the item is not contained in the account root or
            in the trashbin.
  /repository/{parentId}/manifest:
    post:
      tags:
      - Repository
      - Uploads
      summary: Prepares the upload of one or more repository items.
      description: |-
        Prepares the upload of one or more repository items with the given content types to the given paths relative to
        the given common parent.

        Uploads prepared via this endpoint **must** be either completed or aborted by the client via the respective
        endpoints in a timely manner. Uploads that are not completed will expire after a certain period of time and all
        uploaded data will be discarded.

        Each repository item can be uploaded either as a whole (i.e. in a single part) or in multiple parts. The number
        of parts into which to split the upload of an item does *not* need to be known by the client in advance. The
        uploads of additional parts of an item can be prepared by calling the respective endpoint.

        For each part of each repository item prepared by a request to this endpoint, the endpoint returns the
        specification of a request (including the HTTP method, the target URL, and mandatory headers) that the client is
        instructed to use in order to perform the actual upload of the part's data. The prepared requests are only valid
        for a certain period of time. After that, they need to be refreshed individually by calling the respective
        endpoint.
      parameters:
      - name: parentId
        in: path
        description: The ID of the parent where the items will be uploaded into.
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
        example: '*YK_q3iKGm3WUlAzo'
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/PrepareUploadRequestBody"
      responses:
        "202":
          description: The uploads have been prepared and can be started by the client.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/PrepareUploadResponseBody"
        "400":
          description: |-
            Response if
            - The parent with the given ID is not a space or workflow group.
            - The name of the item in any of the relative paths is invalid.
            - The provided content type of any of the items was not understood or is not supported.
            - The requested initial part count of any of the items exceeds the minimum (0) or maximum (500) values.
            - The number of initial parts over all items exceeds the maximum value (500).
        "401":
          description: The client is not authenticated.
        "403":
          description: The client does not have permission to upload to the given
            parent.
        "404":
          description: The parent does not exist.
  /uploads/{uploadId}/parts:
    post:
      tags:
      - Uploads
      summary: Prepares the upload of a part of a repository item.
      description: |-
        Prepares the upload of the part with the given number within the scope of the upload with the given ID.

        Returns the specification of a request (including the HTTP method, the target URL, and mandatory headers) that
        the client is instructed to use in order to perform the actual upload of the part's data. The prepared request
        is only valid for a certain period of time. After that, a new request needs to be prepared by calling this
        endpoint again.
      parameters:
      - $ref: "#/components/parameters/uploadId"
      - name: partNumber
        in: query
        description: The (one-based) number of the part.
        required: true
        schema:
          maximum: 10000
          minimum: 1
          type: integer
          example: 1
      responses:
        "200":
          description: The part upload has been prepared and can be started by the
            client.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/PreparePartUploadResponseBody"
        "400":
          description: |-
            Reponse if
            - The given upload ID is invalid.
            - The upload with the given ID had already been completed or aborted.
            - The given part number exceeds the minimum (1) or maximum (10,000) values.
        "401":
          description: The client is not authenticated.
        "403":
          description: The client does not have permission to upload the given part.
        "404":
          description: The upload does not exist.
  /uploads/{uploadId}:
    post:
      tags:
      - Uploads
      summary: Completes an upload.
      description: |-
        Completes the upload with the given ID.

        Completing the upload of a repository item requires specifying the list of parts that the client has uploaded
        for the item. Optionally, each part's ETag can be specified, if it was returned with the response of the actual
        upload of its data via its prepared upload request.
      parameters:
      - $ref: "#/components/parameters/uploadId"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CompleteUploadRequestBody"
      responses:
        "204":
          description: The upload has been completed.
        "400":
          description: |-
            Response if
            - The given upload ID is invalid.
            - The upload with the given ID had already been aborted.
            - The specified part numbers do not form a continuous sequence starting at one, i.e. there are "holes" in
            the list of part numbers.
            - Any of the specified parts is missing server side, i.e. its part number does not exist or its ETag does
            not match, if the ETag was provided.
            - Any of the specified parts exceeds the minimum (5 MB) or maximum (5 GB) part sizes.
            - The specified parts are not equal in size. Only the part with the highest part number may have a different
            size.
            - ETags were specified for some parts, but not for others. Clients must either specify ETags for all parts or
            for none.
        "401":
          description: The client is not authenticated.
        "403":
          description: The client does not have permission to complete the given upload.
        "404":
          description: The upload does not exist.
    delete:
      tags:
      - Uploads
      summary: Aborts an upload.
      description: Aborts the upload with the given ID.
      parameters:
      - $ref: "#/components/parameters/uploadId"
      responses:
        "204":
          description: The upload has been aborted or had already been aborted.
        "400":
          description: |-
            Response if
            - The given upload ID is invalid.
            - The upload with the given ID had already been completed.
        "401":
          description: The client is not authenticated.
        "403":
          description: The client does not have permission to abort the given upload.
        "404":
          description: The upload does not exist.
  /uploads/{uploadId}/status:
    get:
      tags:
      - Uploads
      summary: Retrieves the status of an upload.
      description: Retrieves the status of the upload with the given ID.
      parameters:
      - $ref: "#/components/parameters/uploadId"
      responses:
        "200":
          description: The status of the upload.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/UploadStatus"
        "401":
          description: The client is not authenticated.
        "403":
          description: The client does not have permission to view the upload.
        "404":
          description: The upload does not exist.
  /uploads/status:
    get:
      tags:
      - Uploads
      summary: Retrieves the statuses of multiple uploads.
      description: Retrieves the statuses of the uploads with the given IDs.
      parameters:
      - name: uploadIds
        in: query
        description: a comma-separated list of upload IDs
        required: true
        explode: false
        schema:
          type: array
          items:
            $ref: "#/components/schemas/UploadId"
      responses:
        "200":
          description: The upload statuses.
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/UploadStatus"
        "400":
          description: |-
            Response if
            - uploadIds is missing or empty
            - uploadIds contains duplicate IDs
        "401":
          description: The client is not authenticated.
        "403":
          description: The client does not have permission to view one or more of
            the uploads.
        "404":
          description: At least one of the uploads does not exist.
  /repository/{id}/artifact:
    get:
      tags:
      - Repository
      - Downloads
      summary: Prepares the download of a repository item.
      description: "Prepares the download of the repository item with the given ID.\
        \ If the repository item is a workflow group, space, or account root, it will\
        \ be downloadable as a single archive."
      parameters:
      - name: id
        in: path
        description: The ID of the repository item whose download to prepare.
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
        example: '*VEvcDI7F11RSpgPo'
      - name: version
        in: query
        description: |-
          Optional query parameter which specifies the version of the item to download.
          One of:
            - The version number of an existing item version. Must be a positive integer.
            - The special value 'most-recent', which points to the latest version of the item.
            - The special value 'current-state', which points to the latest overall state of the item, i.e. including
              unversioned changes. Note that this is the only valid option for items that do not support versioning.
        required: false
        schema:
          default: current-state
          oneOf:
          - minimum: 1
            type: integer
            example: 1
          - enum:
            - current-state
            - most-recent
            type: string
            example: current-state
      responses:
        "200":
          description: "The download is being prepared. In case of a leaf repository\
            \ item a download URL is directly returned, else a download ID is returned\
            \ which can be used to poll for updates."
          content:
            application/json:
              schema:
                oneOf:
                - $ref: "#/components/schemas/PrepareDownloadResponseBody"
                - $ref: "#/components/schemas/LeafItemDownloadResponseBody"
        "400":
          description: |-
            Response if
            - The given ID refers to a repository item above the account root level, the trash bin, or some other type
              of item that cannot be downloaded.
            - The requested item is a workflow group, space, or account root, and the number or total size of its
              elements exceeds the limit.
            - The requested item is not a leaf item and 'version' is specified with a value different from
              'current-state'
        "401":
          description: The client is not authenticated.
        "403":
          description: The client does not have permission to download the given item.
        "404":
          description: The item does not exist or does not exist in the requested
            version.
        "429":
          description: The client has reached the maximum number of downloads that
            can be in preparation at the same time.
  /downloads/{downloadId}/status:
    get:
      tags:
      - Downloads
      summary: Retrieves the status of a download in preparation.
      description: Retrieves the status of the download with the given ID.
      parameters:
      - name: downloadId
        in: path
        description: The ID of the download job
        required: true
        schema:
          type: string
        example: d63ec9e1-24a7-4015-82b4-476ca4f4a57b
      responses:
        "200":
          description: The status details of the download.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/DownloadStatusResponseBody"
        "401":
          description: The client is not authenticated.
        "403":
          description: The client does not have permission to retrieve the status
            of the download.
        "404":
          description: The download does not exist.
  /components/{id}/updates:
    get:
      tags:
      - Components
      - Downloads
      summary: Checks a component for updates and downloads it if there are any.
      description: "Checks the component with the given ID for updates. If are there\
        \ any updates, the client will be redirected to a URL where it can download\
        \ the updated component. Whether there are any updates is determined based\
        \ on the `If-Modified-Since` header specified by the client."
      parameters:
      - name: id
        in: path
        description: The ID of the component to check for updates.
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
        example: '*VEvcDI7F11RSpgPo'
      - name: If-Modified-Since
        in: header
        required: false
        schema:
          format: date-time
          type: string
          example: "Wed, 17 Oct 2023 07:28:00 GMT"
      - name: version
        in: query
        description: |-
          Optional query parameter which specifies the version of the item to retrieve.
          One of:
            - The version number of an existing item version. Must be a positive integer.
            - The special value 'most-recent', which points to the latest version of the item.
            - The special value 'current-state', which points to the latest overall state of the item, i.e. including
              unversioned changes. Note that this is the only valid option for items that do not support versioning.
        required: false
        schema:
          default: current-state
          oneOf:
          - minimum: 1
            type: integer
            example: 1
          - enum:
            - current-state
            - most-recent
            type: string
            example: current-state
      responses:
        "304":
          description: Nothing has changed since the date specified in the `If-Modified-Since`
            header.
        "307":
          description: The component has changed and the client will be redirected
            to a download URL.
        "400":
          description: The given ID does not refer to a component.
        "401":
          description: The client is not authenticated while trying to check for updates
            of a private component.
        "403":
          description: The client does not have permission to check the component
            for updates or to download the component.
        "404":
          description: The component does not exist.
  /recentItems:
    get:
      tags:
      - Recent Items
      summary: List most recently accessed items for the requester
      description: List most recently accessed items for the requester
      operationId: getRecentItemsForRequester
      parameters:
      - name: limit
        in: query
        description: Maximum number of items to return
        required: false
        schema:
          default: 20
          maximum: 100
          minimum: 1
          type: integer
      - name: accountId
        in: query
        description: |-
          the ID of the account to which the recently accessed items should belong, if not provided all recent items
          are returned
        required: false
        schema:
          type: string
          example: account:team:ed551ed7-4caa-4a0c-8a53-160c6909d0cb
      - name: itemTypes
        in: query
        description: A list of item types which should be returned
        required: false
        schema:
          type: array
          items:
            enum:
            - Workflow
            type: string
      responses:
        "200":
          description: A list of recently accessed items
          content:
            application/json:
              schema:
                required:
                - items
                type: object
                properties:
                  items:
                    type: array
                    items:
                      required:
                      - type
                      - id
                      - canonicalPath
                      - owner
                      - ownerAccountId
                      - lastAccessedByRequesterOn
                      type: object
                      properties:
                        type:
                          description: the type of the item
                          type: string
                          example: Workflow
                        id:
                          description: the ID of the item
                          type: string
                          example: '*77lOUCZqZ94-_wF0'
                        canonicalPath:
                          description: the canonical path of the item
                          type: string
                          example: /Users/account:team:a885bb42-d808-4557-9a7f-9f10c5777739/spaceName/groupName/workflowName
                        owner:
                          description: |-
                            the name of the account which owns the item, if using "accountId" query param should be the
                            name of that account
                          type: string
                          example: KNIME Team
                        ownerAccountId:
                          description: |-
                            the ID of the account which owns the item, if using "accountId" query param should be the
                            name of that account
                          type: string
                          example: account:team:a885bb42-d808-4557-9a7f-9f10c5777739
                        lastAccessedByRequesterOn:
                          description: the date the requester last accessed this item
                          type: string
                          example: 2012-07-19T17:20:26+02:00
                        '@controls':
                          description: list allowed actions on item
                          type: object
                          properties:
                            self:
                              description: if present the requester still has read
                                access to this item
                              type: object
                              properties:
                                href:
                                  description: URL to retrieve the item's metadata
                                  type: string
                                  example: http://localhost/repository/path-to-item
                                method:
                                  description: The http method
                                  type: string
                                  example: GET
                            edit:
                              description: |-
                                if present the requester still has write access to this item, note this does not
                                guarantee that the item can be edited via an execution context
                              type: object
                              properties:
                                href:
                                  description: The URL which can be used to edit the
                                    item
                                  type: string
                                  example: http://localhost/repository/path-to-item:data
                                method:
                                  description: The http method
                                  type: string
                                  example: PUT
                                accept:
                                  description: the body types the request accepts
                                  type: array
                                  items:
                                    type: string
                                    example: '*/*'
                                encoding:
                                  description: encoding of the request
                                  enum:
                                  - None
                                  - Json
                                  - JsonPlusFiles
                                  - Raw
                                  type: string
                                  example: Raw
                                title:
                                  description: title of the entry
                                  type: string
                                  example: upload data
                        '@namespaces':
                          description: namespaces of the request
                          type: object
                          properties:
                            knime:
                              type: object
                              properties:
                                name:
                                  type: string
                                  example: http://localhost
        "400":
          description: "the requested accountId is invalid, or limit is outside allowed\
            \ range, or itemType is invalid"
        "401":
          description: auth was not provided
        "403":
          description: Requester does not have permission to requested account
components:
  schemas:
    RepositoryItem:
      required:
      - path
      - id
      - type
      - owner
      - author
      - createdOn
      - downloadCount
      - _class
      type: object
      properties:
        path:
          description: The item's absolute path in the repository.
          type: string
          example: /KNIME_project
        id:
          description: The item's unique ID which does not change when the item is
            renamed or moved.
          pattern: "^\\*[0-9a-zA-Z_\\-]{16}$"
          type: string
          example: '*77lOUCZqZ94-_wF0'
        type:
          enum:
          - WorkflowGroup
          - Workflow
          - WorkflowTemplate
          - Component
          - Data
          - Snapshot
          - Trash
          - Space
          type: string
        owner:
          description: The item's owner
          type: string
          example: knime
        ownerAccountId:
          description: The item's owner account ID
          type: string
          example: account:user:ed551ed7-4caa-4a0c-8a53-160c6909d0cb
        author:
          description: The item's author
          type: string
          example: Sam Smith
        createdOn:
          description: The date when the item was initially created.
          type: string
          example: 2018-02-06T17:20:26+01:00
        itemVersionId:
          description: The item version ID.
          type: string
          example: bbcc4621-d88f-4a94-ae2f-b38072bf5087
        itemVersion:
          description: The version of the item. Will only be returned if the item
            has a named version.
          type: integer
          example: 1
        itemVersionCreatedOn:
          description: The date and time when the item version was created.
          type: string
          example: 2018-02-06T17:20:26+01:00
        _class:
          description: The API class representing this item
          type: string
          example: com.knime.enterprise.server.rest.api.v4.repository.ent.WorkflowGroup
        description:
          description: An optional plain text description for this item
          type: string
          example: This workflow is part of the model factory eco system. Please refer
            to our white paper for further details.
        richDescription:
          description: An optional rich description for this item
          type: string
          example: <h5>A Heading</h5><p><strong>Hello</strong> World</p><p class="small-text">Some
            <u>small</u> text.</p> <br /><u>Underlined</u><blockquote><p>Some famous
            quote here</p></blockquote>
        downloadCount:
          description: A count of how many times this item has been downloaded if
            no If-Modified-Since header was set.
          default: 0
          type: integer
          example: 34
        updateCount:
          description: A count of how many times the requested item was downloaded
            because an update was available. Corresponds to a successful If-Modified-Since
            header precondition check.
          default: 0
          type: integer
          example: 15
        kudosCount:
          description: The number of kudos this item has
          type: integer
          example: 33
        updateCheckCount:
          description: A count of how many times the requested item was requested
            but not downloaded because there was no updated available. Corresponds
            to a failing If-Modified-Since header precondition check.
          default: 0
          type: integer
          example: 26
        canonicalPath:
          description: "the canonical path to the item in the catalog, this differs\
            \ from the 'path' field in that it does not reference accounts by names\
            \ but instead by IDs"
          type: string
          example: /Users/account:team:a885bb42-d808-4557-9a7f-9f10c5777739/spaceName/groupName/workflowName
        itemVersionCreatedBy:
          description: "the name of the user who created this item version, if the\
            \ name cannot be determined '<unknown>' is returned"
          type: string
          example: knime
        itemVersionCreatedByAccountId:
          description: the account ID of the user who created this item version
          type: string
          example: account:user:a885bb42-d808-4557-9a7f-9f10c5777739
      discriminator:
        propertyName: _class
    RepositoryItemAsMason:
      allOf:
      - type: object
        properties:
          '@controls':
            description: A (possibly empty) map with all controls for this object.
            type: object
            additionalProperties:
              $ref: "#/components/schemas/Control"
          '@namespaces':
            description: A (possibly empty) map with the namespaces for this object.
            type: object
            additionalProperties:
              $ref: "#/components/schemas/Namespace"
          '@error':
            $ref: "#/components/schemas/Error"
      - $ref: "#/components/schemas/RepositoryItem"
    WorkflowGroup:
      allOf:
      - type: object
        properties:
          children:
            description: The workflow group's children.
            type: array
            items:
              $ref: "#/components/schemas/RepositoryItemAsMason"
      - $ref: "#/components/schemas/RepositoryItemAsMason"
    Space:
      allOf:
      - required:
        - lastEditedOn
        - private
        - contributors
        - tags
        - accesses
        type: object
        properties:
          lastEditedOn:
            description: The date when the space metadata was last edited.
            type: string
            example: 2018-09-27T14:51:41+02:00
          private:
            description: "true if the space is private, otherwise false"
            type: boolean
          contributors:
            description: an array of usernames for users who are collaborators
            type: array
            items:
              type: string
          accesses:
            description: an array of objects describing accesses on this item
            type: array
            items:
              type: object
              properties:
                identity:
                  description: the ID of the identity that has access on the item
                  type: string
                  deprecated: true
                role:
                  description: the ID of the role that defines the permissions the
                    identity has on the item
                  type: string
                accountId:
                  description: the account ID of the account the has access on the
                    item
                  type: string
                fullyQualifiedAccountId:
                  description: the fully qualified account ID of the account the has
                    access on the item
                  type: string
          stats:
            $ref: "#/components/schemas/SpaceCounts"
          kudos:
            description: an array of kudos given to this space
            type: array
