                $ref: "#/components/schemas/ResourceIndex"
        "400":
          description: Response if a type in the types query parameter is not recognized
            or allowed.
  /nodes:
    get:
      tags:
      - Node Catalog
      summary: "Returns a list of nodes in the server node catalog. If no query parameter\
