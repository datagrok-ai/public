      - name: id
        in: path
        description: The ID of the space to rename.
        required: true
        schema:
          pattern: "\\*[0-9a-zA-Z_\\-]{16}"
          type: string
        example: '*YK_q3iKGm3WUlAzo'
      requestBody:
        description: "The new name for the space, and whether to force the rename,\
