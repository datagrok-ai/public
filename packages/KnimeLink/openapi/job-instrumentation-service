              example: data-app
            scope:
              description: The scope of the deployment.
              type: string
              example: account:team:43d30780-8321-44d3-9a93-ca8ac649c9dd
            creator:
              description: The creator of the deployment.
              type: string
              example: account:user:43d30780-8321-44d3-9a93-ca8ac649c9dd
    JobInfoList:
