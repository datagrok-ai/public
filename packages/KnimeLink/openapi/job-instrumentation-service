  parameters:
    FilterQuery:
      name: q
      in: query
      description: |
        An optional filter to only show the jobs that match the filter. Only a single attribute can be used for filtering right now.
        Available attributes are:
          - `creator`: the account ID of the creator of the job
          - `initiatorId`: the account ID of the initiator of the job
          - `workflowId`: the ID of the workflow the job was created from
          - `executionContextId`: the ID of the execution context in which the job was created
          - `deploymentId`: the ID of the deployment from which the job was created
      schema:
        type: string
      examples:
        creator:
          value: creator=account:user:43d30780-8321-44d3-9a93-ca8ac649c9dd
          summary: Filter by the creator of the job.
        deploymentId:
          value: deploymentId=data-app:43d30780-8321-44d3-9a93-ca8ac649c9dd
          summary: Filter by the deployment of the job.
    SortQuery:
      name: sort
      in: query
      description: |
        An optional parameter for sorting. By default results are sorted in ascending order. If you prefix the attribute with `-` the sort order is descending.
        Available attributes for sorting are:
          - `id`: the ID of the job
          - `workflowId`: the ID of the workflow
          - `itemVersion`: the version of the workflow
          - `jobState`: the last state of the job
          - `workflowState`: the last state of the job's workflow
          - `creator`: the ID of the job's creator
          - `initiatorId`: the account ID of the initiator of the job
          - `deploymentId`: the ID of the deployment from which the job was created
          - `startedAt`: the execution starting time of the job
          - `finishedAt`: the execution finished time of the job
          - `createdAt`: the creation time of the job
      schema:
        default: -createdAt
        type: string
      examples:
        nonDescending:
          value: jobState
          summary: sort by string value of state in ascending order
        nonAscending:
          value: -jobState
          summary: sort by string value of state in descending order
    JobSortQuery:
      name: sort
      in: query
      description: |
        An optional parameter for sorting. By default results are sorted in descending order by 'createdAt' (i.e., '-createdAt'). If you provide an attribute without a prefix, sorting is ascending. If you prefix the attribute with `-` the sort order is descending.  You can provide multiple attributes separated by commas. The default sorting is `-createdAt`. Available attributes for sorting are:
          - `createdAt`: the creation time of the job
      schema:
        default: -createdAt
        type: string
      examples:
        nonDescending:
          value: createdAt
          summary: sort by creation timestamp in ascending order
        nonAscending:
          value: -createdAt
          summary: sort by creation timestamp in descending order
    PageQuery:
      name: page
      in: query
      description: The page number to be returned. If not provided the first page
        will be returned.
      schema:
        type: integer
      example: 1
    PagelenQuery:
      name: pagelen
      in: query
      description: The number of items to be displayed in a single page. If not provided
        the maximum allowed length is used.
      schema:
        default: 100
        maximum: 100
        minimum: 1
        type: integer
      example: 20
    CursorQuery:
      name: cursor
      in: query
      description: "The cursor for the next page. It is provided by the previous response,\
        \ you cannot construct it yourself."
      schema:
        type: string
      example: eyJzIjpbIi1uYW1lIl0sImx2IjpbInVzZXIxIl0sInEiOiJqb2JTdGF0ZT1MT0FESU5HIn0
    PreferHeader:
      name: Prefer
      in: header
      description: "Controls how much HATEOS information should be in the response.\
        \ By default the response contains full Mason information, i.e. both the possible\
        \ actions and their corresponding hyperlinks. If you pass `representation=minimal`\
        \ no Mason controls will be sent. If you pass `representation=basic` only\
        \ the possible actions without any hyperlinks and description will be sent."
      schema:
        enum:
        - representation=minimal
        - representation=basic
        type: string
  securitySchemes:
    SecurityScheme:
      type: http
      scheme: bearer
      bearerFormat: JWT
      description: Authentication
