{
  "$schema": "https://datagrok.ai/schemas/domain-schema.schema.json",
  "name": "apitests",
  "version": "1.1.0",
  "tables": {
    "item": {
      "securityMode": "row",
      "businessKey": ["sku"],
      "description": "Fixture table for grok.dapi.domains ApiTests",
      "columns": {
        "sku": {"type": "string", "required": true, "unique": true},
        "name": {"type": "string"},
        "quantity": {"type": "int", "min": 0}
      },
      "schemas": ["item_meta"]
    },
    "item_event": {
      "securityMode": "master",
      "delegate": "item_id",
      "description": "Detail table for transaction/$ref and expand ApiTests",
      "columns": {
        "item_id": {"type": "ref", "ref": "item", "onDelete": "cascade", "required": true},
        "kind": {"type": "string", "required": true},
        "amount": {"type": "int"}
      }
    }
  },
  "propertySchemas": {
    "item_meta": {
      "note": {"type": "string"}
    }
  }
}
