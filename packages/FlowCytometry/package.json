    "datagrok-api": "^1.27.0",
    "rxjs": "^6.5.5"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "css-loader": "^5.0.0",
    "datagrok-tools": "^5.0.0",
    "eslint": "^8.1.0",
