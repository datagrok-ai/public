{
  "name": "@datagrok/flow-cytometry",
  "friendlyName": "FlowCytometry",
  "version": "0.1.0",
  "description": "Flow cytometry support: import, visualize, and analyze FCS files",
  "author": {
    "name": "Andrew Skalkin",
    "email": "askalkin@datagrok.ai"
  },
  "dependencies": {
